+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Smoke tests for ``vllm.calibration_block_outputs``.
+
+These exercise the env-gate contract, the subset-close gate (the
+distinctive feature of the block-outputs writer relative to the other
+writers), multi-layer rank-ordering correctness, the payload shape +
+per-batch concatenation contract, checkpoint round-trip + subset-close
+preservation, and the per-layer sidecar dump.
+
+Tests:
+
+1. ``test_env_gate_off_no_op`` -- env unset → ``setup()`` and the
+   callback are no-ops (accumulators untouched).
+2. ``test_subset_close_gate`` -- calling :func:`close_subset` makes
+   subsequent dispatches a no-op even with the env on.
+3. ``test_multi_layer_rank_ordering`` -- multiple layers dispatched in
+   any order populate per-rank buckets honoring the rank table built
+   by setup().
+4. ``test_payload_shape_concat_across_batches`` -- two batches of
+   different ``n_tok`` concatenate along dim 0 into one
+   ``[n_tokens_total, hidden]`` slab per rank.
+5. ``test_checkpoint_round_trip`` -- dump → reload module →
+   load_checkpoint restores byte-identical accumulator state, the
+   subset-closed flag, and the cumulative prompt counter.
+6. ``test_dump_produces_per_layer_sidecars`` -- ``dump_block_outputs``
+   calls ``save_block_hidden`` once per populated rank with the
+   correct ``layer_idx`` keyed by ``_RANK_TO_LAYER_ID``.
+7. ``test_dump_truncates_on_over_collection_uniform`` -- when the
+   driver over-collects past ``_SUBSET_SIZE`` and the per-prompt token
+   count is uniform, the dumped tensor is truncated to exactly
+   ``_SUBSET_SIZE * tokens_per_prompt`` rows and
+   ``n_prompts_in_subset == _SUBSET_SIZE``.
+8. ``test_dump_no_truncate_on_variable_length`` -- when the driver
+   over-collects but the per-prompt token count is variable (total
+   tokens does not divide evenly by accumulated prompts), the tensor
+   is shipped as-is and the operator is warned.
+"""
+from __future__ import annotations
+
+import importlib
+import os
+import sys
+from typing import Any
+
+import torch
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+
+def _reload_bo(env: dict[str, str]) -> Any:
+    """Reload ``vllm.calibration_block_outputs`` (and hooks) with a fresh env.
+
+    Module-level ``_CAPTURE_BLOCK_OUTPUTS`` + ``_SUBSET_SIZE`` are
+    sampled at import; per-test isolation requires a fresh import.
+    """
+    sys.modules.pop("vllm.calibration_block_outputs", None)
+    sys.modules.pop("vllm.calibration_hooks", None)
+    for key in (
+        "VLLM_CALIB_CAPTURE_BLOCK_OUTPUTS",
+        "VLLM_CALIB_BLOCK_OUTPUTS_SUBSET_SIZE",
+        "VLLM_CALIB_CAPTURE_BLOCK",
+        "VLLM_CALIB_CAPTURE_OUTPUT_RESERVOIR",
+        "VLLM_CALIB_OUTPUT_RESERVOIR_CAP",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED",
+        "VLLM_CALIB_CAPTURE_REAP_SCORES",
+        "VLLM_CALIB_CAPTURE_ROUTER",
+        "VLLM_CALIB_CAPTURE_IMATRIX",
+        "VLLM_CALIB_CAPTURE_EXPERT",
+        "VLLM_CALIB_CAPTURE_EXPERT_MID",
+        "VLLM_CALIB_CAPTURE_INPUT_COV",
+        "VLLM_CALIB_CAPTURE_PER_EXPERT_MAX",
+    ):
+        os.environ.pop(key, None)
+    for k, v in env.items():
+        os.environ[k] = v
+    importlib.import_module("vllm.calibration_hooks")
+    return importlib.import_module("vllm.calibration_block_outputs")
+
+
+def _seed_layer(bo: Any, layer_idx: int, rank: int, n_experts: int = 4) -> None:
+    """Manually wire up the per-layer rank table the way setup() would."""
+    bo._LAYER_ID_TO_RANK[layer_idx] = rank
+    bo._RANK_TO_LAYER_ID[rank] = layer_idx
+    if rank + 1 > bo._N_LAYERS:
+        bo._N_LAYERS = rank + 1
+    if n_experts > bo._N_EXPERTS:
+        bo._N_EXPERTS = n_experts
+
+
+# ---------------------------------------------------------------------------
+# Test 1 -- env-off short-circuit
+# ---------------------------------------------------------------------------
+
+
+def test_env_gate_off_no_op():
+    """Env unset → setup() is a no-op and the callback short-circuits
+    before touching any accumulator."""
+    bo = _reload_bo({})
+    assert bo._CAPTURE_BLOCK_OUTPUTS is False
+
+    # setup() with a stub LLM -> should not register callbacks nor
+    # populate the layer-id-to-rank table.
+    bo.setup(llm=None)
+    assert bo._ACCUM == {}
+    assert bo._LAYER_ID_TO_RANK == {}
+    assert bo._RANK_TO_LAYER_ID == {}
+
+    # Seed the rank table manually + dispatch. The internal env guard
+    # must short-circuit before any allocation.
+    _seed_layer(bo, layer_idx=3, rank=0)
+    output = torch.randn(5, 8, dtype=torch.float32)
+    bo._on_block_out(layer_idx=3, output=output)
+    assert bo._ACCUM == {}
+
+
+# ---------------------------------------------------------------------------
+# Test 2 -- subset-close gate
+# ---------------------------------------------------------------------------
+
+
+def test_subset_close_gate():
+    """``close_subset()`` flips the closed-flag; subsequent dispatches
+    no-op even with the env gate on."""
+    bo = _reload_bo({
+        "VLLM_CALIB_CAPTURE_BLOCK_OUTPUTS": "1",
+        "VLLM_CALIB_BLOCK_OUTPUTS_SUBSET_SIZE": "4",
+        "VLLM_CALIB_CAPTURE_BLOCK": "1",
+    })
+    assert bo._SUBSET_SIZE == 4
+    assert bo._SUBSET_CLOSED is False
+
+    _seed_layer(bo, layer_idx=0, rank=0)
+    output = torch.randn(3, 8, dtype=torch.float32)
+    bo._on_block_out(layer_idx=0, output=output)
+    # First dispatch lands in the accumulator.
+    assert 0 in bo._ACCUM and len(bo._ACCUM[0]) == 1
+    assert bo._ACCUM[0][0].shape == (3, 8)
+    assert bo._ACCUM[0][0].dtype == torch.bfloat16
+
+    # Close the subset.
+    bo.close_subset()
+    assert bo._SUBSET_CLOSED is True
+
+    # Idempotency: calling close_subset twice is harmless.
+    bo.close_subset()
+    assert bo._SUBSET_CLOSED is True
+
+    # Subsequent dispatch is a no-op (rank 0's bucket size stays at 1).
+    output2 = torch.randn(2, 8, dtype=torch.float32)
+    bo._on_block_out(layer_idx=0, output=output2)
+    assert len(bo._ACCUM[0]) == 1
+
+
+# ---------------------------------------------------------------------------
+# Test 3 -- multi-layer rank ordering
+# ---------------------------------------------------------------------------
+
+
+def test_multi_layer_rank_ordering():
+    """Dispatches to multiple layer_idx values populate per-rank buckets
+    honoring the rank table built by setup()."""
+    bo = _reload_bo({
+        "VLLM_CALIB_CAPTURE_BLOCK_OUTPUTS": "1",
+        "VLLM_CALIB_BLOCK_OUTPUTS_SUBSET_SIZE": "32",
+        "VLLM_CALIB_CAPTURE_BLOCK": "1",
+    })
+    # Layer-ids 3, 7, 11 with ranks 0, 1, 2 respectively (matches a
+    # typical MoE-only subset of a mixed dense/MoE decoder stack).
+    _seed_layer(bo, layer_idx=3, rank=0)
+    _seed_layer(bo, layer_idx=7, rank=1)
+    _seed_layer(bo, layer_idx=11, rank=2)
+
+    # Dispatch the layers OUT OF ORDER (7 → 3 → 11). The accumulator
+    # must key by RANK, not by dispatch order.
+    o7 = torch.tensor([[1.0, 2.0], [3.0, 4.0]], dtype=torch.float32)
+    o3 = torch.tensor([[5.0, 6.0]], dtype=torch.float32)
+    o11 = torch.tensor([[7.0, 8.0], [9.0, 10.0], [11.0, 12.0]],
+                       dtype=torch.float32)
+    bo._on_block_out(layer_idx=7, output=o7)
+    bo._on_block_out(layer_idx=3, output=o3)
+    bo._on_block_out(layer_idx=11, output=o11)
+
+    assert set(bo._ACCUM.keys()) == {0, 1, 2}
+    assert bo._ACCUM[0][0].shape == (1, 2)         # rank 0 = layer 3
+    assert bo._ACCUM[1][0].shape == (2, 2)         # rank 1 = layer 7
+    assert bo._ACCUM[2][0].shape == (3, 2)         # rank 2 = layer 11
+
+    # And the contents survive the bf16 round-trip on these small ints.
+    assert torch.equal(
+        bo._ACCUM[0][0],
+        torch.tensor([[5.0, 6.0]], dtype=torch.bfloat16),
+    )
+    assert torch.equal(
+        bo._ACCUM[1][0],
+        torch.tensor([[1.0, 2.0], [3.0, 4.0]], dtype=torch.bfloat16),
+    )
+
+    # Unknown layer_idx -> RuntimeError (no lazy rank growth).
+    try:
+        bo._on_block_out(layer_idx=99, output=o3)
+        raise AssertionError("expected RuntimeError")
+    except RuntimeError as exc:
+        assert "layer_idx=99" in str(exc)
+
+
+# ---------------------------------------------------------------------------
+# Test 4 -- payload shape: concatenation across batches
+# ---------------------------------------------------------------------------
+
+
+def test_payload_shape_concat_across_batches(tmp_path, monkeypatch):
+    """Two batches of different ``n_tok`` concatenate along dim 0 into
+    one ``[n_tokens_total, hidden]`` bf16 slab per rank."""
+    bo = _reload_bo({
+        "VLLM_CALIB_CAPTURE_BLOCK_OUTPUTS": "1",
+        "VLLM_CALIB_BLOCK_OUTPUTS_SUBSET_SIZE": "32",
+        "VLLM_CALIB_CAPTURE_BLOCK": "1",
+    })
+    _seed_layer(bo, layer_idx=5, rank=0)
+
+    batch1 = torch.randn(3, 4, dtype=torch.float32)
+    batch2 = torch.randn(7, 4, dtype=torch.float32)
+    bo._on_block_out(layer_idx=5, output=batch1)
+    bo._on_block_out(layer_idx=5, output=batch2)
+    assert len(bo._ACCUM[0]) == 2
+
+    captured = {}
+
+    def _fake_save(payload, path):
+        captured.setdefault("calls", []).append((payload, path))
+
+    import moe_compress.utils.cached_calibration_signals as ccs
+    monkeypatch.setattr(ccs, "save_block_hidden", _fake_save)
+
+    bo.set_n_prompts_accumulated(20)
+    jsonl = tmp_path / "trace.jsonl"
+    bo.dump_block_outputs(jsonl)
+
+    assert len(captured["calls"]) == 1
+    payload, _ = captured["calls"][0]
+    assert payload.schema_version == 1
+    assert payload.layer_idx == 5
+    # Subset cap is 32, accumulated 20 -> min(20, 32) = 20.
+    assert payload.n_prompts_in_subset == 20
+    assert payload.hidden_states.shape == (10, 4)
+    assert payload.hidden_states.dtype == torch.bfloat16
+
+    # First 3 rows equal batch1 (bf16 round-trip); rows 3..10 equal
+    # batch2.
+    assert torch.equal(
+        payload.hidden_states[:3],
+        batch1.to(torch.bfloat16),
+    )
+    assert torch.equal(
+        payload.hidden_states[3:],
+        batch2.to(torch.bfloat16),
+    )
+
+
+# ---------------------------------------------------------------------------
+# Test 5 -- checkpoint round-trip
+# ---------------------------------------------------------------------------
+
+
+def test_checkpoint_round_trip(tmp_path):
+    """Dump → reload module → load_checkpoint restores byte-identical state.
+
+    Validates the per-rank accumulator lists, the layer-id-to-rank
+    table, the subset-closed flag, the hidden_dim cache, and the
+    cumulative prompt counter all round-trip.
+    """
+    bo = _reload_bo({
+        "VLLM_CALIB_CAPTURE_BLOCK_OUTPUTS": "1",
+        "VLLM_CALIB_BLOCK_OUTPUTS_SUBSET_SIZE": "8",
+        "VLLM_CALIB_CAPTURE_BLOCK": "1",
+    })
+    _seed_layer(bo, layer_idx=2, rank=0)
+    _seed_layer(bo, layer_idx=4, rank=1)
+
+    bo._on_block_out(
+        layer_idx=2,
+        output=torch.tensor([[1.0, 2.0], [3.0, 4.0]], dtype=torch.float32),
+    )
+    bo._on_block_out(
+        layer_idx=4,
+        output=torch.tensor([[5.0, 6.0]], dtype=torch.float32),
+    )
+    bo._on_block_out(
+        layer_idx=2,
+        output=torch.tensor([[7.0, 8.0]], dtype=torch.float32),
+    )
+    bo.set_n_prompts_accumulated(6)
+    bo.close_subset()
+
+    ckpt = str(tmp_path / "test.bo.ckpt")
+    bo.dump_block_outputs_checkpoint(ckpt)
+    assert os.path.exists(ckpt)
+    assert not os.path.exists(ckpt + ".tmp")
+
+    # Fresh module load -- accumulators must hydrate from disk.
+    bo2 = _reload_bo({
+        "VLLM_CALIB_CAPTURE_BLOCK_OUTPUTS": "1",
+        "VLLM_CALIB_BLOCK_OUTPUTS_SUBSET_SIZE": "8",
+        "VLLM_CALIB_CAPTURE_BLOCK": "1",
+    })
+    assert bo2._ACCUM == {}                       # fresh state
+    loaded = bo2.load_block_outputs_checkpoint(ckpt)
+    assert loaded == 6
+    assert bo2.get_n_prompts_accumulated() == 6
+    assert bo2._N_LAYERS == 2
+    assert bo2._LAYER_ID_TO_RANK == {2: 0, 4: 1}
+    assert bo2._RANK_TO_LAYER_ID == {0: 2, 1: 4}
+    assert bo2._SUBSET_CLOSED is True
+    assert bo2._HIDDEN_DIM == 2
+    # Rank 0 had two batches stacked.
+    assert len(bo2._ACCUM[0]) == 2
+    assert torch.equal(
+        bo2._ACCUM[0][0],
+        torch.tensor([[1.0, 2.0], [3.0, 4.0]], dtype=torch.bfloat16),
+    )
+    assert torch.equal(
+        bo2._ACCUM[0][1],
+        torch.tensor([[7.0, 8.0]], dtype=torch.bfloat16),
+    )
+    # Rank 1 had one batch.
+    assert len(bo2._ACCUM[1]) == 1
+    assert torch.equal(
+        bo2._ACCUM[1][0],
+        torch.tensor([[5.0, 6.0]], dtype=torch.bfloat16),
+    )
+
+    # The subset is closed; further dispatches are no-ops.
+    bo2._on_block_out(
+        layer_idx=2,
+        output=torch.tensor([[99.0, 99.0]], dtype=torch.float32),
+    )
+    assert len(bo2._ACCUM[0]) == 2                 # unchanged
+
+
+# ---------------------------------------------------------------------------
+# Test 6 -- per-layer sidecar dump
+# ---------------------------------------------------------------------------
+
+
+def test_dump_produces_per_layer_sidecars(tmp_path, monkeypatch):
+    """``dump_block_outputs`` calls ``save_block_hidden`` once per
+    populated rank with the matching ``layer_idx``."""
+    bo = _reload_bo({
+        "VLLM_CALIB_CAPTURE_BLOCK_OUTPUTS": "1",
+        "VLLM_CALIB_BLOCK_OUTPUTS_SUBSET_SIZE": "16",
+        "VLLM_CALIB_CAPTURE_BLOCK": "1",
+    })
+    # 3 layers; one stays untouched. The dump should write only the
+    # two populated ranks (no zero-rows-empty stub for rank 1).
+    _seed_layer(bo, layer_idx=10, rank=0)
+    _seed_layer(bo, layer_idx=20, rank=1)
+    _seed_layer(bo, layer_idx=30, rank=2)
+
+    bo._on_block_out(layer_idx=10, output=torch.ones(2, 3, dtype=torch.float32))
+    bo._on_block_out(layer_idx=30, output=torch.full((5, 3), 4.0,
+                                                     dtype=torch.float32))
+    bo.set_n_prompts_accumulated(12)
+
+    captured: dict[int, Any] = {}
+
+    def _fake_save(payload, path):
+        captured[payload.layer_idx] = (payload, path)
+
+    import moe_compress.utils.cached_calibration_signals as ccs
+    monkeypatch.setattr(ccs, "save_block_hidden", _fake_save)
+
+    jsonl = tmp_path / "trace.jsonl"
+    bo.dump_block_outputs(jsonl)
+
+    # Only layer_idx 10 + 30 should have been written; 20 was untouched.
+    assert set(captured.keys()) == {10, 30}
+    p10, _ = captured[10]
+    assert p10.layer_idx == 10
+    assert p10.hidden_states.shape == (2, 3)
+    assert p10.n_prompts_in_subset == 12
+
+    p30, _ = captured[30]
+    assert p30.layer_idx == 30
+    assert p30.hidden_states.shape == (5, 3)
+    # All entries are 4.0 (bf16-round-tripped).
+    assert torch.all(p30.hidden_states == 4.0)
+
+
+# ---------------------------------------------------------------------------
+# Test 7 -- truncate on over-collection (uniform per-prompt token count)
+# ---------------------------------------------------------------------------
+
+
+def test_dump_truncates_on_over_collection_uniform(tmp_path, monkeypatch):
+    """When the driver over-collects past ``_SUBSET_SIZE`` AND the
+    per-prompt token count is uniform, ``dump_block_outputs`` truncates
+    the concatenated tensor to exactly
+    ``_SUBSET_SIZE * tokens_per_prompt`` rows and reports
+    ``n_prompts_in_subset == _SUBSET_SIZE`` exactly.
+
+    This is the I1/I2 reachability fix: without truncation the
+    over-collected rows would make the Stage 3 reader's strict
+    ``n_tokens == n_prompts * seq_len`` guard reject every sidecar.
+    """
+    # Subset size = 4, but the driver "over-collects" 6 prompts at
+    # chunk-boundary close. Per-prompt token count is uniform (5).
+    bo = _reload_bo({
+        "VLLM_CALIB_CAPTURE_BLOCK_OUTPUTS": "1",
+        "VLLM_CALIB_BLOCK_OUTPUTS_SUBSET_SIZE": "4",
+        "VLLM_CALIB_CAPTURE_BLOCK": "1",
+    })
+    assert bo._SUBSET_SIZE == 4
+    _seed_layer(bo, layer_idx=5, rank=0)
+
+    # 6 prompts of 5 tokens each -> 30 tokens total dispatched as two
+    # batches (mimicking two chunk-internal forward passes producing
+    # 15 tokens each = 3 prompts each).
+    batch1 = torch.arange(15 * 8, dtype=torch.float32).reshape(15, 8)
+    batch2 = torch.arange(15 * 8, 30 * 8, dtype=torch.float32).reshape(15, 8)
+    bo._on_block_out(layer_idx=5, output=batch1)
+    bo._on_block_out(layer_idx=5, output=batch2)
+    assert sum(t.shape[0] for t in bo._ACCUM[0]) == 30
+
+    # Cumulative prompt counter at dump time: 6 (driver-owned).
+    bo.set_n_prompts_accumulated(6)
+
+    captured: dict[int, Any] = {}
+
+    def _fake_save(payload, path):
+        captured[payload.layer_idx] = (payload, path)
+
+    import moe_compress.utils.cached_calibration_signals as ccs
+    monkeypatch.setattr(ccs, "save_block_hidden", _fake_save)
+
+    jsonl = tmp_path / "trace.jsonl"
+    bo.dump_block_outputs(jsonl)
+
+    assert set(captured.keys()) == {5}
+    payload, _ = captured[5]
+    # The I1+I2 reachability contract: n_prompts_in_subset reports
+    # _SUBSET_SIZE exactly when over-collection occurred.
+    assert payload.n_prompts_in_subset == bo._SUBSET_SIZE == 4
+    # Tensor truncated to subset_size * tokens_per_prompt = 4 * 5 = 20.
+    assert payload.hidden_states.shape == (20, 8)
+    # The truncation preserves the FIRST 20 rows in dispatch order
+    # (batch1's 15 rows + batch2's first 5 rows).
+    expected_first15 = batch1.to(torch.bfloat16)
+    expected_next5 = batch2[:5].to(torch.bfloat16)
+    assert torch.equal(payload.hidden_states[:15], expected_first15)
+    assert torch.equal(payload.hidden_states[15:], expected_next5)
+    # The reader's downstream invariant: tokens / n_prompts_in_subset
+    # divides cleanly back to the per-prompt token count.
+    assert payload.hidden_states.shape[0] % payload.n_prompts_in_subset == 0
+
+
+# ---------------------------------------------------------------------------
+# Test 8 -- no-truncate fallback on variable-length per-prompt regime
+# ---------------------------------------------------------------------------
+
+
+def test_dump_no_truncate_on_variable_length(tmp_path, monkeypatch):
+    """When the driver over-collects but the total token count does
+    NOT divide evenly by ``_n_prompts_accumulated`` (variable per-prompt
+    length, the default vLLM continuous-batching regime), the tensor
+    ships as-is and a warning is emitted telling the operator to
+    pick chunk-size as a divisor of subset-size.
+
+    Note: vLLM configures ``propagate=False`` on its loggers and binds
+    its handler stream at config-load time, so neither pytest's
+    ``caplog`` nor ``capsys`` see the warnings. We attach a per-test
+    in-memory handler directly to the module logger to capture them.
+    """
+    import io
+    import logging
+
+    bo = _reload_bo({
+        "VLLM_CALIB_CAPTURE_BLOCK_OUTPUTS": "1",
+        "VLLM_CALIB_BLOCK_OUTPUTS_SUBSET_SIZE": "4",
+        "VLLM_CALIB_CAPTURE_BLOCK": "1",
+    })
+
+    # Attach an in-memory StreamHandler to the module logger so we can
+    # observe the warning without relying on stdout capture.
+    log_stream = io.StringIO()
+    test_handler = logging.StreamHandler(log_stream)
+    test_handler.setLevel(logging.WARNING)
+    module_logger = logging.getLogger("vllm.calibration_block_outputs")
+    module_logger.addHandler(test_handler)
+    module_logger.setLevel(logging.WARNING)
+
+    _seed_layer(bo, layer_idx=5, rank=0)
+
+    # 6 prompts but 31 total tokens (variable-length: 31 does not divide
+    # evenly by 6). Two batches of 13 + 18 rows.
+    batch1 = torch.randn(13, 4, dtype=torch.float32)
+    batch2 = torch.randn(18, 4, dtype=torch.float32)
+    bo._on_block_out(layer_idx=5, output=batch1)
+    bo._on_block_out(layer_idx=5, output=batch2)
+    bo.set_n_prompts_accumulated(6)
+
+    captured: dict[int, Any] = {}
+
+    def _fake_save(payload, path):
+        captured[payload.layer_idx] = (payload, path)
+
+    import moe_compress.utils.cached_calibration_signals as ccs
+    monkeypatch.setattr(ccs, "save_block_hidden", _fake_save)
+
+    jsonl = tmp_path / "trace.jsonl"
+    try:
+        bo.dump_block_outputs(jsonl)
+    finally:
+        module_logger.removeHandler(test_handler)
+    log_text = log_stream.getvalue()
+
+    payload, _ = captured[5]
+    # n_prompts_in_subset still reports the floor at _SUBSET_SIZE.
+    assert payload.n_prompts_in_subset == 4
+    # Tensor is shipped as-is -- no truncation (31 rows, not 4*k).
+    assert payload.hidden_states.shape == (31, 4)
+    # Operator-facing warning surfaced.
+    assert "does NOT divide evenly" in log_text
+    assert "--chunk-size as a divisor" in log_text
