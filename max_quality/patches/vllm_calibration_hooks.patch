+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Per-(layer, expert) ``down_proj`` output max-L_inf capture for
+calibration-v2 (Item 2 of the writers campaign).
+
+Computes ``max_j(|f_j(x)|_inf)`` per (layer, expert) over every token
+routed to expert ``j`` in layer rank ``l`` across the calibration run.
+This is the cheap-pruning candidate-ranking signal consumed by Stage 1's
+``ThreeWayAndPlugin``, ``MagnitudeTopkPlugin``, and ``ablation_filter`` to
+identify low-magnitude experts.
+
+The single hook used here is ``expert_out_unweighted``
+(``vllm/model_executor/layers/fused_moe/experts/triton_moe.py``), which
+dispatches ``(layer_idx, unweighted, topk_ids)`` after
+``invoke_fused_moe_triton_kernel`` returns. The hook is shared with
+``vllm.calibration_reap_scores``; the chained-callback registry in
+``vllm.calibration_hooks`` (Item 1's review-fix) lets both writers
+subscribe without collision.
+
+Env-var gating
+--------------
+``VLLM_CALIB_CAPTURE_PER_EXPERT_MAX=1`` activates the module. Requires:
+
+* ``VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED=1`` (Triton kernel hook fires)
+* ``VLLM_USE_FLASHINFER_MOE_FP16=0`` (forces Triton MoE backend;
+  ``expert_out_unweighted`` is NOT available on the FlashInfer
+  monolithic path)
+
+The driver (``build_self_traces_calib_vllm.py``) sets all three env vars
+BEFORE the first vllm import when ``--capture-per-expert-max`` is passed.
+
+CUDA-graph compatibility
+------------------------
+Accumulators live on CPU. The callback is dispatched from Python
+synchronously after the kernel returns; ``unweighted`` is cloned at
+callback entry so subsequent kernel writes into the persistent buffer
+cannot corrupt the per-expert-max math.
+
+Resumability
+------------
+Mirrors ``vllm.calibration_reap_scores``: periodic
+``dump_per_expert_max_checkpoint`` during the run,
+``load_per_expert_max_checkpoint`` on ``--resume``. The final
+``dump_per_expert_max`` writes the payload via
+``moe_compress.utils.cached_calibration_signals.save_per_expert_max``
+(Item 0).
+"""
+from __future__ import annotations
+
+import logging
+import os
+from pathlib import Path
+from typing import Any
+
+import torch
+
+import vllm.calibration_hooks as _ch
+
+log = logging.getLogger(__name__)
+
+__all__ = [
+    "setup",
+    "dump_per_expert_max",
+    "dump_per_expert_max_checkpoint",
+    "load_per_expert_max_checkpoint",
+    "get_n_prompts_accumulated",
+    "set_n_prompts_accumulated",
+]
+
+# Sampled at import time -- matches calibration_imatrix / reap_scores pattern.
+_CAPTURE_PER_EXPERT_MAX: bool = (
+    os.getenv("VLLM_CALIB_CAPTURE_PER_EXPERT_MAX", "0") == "1"
+)
+
+# Per-layer-rank CPU accumulators. ``_PEM_ACCUM[rank][expert_id]`` holds
+# the running max of ``|f_j(x)|_inf`` over every token routed to expert
+# ``expert_id`` in layer rank ``rank``. Initialized to ``-inf`` so the
+# first observation always wins via ``scatter_reduce_(reduce="amax")``;
+# at dump time, experts that received zero tokens are zero-filled.
+_PEM_ACCUM: dict[int, torch.Tensor] = {}        # rank -> [n_experts] float32
+_PEM_TOKEN_COUNTS: dict[int, torch.Tensor] = {}  # rank -> [n_experts] int64
+
+_LAYER_ID_TO_RANK: dict[int, int] = {}
+_N_LAYERS: int = 0
+_N_EXPERTS: int = 0
+
+# Cumulative prompt counter mirroring imatrix / reap_scores.
+_n_prompts_accumulated: int = 0
+_CHECKPOINT_SCHEMA_VERSION: int = 1
+
+
+def get_n_prompts_accumulated() -> int:
+    return _n_prompts_accumulated
+
+
+def set_n_prompts_accumulated(n: int) -> None:
+    global _n_prompts_accumulated
+    if n < 0:
+        raise ValueError(f"n must be >= 0; got {n}")
+    _n_prompts_accumulated = int(n)
+
+
+def _resolve_model(llm: Any) -> Any | None:
+    """Walk well-known attribute paths to find the live nn.Module."""
+    candidates = [
+        ("llm_engine", "model_executor", "driver_worker", "model_runner",
+         "model"),
+        ("llm_engine", "model_executor", "model_runner", "model"),
+        ("model_executor", "driver_worker", "model_runner", "model"),
+        ("model_runner", "model"),
+    ]
+    for path in candidates:
+        obj: Any = llm
+        ok = True
+        for attr in path:
+            obj = getattr(obj, attr, None)
+            if obj is None:
+                ok = False
+                break
+        if ok:
+            return obj
+    return None
+
+
+def setup(llm: Any) -> None:
+    """Discover MoE layers, pre-allocate accumulators, register callback.
+
+    Idempotent: calling twice does not double-allocate.
+    """
+    global _N_LAYERS, _N_EXPERTS
+
+    if not _CAPTURE_PER_EXPERT_MAX:
+        log.info("calibration_per_expert_max: env gate off; no-op setup.")
+        return
+
+    model = _resolve_model(llm)
+    if model is None:
+        log.warning(
+            "calibration_per_expert_max: could not resolve model from LLM; "
+            "callback will be registered but accumulators will be lazily "
+            "allocated at first expert_out_unweighted dispatch."
+        )
+
+    # Discover MoE layers by attribute presence.
+    n_layers = 0
+    n_experts_seen: int | None = None
+    if model is not None:
+        for name, module in model.named_modules():
+            moe_layer_id = getattr(module, "moe_layer_id", None)
+            num_experts = getattr(module, "num_experts", None)
+            if not (isinstance(moe_layer_id, int)
+                    and isinstance(num_experts, int) and num_experts > 0):
+                continue
+            _LAYER_ID_TO_RANK[moe_layer_id] = n_layers
+            if n_experts_seen is None:
+                n_experts_seen = num_experts
+            elif n_experts_seen != num_experts:
+                log.warning(
+                    "calibration_per_expert_max: mixed expert counts "
+                    "(%d vs first-seen %d at %s); using first.",
+                    num_experts, n_experts_seen, name,
+                )
+            n_layers += 1
+
+    _N_LAYERS = n_layers
+    _N_EXPERTS = int(n_experts_seen) if n_experts_seen is not None else 0
+
+    # Pre-allocate CPU accumulators with -inf so the first observation
+    # always wins via scatter_reduce_(reduce="amax").
+    for rank in range(_N_LAYERS):
+        if rank not in _PEM_ACCUM:
+            _PEM_ACCUM[rank] = torch.full(
+                (_N_EXPERTS,), float("-inf"), dtype=torch.float32,
+            )
+            _PEM_TOKEN_COUNTS[rank] = torch.zeros(
+                _N_EXPERTS, dtype=torch.int64,
+            )
+
+    _ch.register_callback("expert_out_unweighted", _on_expert_out_unweighted)
+
+    log.info(
+        "calibration_per_expert_max: setup complete -- %d MoE layers, "
+        "%d experts/layer; callback registered for expert_out_unweighted.",
+        _N_LAYERS, _N_EXPERTS,
+    )
+
+
+def _on_expert_out_unweighted(layer_idx: int, unweighted: torch.Tensor,
+                              topk_ids: torch.Tensor, **_: Any) -> None:
+    """Scatter-amax per-expert ``|f_j(x)|_inf`` into the accumulator.
+
+    ``unweighted`` is ``[n_tok, top_k, hidden]`` bf16 (a slice of the
+    persistent buffer in the Triton kernel); cloned at entry so post-
+    callback mutation of the underlying buffer cannot corrupt this
+    layer's accumulator.
+    """
+    if not _CAPTURE_PER_EXPERT_MAX:
+        return
+
+    rank = _LAYER_ID_TO_RANK.get(layer_idx)
+    if rank is None:
+        raise RuntimeError(
+            f"calibration_per_expert_max: layer_idx={layer_idx} was not "
+            f"discovered by setup() — the MoE layer must be visible via "
+            f"named_modules() with the moe_layer_id attribute set. "
+            f"Late-discovered layers would force the accumulators to grow, "
+            f"corrupting already-allocated buffers for other layers. Fix "
+            f"the setup() pass to find ALL MoE layers (or this layer's "
+            f"FusedMoE module is missing the moe_layer_id attribute)."
+        )
+
+    # Clone immediately + move to CPU + float32 for the math. The clone
+    # is critical: ``unweighted`` is a slice of a persistent Triton
+    # buffer; the next forward overwrites it in place.
+    uw = unweighted.detach().clone().cpu().to(torch.float32)   # [n_tok, top_k, hidden]
+    magnitudes = uw.abs().amax(dim=-1)                          # [n_tok, top_k]
+    flat_mags = magnitudes.reshape(-1)                          # [n_tok * top_k]
+    flat_ids = topk_ids.detach().cpu().to(torch.int64).reshape(-1)
+
+    score_accum = _PEM_ACCUM[rank]
+    count_accum = _PEM_TOKEN_COUNTS[rank]
+    score_accum.scatter_reduce_(
+        0, flat_ids, flat_mags, reduce="amax", include_self=True,
+    )
+    count_accum.scatter_add_(
+        0, flat_ids, torch.ones_like(flat_ids, dtype=torch.int64),
+    )
+
+
+def dump_per_expert_max(jsonl_path: str | Path) -> None:
+    """Write the final per-expert-max sidecar via the Item-0 helper.
+
+    Zero-traffic experts (still at ``-inf`` from the pre-allocation) are
+    replaced with ``0.0`` so downstream consumers see a clean numeric
+    payload (the ``DownProjMaxAccumulator`` in the live path uses an
+    absent-key convention for zero traffic; this writer maps that onto
+    the dense tensor representation by zero-filling).
+    """
+    if not _CAPTURE_PER_EXPERT_MAX:
+        return
+
+    # Import here (not at module top) so the dependency is lazy.
+    from moe_compress.utils.cached_calibration_signals import (
+        Stage1PerExpertMaxPayload, save_per_expert_max, SCHEMA_VERSIONS,
+    )
+
+    if _N_LAYERS == 0 or _N_EXPERTS == 0:
+        log.warning(
+            "calibration_per_expert_max: no MoE layers seen; skipping dump."
+        )
+        return
+
+    max_rows = []
+    count_rows = []
+    for rank in range(_N_LAYERS):
+        scores = _PEM_ACCUM.get(rank)
+        counts = _PEM_TOKEN_COUNTS.get(rank)
+        if scores is None or counts is None:
+            max_rows.append(torch.zeros(_N_EXPERTS, dtype=torch.float32))
+            count_rows.append(torch.zeros(_N_EXPERTS, dtype=torch.int64))
+            continue
+        # Replace -inf (zero-traffic sentinel) with 0.0.
+        cleaned = scores.clone()
+        cleaned[cleaned == float("-inf")] = 0.0
+        max_rows.append(cleaned)
+        count_rows.append(counts)
+    per_expert_max = torch.stack(max_rows)
+    token_counts = torch.stack(count_rows)
+
+    payload = Stage1PerExpertMaxPayload(
+        schema_version=SCHEMA_VERSIONS["per_expert_max"],
+        n_experts=_N_EXPERTS,
+        n_layers=_N_LAYERS,
+        per_expert_max=per_expert_max,
+        token_counts=token_counts,
+    )
+    save_per_expert_max(payload, Path(jsonl_path))
+    log.info(
+        "calibration_per_expert_max: wrote %d-layer × %d-expert sidecar "
+        "next to %s", _N_LAYERS, _N_EXPERTS, jsonl_path,
+    )
+
+
+def dump_per_expert_max_checkpoint(ckpt_path: str) -> None:
+    """Atomic checkpoint of raw accumulator state for resume."""
+    if not _CAPTURE_PER_EXPERT_MAX:
+        return
+    payload = {
+        "schema_version": _CHECKPOINT_SCHEMA_VERSION,
+        "n_prompts_accumulated": _n_prompts_accumulated,
+        "n_layers": _N_LAYERS,
+        "n_experts": _N_EXPERTS,
+        "layer_id_to_rank": dict(_LAYER_ID_TO_RANK),
+        "pem_accum": {r: v.clone() for r, v in _PEM_ACCUM.items()},
+        "token_counts": {r: v.clone() for r, v in _PEM_TOKEN_COUNTS.items()},
+    }
+    tmp = ckpt_path + ".tmp"
+    with open(tmp, "wb") as f:
+        torch.save(payload, f)
+        f.flush()
+        os.fsync(f.fileno())
+    os.replace(tmp, ckpt_path)
+    _dir_fd = os.open(os.path.dirname(ckpt_path) or ".", os.O_RDONLY)
+    try:
+        os.fsync(_dir_fd)
+    except OSError:
+        pass
+    finally:
+        os.close(_dir_fd)
+
+
+def load_per_expert_max_checkpoint(ckpt_path: str) -> int:
+    """Hydrate accumulators from a previous run's checkpoint. Returns
+    n_prompts_accumulated; 0 if file missing."""
+    global _N_LAYERS, _N_EXPERTS, _n_prompts_accumulated
+    if not os.path.exists(ckpt_path):
+        return 0
+    payload = torch.load(ckpt_path, map_location="cpu", weights_only=False)
+    schema = int(payload.get("schema_version", 0))
+    if schema != _CHECKPOINT_SCHEMA_VERSION:
+        raise ValueError(
+            f"calibration_per_expert_max: checkpoint at {ckpt_path} has "
+            f"schema_version={schema}, expected {_CHECKPOINT_SCHEMA_VERSION}. "
+            f"Delete the checkpoint to restart from scratch."
+        )
+    _n_prompts_accumulated = int(payload["n_prompts_accumulated"])
+    _N_LAYERS = int(payload["n_layers"])
+    _N_EXPERTS = int(payload["n_experts"])
+    _LAYER_ID_TO_RANK.clear()
+    _LAYER_ID_TO_RANK.update({int(k): int(v) for k, v in payload.get(
+        "layer_id_to_rank", {}).items()})
+    _PEM_ACCUM.clear()
+    _PEM_TOKEN_COUNTS.clear()
+    for r, t in payload.get("pem_accum", {}).items():
+        _PEM_ACCUM[int(r)] = t.to(torch.float32).clone()
+    for r, t in payload.get("token_counts", {}).items():
+        _PEM_TOKEN_COUNTS[int(r)] = t.to(torch.int64).clone()
+    return _n_prompts_accumulated
