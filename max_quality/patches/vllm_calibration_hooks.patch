@@ -0,0 +1,500 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Per-MoE-block hidden-states writer for calibration-v2 (Item 7).
+
+Captures the per-MoE-block output hidden states on a **fixed N-prompt
+subset** (default 128) and writes one sidecar per layer at
+``<jsonl>/sidecars/block_hidden/layer_{idx:04d}.pt`` (schema v1, bf16
+``[n_tokens, hidden_dim]`` tensor). The downstream Stage 3 block-refine
+cache reader hydrates these as anchored teacher targets so the live
+teacher block forward can be skipped.
+
+Hook
+----
+The ``block_out`` hook is dispatched by ``Qwen3MoeSparseMoeBlock.forward``
+(both internal-router and external-gate branches) under the
+``VLLM_CALIB_CAPTURE_BLOCK`` gate. This writer subscribes a callback that
+clones the post-MoE-block hidden states (pre-residual-add) and appends them
+to a per-rank list of CPU bf16 tensors. After ``_SUBSET_SIZE`` prompts have
+been processed the driver calls :func:`close_subset` which flips
+``_SUBSET_CLOSED`` and short-circuits subsequent dispatches.
+
+Env-var gating
+--------------
+* ``VLLM_CALIB_CAPTURE_BLOCK_OUTPUTS=1`` activates the module.
+* ``VLLM_CALIB_BLOCK_OUTPUTS_SUBSET_SIZE`` (default 128) caps the
+  prompt-count at which :func:`close_subset` is expected to fire. The
+  module itself does NOT count prompts -- the driver owns the counter
+  and decides when to call :func:`close_subset`. Once the subset is
+  closed the dispatch fast-path early-returns.
+* Requires ``VLLM_CALIB_CAPTURE_BLOCK=1`` (the upstream hook gate).
+
+The driver (``build_self_traces_calib_vllm.py --capture-block-outputs``)
+sets BOTH env vars BEFORE the first vllm import. Strict-string rule per
+``vllm.calibration_hooks`` applies.
+
+Resumability
+------------
+``dump_block_outputs_checkpoint`` / ``load_block_outputs_checkpoint``
+serialize the entire per-rank accumulator list + the closed-flag + the
+cumulative prompt counter. Resume hydrates and continues collecting
+until ``close_subset`` fires (or the previous checkpoint already had the
+subset closed, in which case capture stays a no-op).
+
+Per-layer sidecar contract
+--------------------------
+At dump time, for each layer rank we concatenate the per-batch tensors
+along dim 0 into a single ``[n_tokens, hidden_dim]`` bf16 tensor and
+write it via ``moe_compress.utils.cached_calibration_signals.save_block_hidden``
+to ``<jsonl_path.parent>/sidecars/block_hidden/layer_{layer_idx:04d}.pt``.
+The ``BlockHiddenPayload`` schema is v1 (no bump for Item 7).
+
+Storage budget
+--------------
+For Qwen3-30B-A3B (48 MoE layers, hidden=2048) at 128 prompts of average
+~2700 tokens with bf16 = 2 bytes:
+``128 × 2700 × 2048 × 48 × 2 ≈ 64 GiB`` total across sidecars. Matches
+the campaign plan's ~67 GB estimate; per-layer files average ~1.3 GiB.
+"""
+from __future__ import annotations
+
+import logging
+import os
+from pathlib import Path
+from typing import Any
+
+import torch
+
+import vllm.calibration_hooks as _ch
+
+log = logging.getLogger(__name__)
+
+__all__ = [
+    "setup",
+    "close_subset",
+    "dump_block_outputs",
+    "dump_block_outputs_checkpoint",
+    "load_block_outputs_checkpoint",
+    "get_n_prompts_accumulated",
+    "set_n_prompts_accumulated",
+]
+
+# Sampled at import time -- matches the other writer modules.
+_CAPTURE_BLOCK_OUTPUTS: bool = (
+    os.getenv("VLLM_CALIB_CAPTURE_BLOCK_OUTPUTS", "0") == "1"
+)
+_SUBSET_SIZE: int = int(
+    os.getenv("VLLM_CALIB_BLOCK_OUTPUTS_SUBSET_SIZE", "128")
+)
+
+# Per-rank list of CPU bf16 tensors. Each list entry is one
+# ``[n_tokens_in_batch, hidden_dim]`` slice captured by a single
+# ``block_out`` dispatch. Concatenated along dim 0 at dump time.
+_ACCUM: dict[int, list[torch.Tensor]] = {}
+
+_LAYER_ID_TO_RANK: dict[int, int] = {}
+_RANK_TO_LAYER_ID: dict[int, int] = {}
+_N_LAYERS: int = 0
+_N_EXPERTS: int = 0
+_HIDDEN_DIM: int = 0
+
+# Cumulative prompt counter mirroring the other writers. The driver
+# updates this via ``set_n_prompts_accumulated`` at chunk boundaries;
+# this module does NOT itself count prompts.
+_n_prompts_accumulated: int = 0
+
+# Once the subset is closed the dispatch fast-path early-returns. The
+# driver calls ``close_subset`` after the first ``_SUBSET_SIZE`` prompts
+# have been processed; on a resumed run the flag is restored from the
+# checkpoint via ``load_block_outputs_checkpoint``.
+_SUBSET_CLOSED: bool = False
+
+_CHECKPOINT_SCHEMA_VERSION: int = 1
+
+
+def get_n_prompts_accumulated() -> int:
+    return _n_prompts_accumulated
+
+
+def set_n_prompts_accumulated(n: int) -> None:
+    global _n_prompts_accumulated
+    if n < 0:
+        raise ValueError(f"n must be >= 0; got {n}")
+    _n_prompts_accumulated = int(n)
+
+
+def close_subset() -> None:
+    """Lock the subset: subsequent ``block_out`` dispatches are no-ops.
+
+    The driver calls this after the first ``_SUBSET_SIZE`` prompts have
+    been processed. Idempotent: calling twice is harmless. Once closed,
+    the only way to re-open the subset within the same process is via a
+    fresh module import (the test path uses this).
+    """
+    global _SUBSET_CLOSED
+    _SUBSET_CLOSED = True
+
+
+def _resolve_model(llm: Any) -> Any | None:
+    """Walk well-known attribute paths to find the live nn.Module."""
+    candidates = [
+        ("llm_engine", "model_executor", "driver_worker", "model_runner",
+         "model"),
+        ("llm_engine", "model_executor", "model_runner", "model"),
+        ("model_executor", "driver_worker", "model_runner", "model"),
+        ("model_runner", "model"),
+    ]
+    for path in candidates:
+        obj: Any = llm
+        ok = True
+        for attr in path:
+            obj = getattr(obj, attr, None)
+            if obj is None:
+                ok = False
+                break
+        if ok:
+            return obj
+    return None
+
+
+def setup(llm: Any) -> None:
+    """Discover MoE layers, register the ``block_out`` callback.
+
+    Idempotent: calling twice does not double-register (the registry
+    de-duplicates by callable identity).
+    """
+    global _N_LAYERS, _N_EXPERTS
+
+    if not _CAPTURE_BLOCK_OUTPUTS:
+        log.info("calibration_block_outputs: env gate off; no-op setup.")
+        return
+
+    model = _resolve_model(llm)
+    if model is None:
+        log.warning(
+            "calibration_block_outputs: could not resolve model from LLM; "
+            "callback will be registered but layer-rank discovery will be "
+            "skipped (rank table populated lazily would break the "
+            "cross-writer rank consistency invariant). Subscribe-and-pray."
+        )
+
+    # Discover MoE layers by attribute presence. Same ordering convention
+    # as the other writers: named_modules() + moe_layer_id sort key.
+    n_layers = 0
+    n_experts_seen: int | None = None
+    if model is not None:
+        for name, module in model.named_modules():
+            moe_layer_id = getattr(module, "moe_layer_id", None)
+            num_experts = getattr(module, "num_experts", None)
+            if not (isinstance(moe_layer_id, int)
+                    and isinstance(num_experts, int) and num_experts > 0):
+                continue
+            _LAYER_ID_TO_RANK[moe_layer_id] = n_layers
+            _RANK_TO_LAYER_ID[n_layers] = moe_layer_id
+            if n_experts_seen is None:
+                n_experts_seen = num_experts
+            elif n_experts_seen != num_experts:
+                log.warning(
+                    "calibration_block_outputs: mixed expert counts "
+                    "(%d vs first-seen %d at %s); using first.",
+                    num_experts, n_experts_seen, name,
+                )
+            n_layers += 1
+
+    _N_LAYERS = n_layers
+    _N_EXPERTS = int(n_experts_seen) if n_experts_seen is not None else 0
+
+    _ch.register_callback("block_out", _on_block_out)
+
+    log.info(
+        "calibration_block_outputs: setup complete -- %d MoE layers, "
+        "%d experts/layer, subset_size=%d; callback registered for "
+        "block_out.",
+        _N_LAYERS, _N_EXPERTS, _SUBSET_SIZE,
+    )
+
+
+def _on_block_out(layer_idx: int, output: torch.Tensor, **_: Any) -> None:
+    """Append a clone of the block output to the per-rank accumulator.
+
+    ``output`` is the post-MoE-block hidden state pre-residual-add as
+    dispatched from ``Qwen3MoeSparseMoeBlock.forward``. Shape is
+    ``[n_tok, hidden]`` (2D) per the ``block_out`` contract in
+    ``vllm.calibration_hooks``. The tensor is cloned + moved to CPU bf16
+    at callback entry so subsequent forward passes cannot mutate it.
+    """
+    global _HIDDEN_DIM
+
+    if not _CAPTURE_BLOCK_OUTPUTS:
+        return
+    if _SUBSET_CLOSED:
+        return
+
+    rank = _LAYER_ID_TO_RANK.get(layer_idx)
+    if rank is None:
+        raise RuntimeError(
+            f"calibration_block_outputs: layer_idx={layer_idx} was not "
+            f"discovered by setup() — the MoE layer must be visible via "
+            f"named_modules() with the moe_layer_id attribute set. "
+            f"Late-discovered layers would force the rank table to grow, "
+            f"breaking the cross-writer rank consistency invariant."
+        )
+
+    if output is None or output.numel() == 0:
+        return
+
+    # Clone immediately to CPU bf16. The block_out dispatch fires on a
+    # transient tensor; without the clone, the next forward through the
+    # decoder block could overwrite it.
+    t = output.detach().clone().to(device="cpu", dtype=torch.bfloat16)
+    # Block hooks may dispatch a 3D tensor ``[batch, seq, hidden]`` in
+    # some code paths; flatten to 2D so the per-layer sidecar is a
+    # uniform ``[n_tokens, hidden]`` slab regardless of upstream shape.
+    if t.dim() == 3:
+        t = t.reshape(-1, t.shape[-1])
+    elif t.dim() != 2:
+        raise RuntimeError(
+            f"calibration_block_outputs: expected 2D or 3D output tensor "
+            f"from block_out dispatch; got shape {tuple(t.shape)}"
+        )
+
+    if _HIDDEN_DIM == 0:
+        _HIDDEN_DIM = int(t.shape[-1])
+    elif _HIDDEN_DIM != int(t.shape[-1]):
+        raise RuntimeError(
+            f"calibration_block_outputs: hidden_dim mismatch -- first-seen "
+            f"{_HIDDEN_DIM} but layer_idx={layer_idx} dispatched {t.shape[-1]}"
+        )
+
+    bucket = _ACCUM.get(rank)
+    if bucket is None:
+        bucket = []
+        _ACCUM[rank] = bucket
+    bucket.append(t)
+
+
+def dump_block_outputs(jsonl_path: str | Path) -> None:
+    """Write per-layer sidecars via the Item-0 ``save_block_hidden`` helper.
+
+    For each populated rank, concatenate the per-batch tensors along
+    dim 0 into a single ``[n_tokens, hidden_dim]`` bf16 slab and write
+    one sidecar per layer at
+    ``<jsonl_parent>/sidecars/block_hidden/layer_{layer_idx:04d}.pt``.
+
+    Over-collection truncation
+    --------------------------
+    Because the driver closes the subset at the JSONL flush boundary
+    (chunk boundary), if ``chunk_size`` is not a divisor of
+    ``_SUBSET_SIZE`` the writer will have already absorbed up to
+    ``chunk_size - 1`` extra prompts past the cap when ``close_subset()``
+    fires. The downstream Stage 3 reader's strict-equality token-count
+    guard (``n_tokens == n_prompts × seq_len``) would then reject every
+    sidecar as a cache miss. To make the cache hit reachable for
+    properly-configured runs (uniform per-prompt token count, i.e.
+    chat-templated prompts padded by the tokenizer to the same length),
+    we truncate the concatenated tensor to exactly
+    ``_SUBSET_SIZE * tokens_per_prompt`` rows when over-collection
+    occurred AND the total token count divides cleanly by the cumulative
+    prompt count. If the token count does NOT divide cleanly (variable
+    per-prompt token count -- typical for vLLM continuous batching with
+    decode-step block_out dispatches), we cannot identify a per-prompt
+    boundary and skip the truncate: the sidecar still ships with the
+    over-collected tensor and the reader will fall through to the live
+    forward with its existing warning. The operator-facing fix in that
+    case is to set ``--chunk-size`` as a divisor of
+    ``--block-outputs-subset-size``.
+
+    Failures during the concatenation/save of a single layer are logged
+    but do not block the other layers.
+    """
+    if not _CAPTURE_BLOCK_OUTPUTS:
+        return
+
+    # Lazy import so the moe_compress dependency is not imposed at module
+    # import time (the dump path is only ever called by the driver).
+    from moe_compress.utils.cached_calibration_signals import (
+        BlockHiddenPayload, save_block_hidden, SCHEMA_VERSIONS,
+    )
+
+    if not _ACCUM:
+        log.warning(
+            "calibration_block_outputs: zero block_out dispatches captured; "
+            "skipping dump."
+        )
+        return
+
+    jsonl_path_obj = Path(jsonl_path)
+
+    # Over-collection guard: when the driver closes the subset at the
+    # chunk boundary, _n_prompts_accumulated can exceed _SUBSET_SIZE by
+    # up to chunk_size-1 prompts (the I1 hazard). The reader's I2 guard
+    # checks strict equality on n_prompts_in_subset; absent a truncate
+    # the cache hit would be unreachable for any operator who did not
+    # coincidentally pick chunk_size as a divisor of subset_size.
+    #
+    # We truncate to _SUBSET_SIZE * tokens_per_prompt rows when the
+    # uniform-per-prompt-tokens regime holds (total tokens divides
+    # cleanly by _n_prompts_accumulated). Otherwise -- variable-length
+    # per-prompt dispatches, which is the default for vLLM continuous
+    # batching with decode-step block_out dispatches -- we cannot
+    # identify a per-prompt boundary so we leave the tensor untouched
+    # and emit a warning. See module docstring's I1+I2 note.
+    over_collected = _n_prompts_accumulated > _SUBSET_SIZE
+    n_prompts_in_subset = min(_n_prompts_accumulated, _SUBSET_SIZE)
+
+    n_written = 0
+    truncated_any = False
+    for rank in sorted(_ACCUM.keys()):
+        batches = _ACCUM[rank]
+        if not batches:
+            continue
+        layer_idx = _RANK_TO_LAYER_ID.get(rank)
+        if layer_idx is None:
+            log.error(
+                "calibration_block_outputs: rank=%d has no mapped "
+                "layer_idx in _RANK_TO_LAYER_ID -- skipping (this should "
+                "be impossible if setup() populated the rank table).",
+                rank,
+            )
+            continue
+        try:
+            hidden = torch.cat(batches, dim=0)
+            n_tokens_total = int(hidden.shape[0])
+
+            # Truncate if (a) the driver over-collected and (b) the
+            # total token count divides cleanly by the cumulative
+            # prompt count (uniform-per-prompt-tokens regime).
+            if over_collected and _n_prompts_accumulated > 0:
+                if n_tokens_total % _n_prompts_accumulated == 0:
+                    tokens_per_prompt = (
+                        n_tokens_total // _n_prompts_accumulated
+                    )
+                    target_tokens = n_prompts_in_subset * tokens_per_prompt
+                    if target_tokens < n_tokens_total:
+                        hidden = hidden[:target_tokens].contiguous()
+                        truncated_any = True
+                else:
+                    log.warning(
+                        "calibration_block_outputs: layer_idx=%d -- "
+                        "over-collected by %d prompts (accumulated=%d, "
+                        "subset_size=%d) but n_tokens=%d does NOT divide "
+                        "evenly by accumulated prompt count, so per-prompt "
+                        "token boundaries are unknown (variable-length "
+                        "regime). Shipping the over-collected tensor "
+                        "as-is; the Stage 3 reader's strict equality "
+                        "guard will reject it as a cache miss. To make "
+                        "the cache hit reachable, set --chunk-size as a "
+                        "divisor of --block-outputs-subset-size.",
+                        layer_idx,
+                        _n_prompts_accumulated - _SUBSET_SIZE,
+                        _n_prompts_accumulated, _SUBSET_SIZE, n_tokens_total,
+                    )
+
+            payload = BlockHiddenPayload(
+                schema_version=SCHEMA_VERSIONS["block_hidden"],
+                layer_idx=int(layer_idx),
+                n_prompts_in_subset=int(n_prompts_in_subset),
+                hidden_states=hidden,
+            )
+            save_block_hidden(payload, jsonl_path_obj)
+            n_written += 1
+        except Exception as exc:  # noqa: BLE001
+            log.error(
+                "calibration_block_outputs: failed to write sidecar for "
+                "rank=%d layer_idx=%s: %s",
+                rank, layer_idx, exc, exc_info=True,
+            )
+
+    log.info(
+        "calibration_block_outputs: wrote %d per-layer sidecars "
+        "(n_prompts_in_subset=%d, over_collected=%s, truncated=%s) next to %s",
+        n_written, n_prompts_in_subset, over_collected, truncated_any,
+        jsonl_path,
+    )
+
+
+def dump_block_outputs_checkpoint(ckpt_path: str) -> None:
+    """Atomic checkpoint of raw accumulator state for resume.
+
+    Stores the per-rank accumulator list (each entry already CPU bf16),
+    the layer-id-to-rank table, the subset-closed flag, and the
+    cumulative prompt counter. Atomic-write via tmp + ``os.replace``.
+    """
+    if not _CAPTURE_BLOCK_OUTPUTS:
+        return
+    payload = {
+        "schema_version": _CHECKPOINT_SCHEMA_VERSION,
+        "n_prompts_accumulated": _n_prompts_accumulated,
+        "n_layers": _N_LAYERS,
+        "n_experts": _N_EXPERTS,
+        "subset_size": _SUBSET_SIZE,
+        "subset_closed": _SUBSET_CLOSED,
+        "hidden_dim": _HIDDEN_DIM,
+        "layer_id_to_rank": dict(_LAYER_ID_TO_RANK),
+        "rank_to_layer_id": dict(_RANK_TO_LAYER_ID),
+        # Clone each accumulator tensor so the checkpoint snapshot is
+        # independent of any subsequent in-place changes.
+        "accum": {k: [t.clone() for t in v] for k, v in _ACCUM.items()},
+    }
+    tmp = ckpt_path + ".tmp"
+    with open(tmp, "wb") as f:
+        torch.save(payload, f)
+        f.flush()
+        os.fsync(f.fileno())
+    os.replace(tmp, ckpt_path)
+    _dir_fd = os.open(os.path.dirname(ckpt_path) or ".", os.O_RDONLY)
+    try:
+        os.fsync(_dir_fd)
+    except OSError:
+        pass
+    finally:
+        os.close(_dir_fd)
+
+
+def load_block_outputs_checkpoint(ckpt_path: str) -> int:
+    """Hydrate accumulator state from a previous run's checkpoint.
+
+    Returns ``n_prompts_accumulated``; 0 if the file is missing. A
+    subset-size mismatch between the checkpoint and the current run
+    raises ``ValueError`` -- the two-phase subset-close math depends on a
+    consistent ``_SUBSET_SIZE`` across the full run.
+    """
+    global _N_LAYERS, _N_EXPERTS, _n_prompts_accumulated, _SUBSET_CLOSED
+    global _HIDDEN_DIM
+    if not os.path.exists(ckpt_path):
+        return 0
+    payload = torch.load(ckpt_path, map_location="cpu", weights_only=False)
+    schema = int(payload.get("schema_version", 0))
+    if schema != _CHECKPOINT_SCHEMA_VERSION:
+        raise ValueError(
+            f"calibration_block_outputs: checkpoint at {ckpt_path} has "
+            f"schema_version={schema}, expected {_CHECKPOINT_SCHEMA_VERSION}. "
+            f"Delete the checkpoint to restart from scratch."
+        )
+    ckpt_subset = int(payload.get("subset_size", _SUBSET_SIZE))
+    if ckpt_subset != _SUBSET_SIZE:
+        raise ValueError(
+            f"calibration_block_outputs: checkpoint at {ckpt_path} was "
+            f"written with subset_size={ckpt_subset} but the current run is "
+            f"configured for subset_size={_SUBSET_SIZE}. The subset-close "
+            f"contract depends on a consistent size across the full run -- "
+            f"delete the checkpoint or restore the matching "
+            f"VLLM_CALIB_BLOCK_OUTPUTS_SUBSET_SIZE."
+        )
+    _n_prompts_accumulated = int(payload["n_prompts_accumulated"])
+    _N_LAYERS = int(payload["n_layers"])
+    _N_EXPERTS = int(payload["n_experts"])
+    _HIDDEN_DIM = int(payload.get("hidden_dim", 0))
+    _SUBSET_CLOSED = bool(payload.get("subset_closed", False))
+    _LAYER_ID_TO_RANK.clear()
+    _LAYER_ID_TO_RANK.update(
+        {int(k): int(v) for k, v in payload.get("layer_id_to_rank", {}).items()}
+    )
+    _RANK_TO_LAYER_ID.clear()
+    _RANK_TO_LAYER_ID.update(
+        {int(k): int(v) for k, v in payload.get("rank_to_layer_id", {}).items()}
+    )
+    _ACCUM.clear()
+    for k, batches in payload.get("accum", {}).items():
+        _ACCUM[int(k)] = [t.clone() for t in batches]
+    return _n_prompts_accumulated
