+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Per-(layer, expert) routing-frequency + mean-routing-weight capture for
+calibration-v2 (Item 3 of the writers campaign).
+
+Computes two per-(layer, expert) quantities across the entire
+calibration run from the live router's ``topk_ids`` + ``topk_weights``:
+
+* ``freq[layer_rank, expert_id]``     -- int64 count of tokens that
+  selected expert ``expert_id`` at layer rank ``layer_rank``.
+* ``mean_weight[layer_rank, expert_id]`` -- float32 ``mean(g_j(x))``
+  over the same population (zero where ``freq == 0``).
+
+Both are derived from the ``router`` hook, which dispatches
+``(layer_idx, router_logits, topk_weights, topk_ids)`` after the routing
+gate selects the top-k experts. The hook fires on every MoE backend
+(Triton / FlashInfer / etc.) so there is NO ``EXPERT_UNWEIGHTED`` or
+``FLASHINFER`` dependency -- unlike Item 2's per-expert-max writer.
+
+Env-var gating
+--------------
+``VLLM_CALIB_CAPTURE_ROUTING_STATS=1`` activates the module. Requires:
+
+* ``VLLM_CALIB_CAPTURE_ROUTER=1`` (router hook fires).
+
+The driver (``build_self_traces_calib_vllm.py``) sets both BEFORE the
+first vllm import when ``--capture-routing-stats`` is passed.
+
+No-downstream-consumer note
+---------------------------
+There is NO immediate Stage-1 / Stage-2 / Stage-3 consumer for the
+sidecar produced here. Item 3 lays infrastructure for future plugins
+(routing-aware ablation gating, mean-weight-weighted REAP variants).
+The Stage 1 / Stage 2 cache readers shipped alongside this writer only
+deposit the payload onto ``ctx`` so future read-side plugins can pick
+it up without requiring a fresh schema rev.
+
+CUDA-graph compatibility
+------------------------
+Accumulators live on CPU. The callback is dispatched from Python
+synchronously after the router runs; ``topk_ids`` + ``topk_weights``
+are cloned (via ``.detach().cpu()``) at callback entry.
+
+Resumability
+------------
+Mirrors ``vllm.calibration_per_expert_max``: periodic
+``dump_routing_stats_checkpoint`` during the run,
+``load_routing_stats_checkpoint`` on ``--resume``. The final
+``dump_routing_stats`` writes the payload via
+``moe_compress.utils.cached_calibration_signals.save_routing_stats``
+(Item 0).
+"""
+from __future__ import annotations
+
+import logging
+import os
+from pathlib import Path
+from typing import Any
+
+import torch
+
+import vllm.calibration_hooks as _ch
+
+log = logging.getLogger(__name__)
+
+__all__ = [
+    "setup",
+    "dump_routing_stats",
+    "dump_routing_stats_checkpoint",
+    "load_routing_stats_checkpoint",
+    "get_n_prompts_accumulated",
+    "set_n_prompts_accumulated",
+]
+
+# Sampled at import time -- matches calibration_imatrix / per_expert_max pattern.
+_CAPTURE_ROUTING_STATS: bool = (
+    os.getenv("VLLM_CALIB_CAPTURE_ROUTING_STATS", "0") == "1"
+)
+
+# Per-layer-rank CPU accumulators.
+# ``_FREQ_ACCUM[rank][expert_id]``        : int64 token count for the
+#                                           expert at layer rank ``rank``.
+# ``_WEIGHT_SUM_ACCUM[rank][expert_id]``  : float32 sum of router weights
+#                                           for the same population.
+# The mean weight is derived at dump time as
+#   ``weight_sum / freq.clamp(min=1).float()`` (clamp avoids 0/0).
+_FREQ_ACCUM: dict[int, torch.Tensor] = {}          # rank -> [n_experts] int64
+_WEIGHT_SUM_ACCUM: dict[int, torch.Tensor] = {}    # rank -> [n_experts] float32
+
+_LAYER_ID_TO_RANK: dict[int, int] = {}
+_N_LAYERS: int = 0
+_N_EXPERTS: int = 0
+
+# Cumulative prompt counter mirroring imatrix / reap_scores / per_expert_max.
+_n_prompts_accumulated: int = 0
+_CHECKPOINT_SCHEMA_VERSION: int = 1
+
+
+def get_n_prompts_accumulated() -> int:
+    return _n_prompts_accumulated
+
+
+def set_n_prompts_accumulated(n: int) -> None:
+    global _n_prompts_accumulated
+    if n < 0:
+        raise ValueError(f"n must be >= 0; got {n}")
+    _n_prompts_accumulated = int(n)
+
+
+def _resolve_model(llm: Any) -> Any | None:
+    """Walk well-known attribute paths to find the live nn.Module."""
+    candidates = [
+        ("llm_engine", "model_executor", "driver_worker", "model_runner",
+         "model"),
+        ("llm_engine", "model_executor", "model_runner", "model"),
+        ("model_executor", "driver_worker", "model_runner", "model"),
+        ("model_runner", "model"),
+    ]
+    for path in candidates:
+        obj: Any = llm
+        ok = True
+        for attr in path:
+            obj = getattr(obj, attr, None)
+            if obj is None:
+                ok = False
+                break
+        if ok:
+            return obj
+    return None
+
+
+def setup(llm: Any) -> None:
+    """Discover MoE layers, pre-allocate accumulators, register callback.
+
+    Idempotent: calling twice does not double-allocate.
+    """
+    global _N_LAYERS, _N_EXPERTS
+
+    if not _CAPTURE_ROUTING_STATS:
+        log.info("calibration_routing_stats: env gate off; no-op setup.")
+        return
+
+    model = _resolve_model(llm)
+    if model is None:
+        log.warning(
+            "calibration_routing_stats: could not resolve model from LLM; "
+            "callback will be registered but accumulators will not have "
+            "their layer->rank mapping populated until first dispatch."
+        )
+
+    # Discover MoE layers by attribute presence -- same pattern as
+    # calibration_reap_scores / calibration_per_expert_max so the rank
+    # ordering matches across all three writers' sidecars.
+    n_layers = 0
+    n_experts_seen: int | None = None
+    if model is not None:
+        for name, module in model.named_modules():
+            moe_layer_id = getattr(module, "moe_layer_id", None)
+            num_experts = getattr(module, "num_experts", None)
+            if not (isinstance(moe_layer_id, int)
+                    and isinstance(num_experts, int) and num_experts > 0):
+                continue
+            _LAYER_ID_TO_RANK[moe_layer_id] = n_layers
+            if n_experts_seen is None:
+                n_experts_seen = num_experts
+            elif n_experts_seen != num_experts:
+                log.warning(
+                    "calibration_routing_stats: mixed expert counts "
+                    "(%d vs first-seen %d at %s); using first.",
+                    num_experts, n_experts_seen, name,
+                )
+            n_layers += 1
+
+    _N_LAYERS = n_layers
+    _N_EXPERTS = int(n_experts_seen) if n_experts_seen is not None else 0
+
+    # Pre-allocate CPU accumulators with zeros -- max-style sentinels are
+    # NOT needed here (additive accumulators).
+    for rank in range(_N_LAYERS):
+        if rank not in _FREQ_ACCUM:
+            _FREQ_ACCUM[rank] = torch.zeros(
+                _N_EXPERTS, dtype=torch.int64,
+            )
+            _WEIGHT_SUM_ACCUM[rank] = torch.zeros(
+                _N_EXPERTS, dtype=torch.float32,
+            )
+
+    _ch.register_callback("router", _on_router)
+
+    log.info(
+        "calibration_routing_stats: setup complete -- %d MoE layers, "
+        "%d experts/layer; callback registered for router.",
+        _N_LAYERS, _N_EXPERTS,
+    )
+
+
+def _on_router(layer_idx: int, router_logits: torch.Tensor,
+               topk_weights: torch.Tensor, topk_ids: torch.Tensor,
+               **_: Any) -> None:
+    """Scatter-add per-expert token counts + weight sums into the accumulator.
+
+    ``topk_ids`` is ``[n_tok, top_k]`` int; ``topk_weights`` is
+    ``[n_tok, top_k]`` (typically bf16/fp16). Per (token, k) selection we
+    add 1 to ``freq[expert]`` and ``topk_weight`` to ``weight_sum[expert]``.
+    """
+    if not _CAPTURE_ROUTING_STATS:
+        return
+
+    rank = _LAYER_ID_TO_RANK.get(layer_idx)
+    if rank is None:
+        raise RuntimeError(
+            f"calibration_routing_stats: layer_idx={layer_idx} was not "
+            f"discovered by setup() -- the MoE layer must be visible via "
+            f"named_modules() with the moe_layer_id attribute set. "
+            f"Late-discovered layers would force the accumulators to grow, "
+            f"corrupting already-allocated buffers for other layers. Fix "
+            f"the setup() pass to find ALL MoE layers (or this layer's "
+            f"FusedMoE module is missing the moe_layer_id attribute)."
+        )
+
+    ids = topk_ids.detach().cpu().to(torch.int64).reshape(-1)
+    ones = torch.ones_like(ids, dtype=torch.int64)
+    _FREQ_ACCUM[rank].scatter_add_(0, ids, ones)
+
+    tw = topk_weights.detach().cpu().to(torch.float32).reshape(-1)
+    _WEIGHT_SUM_ACCUM[rank].scatter_add_(0, ids, tw)
+
+
+def dump_routing_stats(jsonl_path: str | Path) -> None:
+    """Write the final routing-stats sidecar via the Item-0 helper.
+
+    Derives ``mean_weight = weight_sum / freq.clamp(min=1).float()`` so
+    zero-traffic experts surface as 0.0 (no NaN).
+    """
+    if not _CAPTURE_ROUTING_STATS:
+        return
+
+    # Import here (not at module top) so the dependency is lazy.
+    from moe_compress.utils.cached_calibration_signals import (
+        RoutingStatsPayload, save_routing_stats, SCHEMA_VERSIONS,
+    )
+
+    if _N_LAYERS == 0 or _N_EXPERTS == 0:
+        log.warning(
+            "calibration_routing_stats: no MoE layers seen; skipping dump."
+        )
+        return
+
+    freq_rows = []
+    weight_rows = []
+    for rank in range(_N_LAYERS):
+        freq = _FREQ_ACCUM.get(rank)
+        weight_sum = _WEIGHT_SUM_ACCUM.get(rank)
+        if freq is None or weight_sum is None:
+            freq_rows.append(torch.zeros(_N_EXPERTS, dtype=torch.int64))
+            weight_rows.append(torch.zeros(_N_EXPERTS, dtype=torch.float32))
+            continue
+        mean = weight_sum / freq.clamp(min=1).to(torch.float32)
+        # Zero-traffic cells: mean must be 0.0 (the clamp put 1 in the
+        # denominator there, but weight_sum is 0 so the division is 0/1 = 0).
+        freq_rows.append(freq.clone())
+        weight_rows.append(mean.clone())
+    freq_tensor = torch.stack(freq_rows)
+    mean_weight_tensor = torch.stack(weight_rows)
+
+    payload = RoutingStatsPayload(
+        schema_version=SCHEMA_VERSIONS["routing_stats"],
+        n_experts=_N_EXPERTS,
+        n_layers=_N_LAYERS,
+        freq=freq_tensor,
+        mean_weight=mean_weight_tensor,
+    )
+    save_routing_stats(payload, Path(jsonl_path))
+    log.info(
+        "calibration_routing_stats: wrote %d-layer x %d-expert sidecar "
+        "next to %s", _N_LAYERS, _N_EXPERTS, jsonl_path,
+    )
+
+
+def dump_routing_stats_checkpoint(ckpt_path: str) -> None:
+    """Atomic checkpoint of raw accumulator state for resume."""
+    if not _CAPTURE_ROUTING_STATS:
+        return
+    payload = {
+        "schema_version": _CHECKPOINT_SCHEMA_VERSION,
+        "n_prompts_accumulated": _n_prompts_accumulated,
+        "n_layers": _N_LAYERS,
+        "n_experts": _N_EXPERTS,
+        "layer_id_to_rank": dict(_LAYER_ID_TO_RANK),
+        "freq_accum": {r: v.clone() for r, v in _FREQ_ACCUM.items()},
+        "weight_sum_accum": {
+            r: v.clone() for r, v in _WEIGHT_SUM_ACCUM.items()
+        },
+    }
+    tmp = ckpt_path + ".tmp"
+    with open(tmp, "wb") as f:
+        torch.save(payload, f)
+        f.flush()
+        os.fsync(f.fileno())
+    os.replace(tmp, ckpt_path)
+    _dir_fd = os.open(os.path.dirname(ckpt_path) or ".", os.O_RDONLY)
+    try:
+        os.fsync(_dir_fd)
+    except OSError:
+        pass
+    finally:
+        os.close(_dir_fd)
+
+
+def load_routing_stats_checkpoint(ckpt_path: str) -> int:
+    """Hydrate accumulators from a previous run's checkpoint. Returns
+    n_prompts_accumulated; 0 if file missing."""
+    global _N_LAYERS, _N_EXPERTS, _n_prompts_accumulated
+    if not os.path.exists(ckpt_path):
+        return 0
+    payload = torch.load(ckpt_path, map_location="cpu", weights_only=False)
+    schema = int(payload.get("schema_version", 0))
+    if schema != _CHECKPOINT_SCHEMA_VERSION:
+        raise ValueError(
+            f"calibration_routing_stats: checkpoint at {ckpt_path} has "
+            f"schema_version={schema}, expected {_CHECKPOINT_SCHEMA_VERSION}. "
+            f"Delete the checkpoint to restart from scratch."
+        )
+    _n_prompts_accumulated = int(payload["n_prompts_accumulated"])
+    _N_LAYERS = int(payload["n_layers"])
+    _N_EXPERTS = int(payload["n_experts"])
+    _LAYER_ID_TO_RANK.clear()
+    _LAYER_ID_TO_RANK.update({int(k): int(v) for k, v in payload.get(
+        "layer_id_to_rank", {}).items()})
+    _FREQ_ACCUM.clear()
+    _WEIGHT_SUM_ACCUM.clear()
+    for r, t in payload.get("freq_accum", {}).items():
+        _FREQ_ACCUM[int(r)] = t.to(torch.int64).clone()
+    for r, t in payload.get("weight_sum_accum", {}).items():
+        _WEIGHT_SUM_ACCUM[int(r)] = t.to(torch.float32).clone()
+    return _n_prompts_accumulated
