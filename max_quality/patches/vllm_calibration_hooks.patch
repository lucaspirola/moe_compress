+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Smoke tests for ``vllm.calibration_routing_stats``.
+
+These exercise the per-(layer, expert) freq + mean-weight accumulator,
+the env-gate contract, checkpoint round-trip + two-segment additivity,
+and the dump-normalization math.
+
+Tests:
+
+1. ``test_env_gate_off_no_op`` -- env unset -> ``setup()`` and the
+   callback are no-ops (accumulators untouched).
+2. ``test_freq_accumulation_correctness`` -- synthetic ``topk_ids``
+   populates ``_FREQ_ACCUM`` with the expected per-expert counts.
+3. ``test_mean_weight_normalization`` -- weights (0.3 + 0.5) routed to
+   expert 0 + (0.7) to expert 1 produce ``mean_weight[0]=0.4`` and
+   ``mean_weight[1]=0.7`` in the dumped payload.
+4. ``test_checkpoint_round_trip`` -- dump -> reload module ->
+   load_checkpoint restores byte-identical accumulator state.
+5. ``test_two_segment_additivity`` -- 10 selections + checkpoint +
+   reload + 10 more selections produces the same freq + weight_sum as a
+   single 20-selection run.
+6. ``test_gate_off_setup_is_no_op`` -- env unset -> ``setup(llm=None)``
+   leaves the registry empty AND does not register a callback.
+"""
+from __future__ import annotations
+
+import importlib
+import os
+import sys
+from typing import Any
+
+import torch
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+
+def _reload_rts(env: dict[str, str]) -> Any:
+    """Reload ``vllm.calibration_routing_stats`` (and hooks) with a fresh env.
+
+    Module-level ``_CAPTURE_ROUTING_STATS`` is sampled at import; per-test
+    isolation requires a fresh import.
+    """
+    sys.modules.pop("vllm.calibration_routing_stats", None)
+    sys.modules.pop("vllm.calibration_hooks", None)
+    for key in (
+        "VLLM_CALIB_CAPTURE_ROUTING_STATS",
+        "VLLM_CALIB_CAPTURE_ROUTER",
+        "VLLM_CALIB_CAPTURE_REAP_SCORES",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED",
+        "VLLM_CALIB_CAPTURE_PER_EXPERT_MAX",
+        "VLLM_CALIB_CAPTURE_IMATRIX",
+        "VLLM_CALIB_CAPTURE_EXPERT",
+        "VLLM_CALIB_CAPTURE_BLOCK",
+        "VLLM_CALIB_CAPTURE_EXPERT_MID",
+        "VLLM_CALIB_CAPTURE_INPUT_COV",
+    ):
+        os.environ.pop(key, None)
+    for k, v in env.items():
+        os.environ[k] = v
+    importlib.import_module("vllm.calibration_hooks")
+    return importlib.import_module("vllm.calibration_routing_stats")
+
+
+def _seed_layer(rts: Any, layer_idx: int, rank: int, n_experts: int) -> None:
+    """Manually wire up the per-layer accumulators the way setup() would."""
+    rts._LAYER_ID_TO_RANK[layer_idx] = rank
+    if rank + 1 > rts._N_LAYERS:
+        rts._N_LAYERS = rank + 1
+    if n_experts > rts._N_EXPERTS:
+        rts._N_EXPERTS = n_experts
+    rts._FREQ_ACCUM[rank] = torch.zeros(n_experts, dtype=torch.int64)
+    rts._WEIGHT_SUM_ACCUM[rank] = torch.zeros(n_experts, dtype=torch.float32)
+
+
+# ---------------------------------------------------------------------------
+# Test 1 -- env-off short-circuit
+# ---------------------------------------------------------------------------
+
+
+def test_env_gate_off_no_op():
+    """Env unset -> setup() is a no-op, and the callback short-circuits
+    before touching any accumulator."""
+    rts = _reload_rts({})  # env cleared
+    assert rts._CAPTURE_ROUTING_STATS is False
+
+    # setup() with a stub LLM -> should not register callbacks nor
+    # allocate accumulators.
+    rts.setup(llm=None)
+    assert rts._FREQ_ACCUM == {}
+    assert rts._WEIGHT_SUM_ACCUM == {}
+
+    # Manually seed accumulators, then call the callback. The internal
+    # env guard must short-circuit before scatter_add_.
+    n_experts = 3
+    _seed_layer(rts, layer_idx=0, rank=0, n_experts=n_experts)
+
+    topk_weights = torch.tensor([[0.6, 0.4]], dtype=torch.float32)
+    topk_ids = torch.tensor([[0, 1]], dtype=torch.int64)
+    rts._on_router(
+        layer_idx=0, router_logits=torch.zeros(1, 3),
+        topk_weights=topk_weights, topk_ids=topk_ids,
+    )
+    # Accumulator unchanged because env guard short-circuits.
+    assert torch.equal(
+        rts._FREQ_ACCUM[0], torch.zeros(n_experts, dtype=torch.int64),
+    )
+    assert torch.equal(
+        rts._WEIGHT_SUM_ACCUM[0],
+        torch.zeros(n_experts, dtype=torch.float32),
+    )
+
+
+# ---------------------------------------------------------------------------
+# Test 2 -- freq accumulation correctness
+# ---------------------------------------------------------------------------
+
+
+def test_freq_accumulation_correctness():
+    """Synthetic ``topk_ids`` populates ``_FREQ_ACCUM`` with the expected
+    per-expert counts.
+
+    3 tokens, top_k=2:
+      t0 picks experts 0,2
+      t1 picks experts 1,2
+      t2 picks experts 0,3
+    Expected freq: e0=2, e1=1, e2=2, e3=1, e4=0.
+    """
+    rts = _reload_rts({
+        "VLLM_CALIB_CAPTURE_ROUTING_STATS": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+    })
+    n_experts = 5
+    _seed_layer(rts, layer_idx=0, rank=0, n_experts=n_experts)
+
+    topk_ids = torch.tensor(
+        [[0, 2], [1, 2], [0, 3]], dtype=torch.int64,
+    )
+    topk_weights = torch.tensor(
+        [[0.5, 0.5], [0.6, 0.4], [0.7, 0.3]], dtype=torch.float32,
+    )
+    rts._on_router(
+        layer_idx=0, router_logits=torch.zeros(3, n_experts),
+        topk_weights=topk_weights, topk_ids=topk_ids,
+    )
+
+    expected_freq = torch.tensor([2, 1, 2, 1, 0], dtype=torch.int64)
+    assert torch.equal(rts._FREQ_ACCUM[0], expected_freq)
+
+    # Weight sums: e0 = 0.5 + 0.7 = 1.2; e1 = 0.6; e2 = 0.5 + 0.4 = 0.9;
+    # e3 = 0.3; e4 = 0.0.
+    expected_weight_sum = torch.tensor(
+        [1.2, 0.6, 0.9, 0.3, 0.0], dtype=torch.float32,
+    )
+    assert torch.allclose(rts._WEIGHT_SUM_ACCUM[0], expected_weight_sum,
+                          atol=1e-6)
+
+
+# ---------------------------------------------------------------------------
+# Test 3 -- mean_weight normalization correctness via dump
+# ---------------------------------------------------------------------------
+
+
+def test_mean_weight_normalization(tmp_path, monkeypatch):
+    """Weights (0.3 + 0.5) routed to expert 0 + (0.7) to expert 1
+    produce mean_weight[0]=0.4 and mean_weight[1]=0.7 in the dumped
+    payload. Zero-traffic cells stay at 0.0 (not NaN)."""
+    rts = _reload_rts({
+        "VLLM_CALIB_CAPTURE_ROUTING_STATS": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+    })
+    n_experts = 3
+    _seed_layer(rts, layer_idx=0, rank=0, n_experts=n_experts)
+    _seed_layer(rts, layer_idx=1, rank=1, n_experts=n_experts)
+
+    # Two tokens, top_k=1. token 0 -> expert 0 weight 0.3; token 1 ->
+    # expert 0 weight 0.5. So e0 freq=2, weight_sum=0.8, mean=0.4.
+    rts._on_router(
+        layer_idx=0,
+        router_logits=torch.zeros(2, n_experts),
+        topk_weights=torch.tensor([[0.3], [0.5]], dtype=torch.float32),
+        topk_ids=torch.tensor([[0], [0]], dtype=torch.int64),
+    )
+    # One token -> expert 1 weight 0.7. So e1 freq=1, weight_sum=0.7,
+    # mean=0.7.
+    rts._on_router(
+        layer_idx=0,
+        router_logits=torch.zeros(1, n_experts),
+        topk_weights=torch.tensor([[0.7]], dtype=torch.float32),
+        topk_ids=torch.tensor([[1]], dtype=torch.int64),
+    )
+    # Layer rank 1: no traffic -- mean_weight row should stay all zeros
+    # (zero-traffic-must-not-NaN guarantee).
+
+    captured = {}
+
+    def _fake_save(payload, path):
+        captured["payload"] = payload
+        captured["path"] = path
+
+    import moe_compress.utils.cached_calibration_signals as ccs
+    monkeypatch.setattr(ccs, "save_routing_stats", _fake_save)
+
+    jsonl = tmp_path / "trace.jsonl"
+    rts.dump_routing_stats(jsonl)
+
+    payload = captured["payload"]
+    assert payload is not None
+    assert payload.schema_version == 1
+    assert payload.n_layers == 2
+    assert payload.n_experts == n_experts
+    assert payload.freq.shape == (2, n_experts)
+    assert payload.mean_weight.shape == (2, n_experts)
+    # Rank 0 freq.
+    assert torch.equal(
+        payload.freq[0], torch.tensor([2, 1, 0], dtype=torch.int64),
+    )
+    # Rank 0 mean weights: e0=0.4, e1=0.7, e2=0.0 (zero-traffic).
+    assert torch.allclose(
+        payload.mean_weight[0],
+        torch.tensor([0.4, 0.7, 0.0], dtype=torch.float32),
+        atol=1e-6,
+    )
+    # Rank 1: never seen any traffic.
+    assert torch.equal(
+        payload.freq[1], torch.zeros(n_experts, dtype=torch.int64),
+    )
+    assert torch.equal(
+        payload.mean_weight[1], torch.zeros(n_experts, dtype=torch.float32),
+    )
+    # No NaN anywhere.
+    assert not torch.isnan(payload.mean_weight).any()
+
+
+# ---------------------------------------------------------------------------
+# Test 4 -- checkpoint round-trip
+# ---------------------------------------------------------------------------
+
+
+def test_checkpoint_round_trip(tmp_path):
+    """Dump -> reload module -> load_checkpoint restores byte-identical
+    accumulator state."""
+    rts = _reload_rts({
+        "VLLM_CALIB_CAPTURE_ROUTING_STATS": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+    })
+    n_experts = 3
+    _seed_layer(rts, layer_idx=0, rank=0, n_experts=n_experts)
+    _seed_layer(rts, layer_idx=1, rank=1, n_experts=n_experts)
+
+    rts._FREQ_ACCUM[0] = torch.tensor([3, 5, 0], dtype=torch.int64)
+    rts._WEIGHT_SUM_ACCUM[0] = torch.tensor(
+        [1.5, 2.5, 0.0], dtype=torch.float32,
+    )
+    rts._FREQ_ACCUM[1] = torch.tensor([1, 0, 7], dtype=torch.int64)
+    rts._WEIGHT_SUM_ACCUM[1] = torch.tensor(
+        [0.5, 0.0, 4.0], dtype=torch.float32,
+    )
+    rts.set_n_prompts_accumulated(42)
+
+    ckpt = str(tmp_path / "test.rts.ckpt")
+    rts.dump_routing_stats_checkpoint(ckpt)
+    assert os.path.exists(ckpt)
+    assert not os.path.exists(ckpt + ".tmp")
+
+    # Fresh module load -- accumulators must hydrate from disk.
+    rts2 = _reload_rts({
+        "VLLM_CALIB_CAPTURE_ROUTING_STATS": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+    })
+    assert rts2._FREQ_ACCUM == {}  # fresh state
+    loaded = rts2.load_routing_stats_checkpoint(ckpt)
+    assert loaded == 42
+    assert rts2.get_n_prompts_accumulated() == 42
+    assert rts2._N_LAYERS == 2
+    assert rts2._N_EXPERTS == n_experts
+    assert torch.equal(
+        rts2._FREQ_ACCUM[0],
+        torch.tensor([3, 5, 0], dtype=torch.int64),
+    )
+    assert torch.equal(
+        rts2._WEIGHT_SUM_ACCUM[0],
+        torch.tensor([1.5, 2.5, 0.0], dtype=torch.float32),
+    )
+    assert torch.equal(
+        rts2._FREQ_ACCUM[1],
+        torch.tensor([1, 0, 7], dtype=torch.int64),
+    )
+    assert torch.equal(
+        rts2._WEIGHT_SUM_ACCUM[1],
+        torch.tensor([0.5, 0.0, 4.0], dtype=torch.float32),
+    )
+    assert rts2._LAYER_ID_TO_RANK == {0: 0, 1: 1}
+
+
+# ---------------------------------------------------------------------------
+# Test 5 -- two-segment additivity (freq + weight_sum are additive)
+# ---------------------------------------------------------------------------
+
+
+def test_two_segment_additivity(tmp_path):
+    """10 selections + ckpt + reload + 10 more selections == 20-selection
+    single run.
+
+    Critical for spot-preemption: an additive writer split across two
+    instance lifetimes must produce the same accumulator state as a
+    single run.
+    """
+    n_experts = 4
+    n_tokens_per = 10
+    top_k = 2
+
+    # Deterministic data.
+    torch.manual_seed(13)
+    ids_all = torch.randint(0, n_experts, (2 * n_tokens_per, top_k),
+                            dtype=torch.int64)
+    w_all = torch.rand(2 * n_tokens_per, top_k, dtype=torch.float32)
+
+    # --- single 20-selection reference run ---------------------------------
+    ref = _reload_rts({
+        "VLLM_CALIB_CAPTURE_ROUTING_STATS": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+    })
+    _seed_layer(ref, layer_idx=0, rank=0, n_experts=n_experts)
+    ref._on_router(
+        layer_idx=0, router_logits=torch.zeros(2 * n_tokens_per, n_experts),
+        topk_weights=w_all, topk_ids=ids_all,
+    )
+    expected_freq = ref._FREQ_ACCUM[0].clone()
+    expected_weight_sum = ref._WEIGHT_SUM_ACCUM[0].clone()
+
+    # --- split across two segments with a checkpoint + reload --------------
+    seg = _reload_rts({
+        "VLLM_CALIB_CAPTURE_ROUTING_STATS": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+    })
+    _seed_layer(seg, layer_idx=0, rank=0, n_experts=n_experts)
+    seg._on_router(
+        layer_idx=0,
+        router_logits=torch.zeros(n_tokens_per, n_experts),
+        topk_weights=w_all[:n_tokens_per],
+        topk_ids=ids_all[:n_tokens_per],
+    )
+    seg.set_n_prompts_accumulated(1)
+    ckpt = str(tmp_path / "twoseg.rts.ckpt")
+    seg.dump_routing_stats_checkpoint(ckpt)
+
+    # Reload module + checkpoint -- simulates a process restart.
+    seg2 = _reload_rts({
+        "VLLM_CALIB_CAPTURE_ROUTING_STATS": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+    })
+    seg2.load_routing_stats_checkpoint(ckpt)
+    seg2._on_router(
+        layer_idx=0,
+        router_logits=torch.zeros(n_tokens_per, n_experts),
+        topk_weights=w_all[n_tokens_per:],
+        topk_ids=ids_all[n_tokens_per:],
+    )
+
+    assert torch.equal(seg2._FREQ_ACCUM[0], expected_freq)
+    assert torch.allclose(
+        seg2._WEIGHT_SUM_ACCUM[0], expected_weight_sum, atol=1e-6,
+    )
+
+
+# ---------------------------------------------------------------------------
+# Test 6 -- env unset -> setup() is a no-op (no callback registered)
+# ---------------------------------------------------------------------------
+
+
+def test_gate_off_setup_is_no_op():
+    """With the env unset, ``setup(llm=None)`` must NOT register any
+    callback against the ``router`` hook -- the chained registry should
+    remain empty so production forwards pay nothing extra."""
+    rts = _reload_rts({})
+    assert rts._CAPTURE_ROUTING_STATS is False
+
+    import vllm.calibration_hooks as _ch
+    # Sanity-check: registry empty before setup.
+    assert _ch._callbacks["router"] == []
+
+    rts.setup(llm=None)
+    # Still empty -- gate is off, no registration happened.
+    assert _ch._callbacks["router"] == []
+    assert rts._FREQ_ACCUM == {}
+    assert rts._WEIGHT_SUM_ACCUM == {}
