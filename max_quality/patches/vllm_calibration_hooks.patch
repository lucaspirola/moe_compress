+# ---------------------------------------------------------------------------
+# Test 10 — chained callbacks coexist on a single hook (H1 regression)
+# ---------------------------------------------------------------------------
+#
+# Pins the H1 fix: ``vllm.calibration_imatrix.setup()`` and
+# ``vllm.calibration_input_cov.setup()`` both register a ``_on_expert_in``
+# callback for the same ``"expert_in"`` hook. Under the legacy single-slot
+# registry, whichever ran second silently overwrote the first; with the
+# multi-slot registry both subscribers receive every dispatch.
+
+
+def test_chained_callbacks_coexist_on_expert_in():
+    """Multiple callbacks registered for the same hook all fire on dispatch.
+
+    Mirror of the production wiring: imatrix.setup() and
+    input_cov.setup() both register their own ``_on_expert_in``. The
+    list-shaped registry must invoke BOTH on a single dispatch call,
+    preserving registration order.
+    """
+    ch = _reload_hooks({"VLLM_CALIB_CAPTURE_EXPERT": "1"})
+
+    seen_a: list[dict[str, Any]] = []
+    seen_b: list[dict[str, Any]] = []
+
+    def cb_a(**kwargs):
+        seen_a.append(kwargs)
+
+    def cb_b(**kwargs):
+        seen_b.append(kwargs)
+
+    ch.register_callback("expert_in", cb_a)
+    ch.register_callback("expert_in", cb_b)
+
+    payload = _mk_expert_in_payload(0)
+    ch.dispatch("expert_in", **payload)
+
+    # Both callbacks received the exact same payload, exactly once each.
+    assert len(seen_a) == 1
+    assert len(seen_b) == 1
+    assert seen_a[0]["layer_idx"] == 0
+    assert seen_b[0]["layer_idx"] == 0
+    assert torch.equal(seen_a[0]["hidden_states"], payload["hidden_states"])
+    assert torch.equal(seen_b[0]["hidden_states"], payload["hidden_states"])
+
+    # Registration order is preserved: cb_a is at index 0, cb_b at 1.
+    bucket = ch._callbacks["expert_in"]
+    assert bucket[0] is cb_a
+    assert bucket[1] is cb_b
+
+
+def test_register_callback_dedup_same_callable():
+    """Registering the same callable twice does NOT double-fire it.
+
+    Producer modules (imatrix, input_cov, …) call ``setup()`` -> which
+    calls ``register_callback`` -- across resume / driver reinitialisation
+    paths. Without identity-based de-dup the same callback would fire N
+    times per dispatch and double-count its accumulators.
+    """
+    ch = _reload_hooks({"VLLM_CALIB_CAPTURE_EXPERT": "1"})
+
+    seen: list[dict[str, Any]] = []
+
+    def cb(**kwargs):
+        seen.append(kwargs)
+
+    ch.register_callback("expert_in", cb)
+    ch.register_callback("expert_in", cb)  # duplicate -- must be a no-op.
+    ch.register_callback("expert_in", cb)  # ditto.
+
+    ch.dispatch("expert_in", **_mk_expert_in_payload(0))
+
+    assert len(seen) == 1, (
+        f"Duplicate registration fired the callback {len(seen)} times; "
+        f"expected exactly 1."
+    )
+    assert ch._callbacks["expert_in"] == [cb]
+
+
+def test_register_callback_none_clears_list():
+    """Passing fn=None clears every callback registered for the name."""
+    ch = _reload_hooks({"VLLM_CALIB_CAPTURE_EXPERT": "1"})
+
+    seen: list[dict[str, Any]] = []
+    ch.register_callback("expert_in", lambda **kw: seen.append(kw))
+    ch.register_callback("expert_in", lambda **kw: seen.append(kw))
+    assert len(ch._callbacks["expert_in"]) == 2
+
+    ch.register_callback("expert_in", None)
+    assert ch._callbacks["expert_in"] == []
+
+    ch.dispatch("expert_in", **_mk_expert_in_payload(0))
+    assert seen == []
