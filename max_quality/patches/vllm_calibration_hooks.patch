+# ---------------------------------------------------------------------------
+# Test 3 — multi-layer layer_idx correctness
+# ---------------------------------------------------------------------------
+
+
+def test_multi_layer_layer_idx_unique_and_full_range():
+    ch = _reload_hooks({"VLLM_CALIB_CAPTURE_BLOCK": "1"})
+
+    seen: list[int] = []
+    ch.register_callback("block_out", lambda **kw: seen.append(kw["layer_idx"]))
+
+    n_layers = 2  # matches planner small config
+    for layer_idx in range(n_layers):
+        ch.dispatch("block_out", **_mk_block_out_payload(layer_idx))
+
+    # No duplicates, covers full range.
+    assert seen == list(range(n_layers))
+    assert len(set(seen)) == n_layers
+
