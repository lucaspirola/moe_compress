+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Smoke tests for ``vllm.calibration_wanda_scalar_row``.
+
+These exercise the per-(layer, expert, "gate_proj") Wanda scalar_row
+accumulator, the router-stash + expert_in dispatch contract, the
+overwrite-no-clear stash lifecycle, and the checkpoint two-segment
+additivity invariant.
+
+Tests:
+
+1. ``test_accumulation_matches_reference`` (T1 in plan §9) -- synthetic
+   _on_router + _on_expert_in for one layer, one expert, two batches.
+   Final sigma_x_g_squared per-channel matches the upstream
+   running-mean formula
+   ``MoEPrunerHookFnForMixtralLinear`` (atol=1e-5; rtol=0).
+2. ``test_expert_in_without_router_logs_error`` (T2) -- expert_in fired
+   without a preceding router dispatch -> accumulator does NOT zero
+   the row, ERROR log is emitted, dump produces a (just empty-for-that-
+   layer) sidecar.
+3. ``test_router_stash_overwrites_no_clear`` (T2b) -- two consecutive
+   _on_router calls for the same layer leave only the latest weights
+   in the stash; reader uses the latest; reader does NOT clear.
+"""
+from __future__ import annotations
+
+import importlib
+import logging
+import os
+import sys
+from typing import Any
+
+import torch
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+
+def _reload_wanda_scalar_row(env: dict[str, str]) -> Any:
+    """Reload ``vllm.calibration_wanda_scalar_row`` (and hooks) with a
+    fresh env. Module-level ``_CAPTURE_WANDA_SCALAR_ROW`` is sampled at
+    import; per-test isolation requires a fresh import.
+    """
+    sys.modules.pop("vllm.calibration_wanda_scalar_row", None)
+    sys.modules.pop("vllm.calibration_hooks", None)
+    for key in (
+        "VLLM_CALIB_CAPTURE_WANDA_SCALAR_ROW",
+        "VLLM_CALIB_CAPTURE_ROUTER",
+        "VLLM_CALIB_CAPTURE_EXPERT",
+        "VLLM_CALIB_CAPTURE_REAP_SCORES",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED",
+        "VLLM_CALIB_CAPTURE_BLOCK",
+        "VLLM_CALIB_CAPTURE_IMATRIX",
+    ):
+        os.environ.pop(key, None)
+    for k, v in env.items():
+        os.environ[k] = v
+    importlib.import_module("vllm.calibration_hooks")
+    return importlib.import_module("vllm.calibration_wanda_scalar_row")
+
+
+def _seed_layer(wsr: Any, layer_idx: int, rank: int, n_experts: int) -> None:
+    """Manually wire up the per-layer book-keeping the way setup() would."""
+    wsr._LAYER_ID_TO_RANK[layer_idx] = rank
+    if rank + 1 > wsr._N_LAYERS:
+        wsr._N_LAYERS = rank + 1
+    if n_experts > wsr._N_EXPERTS:
+        wsr._N_EXPERTS = n_experts
+
+
+# ---------------------------------------------------------------------------
+# Test 1 (T1) -- accumulation matches reference upstream formula
+# ---------------------------------------------------------------------------
+
+
+def test_accumulation_matches_reference():
+    """Two batches of synthetic _on_router + _on_expert_in produce the
+    same per-(layer, expert, "gate_proj") sigma_x_g_squared as the
+    upstream running-mean reference at near-byte-equality
+    (atol=1e-5; rtol=0).
+
+    Reference math (MoEPrunerHookFnForMixtralLinear):
+
+        scalar_row[c] = E_t[(x_t[c] * g_{e,t})^2]
+                      = sum_t (x_t[c] * g_{e,t})^2 / N
+
+    where the expectation is over tokens routed to expert e and N is
+    that token count.
+    """
+    wsr = _reload_wanda_scalar_row({
+        "VLLM_CALIB_CAPTURE_WANDA_SCALAR_ROW": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT": "1",
+    })
+    n_experts = 4
+    d_in = 5
+    _seed_layer(wsr, layer_idx=0, rank=0, n_experts=n_experts)
+
+    # ---- Batch 1: two tokens, top_k=2, both routed to expert 0 in slot 0
+    # Token 0 -> (e=0, e=2) with weights (0.7, 0.3)
+    # Token 1 -> (e=0, e=1) with weights (0.6, 0.4)
+    # Hidden dim = 5; deterministic vectors so the math is hand-checkable.
+    torch.manual_seed(7)
+    hs1 = torch.randn(2, d_in, dtype=torch.float32)
+    tw1 = torch.tensor([[0.7, 0.3], [0.6, 0.4]], dtype=torch.float32)
+    ids1 = torch.tensor([[0, 2], [0, 1]], dtype=torch.int64)
+
+    wsr._on_router(layer_idx=0, router_logits=torch.zeros(2, n_experts),
+                   topk_weights=tw1, topk_ids=ids1)
+    wsr._on_expert_in(layer_idx=0, hidden_states=hs1, topk_ids=ids1)
+
+    # ---- Batch 2: three more tokens.
+    hs2 = torch.randn(3, d_in, dtype=torch.float32)
+    tw2 = torch.tensor(
+        [[0.5, 0.5], [0.8, 0.2], [0.1, 0.9]], dtype=torch.float32,
+    )
+    ids2 = torch.tensor([[0, 3], [1, 0], [2, 0]], dtype=torch.int64)
+
+    wsr._on_router(layer_idx=0, router_logits=torch.zeros(3, n_experts),
+                   topk_weights=tw2, topk_ids=ids2)
+    wsr._on_expert_in(layer_idx=0, hidden_states=hs2, topk_ids=ids2)
+
+    # ---- Reference: per-(layer, expert) per-channel running mean ---
+    # For each batch, iterate tokens/slots routed to expert 0 and add
+    # (x_t * g_{e=0, t, slot}) ** 2 per channel; finally divide by the
+    # token count.
+    def _reference_for_expert(e: int) -> tuple[torch.Tensor, int]:
+        sumsq = torch.zeros(d_in, dtype=torch.float32)
+        count = 0
+        for hs, tw, ids in ((hs1, tw1, ids1), (hs2, tw2, ids2)):
+            mask = (ids == e)
+            token_idx, slot_idx = mask.nonzero(as_tuple=True)
+            for t, s in zip(token_idx.tolist(), slot_idx.tolist()):
+                g = tw[t, s].item()
+                sumsq += (hs[t].to(torch.float32) * g).pow(2)
+                count += 1
+        return sumsq, count
+
+    for e in range(n_experts):
+        ref_sum, ref_count = _reference_for_expert(e)
+        key = (0, e, "gate_proj")
+        if ref_count == 0:
+            assert key not in wsr._WANDA_SCALAR_ROW_SUM
+            continue
+        got_sum = wsr._WANDA_SCALAR_ROW_SUM[key]
+        got_count = wsr._WANDA_TOKEN_COUNTS[key]
+        assert got_count == ref_count, (
+            f"expert {e}: count {got_count} vs ref {ref_count}"
+        )
+        assert torch.allclose(got_sum, ref_sum, rtol=0, atol=1e-5), (
+            f"expert {e}: sumsq mismatch"
+        )
+
+    # ---- Final dump produces the running MEAN (sum / count) ----------
+    # Drive dump via the on-disk path -- requires save_wanda_scalar_row
+    # which is a moe_compress-side helper. We assert the math by
+    # constructing the payload that dump_wanda_scalar_row would build.
+    for e in range(n_experts):
+        ref_sum, ref_count = _reference_for_expert(e)
+        if ref_count == 0:
+            continue
+        ref_mean = ref_sum / float(ref_count)
+        # Reconstruct what dump_wanda_scalar_row will emit:
+        key = (0, e, "gate_proj")
+        got_sum = wsr._WANDA_SCALAR_ROW_SUM[key]
+        got_count = wsr._WANDA_TOKEN_COUNTS[key]
+        got_mean = got_sum / float(max(1, got_count))
+        assert torch.allclose(got_mean, ref_mean, rtol=0, atol=1e-5)
+
+
+# ---------------------------------------------------------------------------
+# Test 2 (T2) -- expert_in without router fires an ERROR + skips
+# ---------------------------------------------------------------------------
+
+
+def test_expert_in_without_router_logs_error(caplog):
+    """expert_in dispatched without a preceding router dispatch -> the
+    accumulator is NOT touched and an ERROR is logged."""
+    wsr = _reload_wanda_scalar_row({
+        "VLLM_CALIB_CAPTURE_WANDA_SCALAR_ROW": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT": "1",
+    })
+    n_experts = 3
+    d_in = 4
+    _seed_layer(wsr, layer_idx=7, rank=0, n_experts=n_experts)
+
+    hs = torch.randn(2, d_in, dtype=torch.float32)
+    ids = torch.tensor([[0, 1], [1, 2]], dtype=torch.int64)
+
+    # The vllm.* loggers set propagate=False via the vllm logging
+    # config (see vllm/logger.py), so pytest's ``caplog`` fixture
+    # (which works by attaching to the root logger and relying on
+    # record propagation) silently captures NOTHING for these
+    # records. We attach a raw handler directly on the module's
+    # logger instead -- this is the canonical workaround for
+    # propagate=False loggers and is documented in pytest's caplog
+    # caveats. Switching to ``caplog`` would make the test green
+    # without actually verifying anything (the assertion list would
+    # be empty rather than containing the ERROR record).
+    module_log = logging.getLogger("vllm.calibration_wanda_scalar_row")
+    records: list[logging.LogRecord] = []
+    handler = logging.Handler()
+    handler.emit = records.append  # type: ignore[assignment]
+    handler.setLevel(logging.ERROR)
+    module_log.addHandler(handler)
+    try:
+        wsr._on_expert_in(layer_idx=7, hidden_states=hs, topk_ids=ids)
+    finally:
+        module_log.removeHandler(handler)
+
+    # Accumulator untouched.
+    assert not wsr._WANDA_SCALAR_ROW_SUM
+    assert not wsr._WANDA_TOKEN_COUNTS
+
+    # ERROR log was emitted with the layer index.
+    error_msgs = [r.getMessage() for r in records if r.levelno >= logging.ERROR]
+    assert any("layer 7" in m for m in error_msgs), (
+        f"Expected ERROR log mentioning 'layer 7', got: {error_msgs}"
+    )
+    assert any("VLLM_CALIB_CAPTURE_ROUTER" in m for m in error_msgs), (
+        f"Expected ERROR log mentioning the actionable env var: {error_msgs}"
+    )
+
+
+# ---------------------------------------------------------------------------
+# Test 3 (T2b) -- router-stash overwrite-on-fire, NO explicit clear
+# ---------------------------------------------------------------------------
+
+
+def test_router_stash_overwrites_no_clear():
+    """Two consecutive _on_router calls for the same layer leave only
+    the latest weights in the stash. Reader uses the latest. Reader
+    does NOT clear after consumption.
+
+    Anchors the §3.0 lifecycle claim in
+    ``tasks/PLAN_W1_WANDA_SCALAR_ROW_CAPTURE.md`` that the REAP
+    precedent is overwrite-on-router-fire + no explicit clear (the
+    inline comment at vllm_calibration_hooks.patch:8218 is stale).
+    """
+    wsr = _reload_wanda_scalar_row({
+        "VLLM_CALIB_CAPTURE_WANDA_SCALAR_ROW": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT": "1",
+    })
+    n_experts = 3
+    d_in = 4
+    _seed_layer(wsr, layer_idx=0, rank=0, n_experts=n_experts)
+
+    n_tok = 2
+    top_k = 2
+    W1 = torch.full((n_tok, top_k), 0.25, dtype=torch.float32)
+    W2 = torch.full((n_tok, top_k), 0.75, dtype=torch.float32)
+    ids = torch.tensor([[0, 1], [0, 2]], dtype=torch.int64)
+
+    # Step 1: first router fire -> stash holds W1.
+    wsr._on_router(layer_idx=0,
+                   router_logits=torch.zeros(n_tok, n_experts),
+                   topk_weights=W1, topk_ids=ids)
+    assert torch.allclose(
+        wsr._ROUTER_WEIGHTS_STASH[0],
+        W1.to("cpu", torch.float32),
+        rtol=0, atol=0,
+    )
+
+    # Step 2: second router fire (no intervening expert_in / clear) ->
+    # stash MUST hold W2 (latest), not W1 (not a concat or a sum).
+    wsr._on_router(layer_idx=0,
+                   router_logits=torch.zeros(n_tok, n_experts),
+                   topk_weights=W2, topk_ids=ids)
+    stashed = wsr._ROUTER_WEIGHTS_STASH[0]
+    assert torch.allclose(
+        stashed, W2.to("cpu", torch.float32), rtol=0, atol=0,
+    ), f"Expected W2 in stash; got: {stashed}"
+    assert not torch.allclose(
+        stashed, W1.to("cpu", torch.float32), rtol=0, atol=0,
+    ), "Stash still contains W1 — overwrite failed"
+
+    # Step 3: drive expert_in -> accumulator update uses W2's weights.
+    torch.manual_seed(11)
+    hs = torch.randn(n_tok, d_in, dtype=torch.float32)
+    wsr._on_expert_in(layer_idx=0, hidden_states=hs, topk_ids=ids)
+
+    # Expert 0 was selected in slot 0 of both tokens with weight 0.75
+    # (from W2). Per-channel contribution = sum_{t in {0,1}}
+    # (hs[t] * 0.75) ** 2.
+    expected = (hs * 0.75).pow(2).sum(dim=0)
+    got = wsr._WANDA_SCALAR_ROW_SUM[(0, 0, "gate_proj")]
+    assert torch.allclose(got, expected, rtol=0, atol=1e-5), (
+        f"Update used wrong weights; got {got}, expected {expected}"
+    )
+
+    # Step 4: stash entry survives the reader (no clear).
+    assert torch.allclose(
+        wsr._ROUTER_WEIGHTS_STASH[0],
+        W2.to("cpu", torch.float32),
+        rtol=0, atol=0,
+    ), "Reader cleared the stash — lifecycle violated"
