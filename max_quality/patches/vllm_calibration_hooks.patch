@@ -0,0 +1,468 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Smoke tests for ``vllm.calibration_output_reservoir``.
+
+These exercise the per-(layer, expert) two-phase fill+sample
+reservoir, the env-gate contract, checkpoint round-trip + two-segment
+additivity (in the fill-only regime so the math is exact), the
+persistent-buffer clone guard, and the dump-payload shape + bf16
+dtype + ``valid_count`` correctness.
+
+Tests:
+
+1. ``test_accumulator_math_fill_only`` -- a synthetic dispatch with
+   ``n_tok * top_k <= max_tokens`` populates the reservoir with the
+   input rows in routing order (Phase 1 fill regime; no Phase 2
+   sampling). Reservoir contents are byte-equal to the input slice.
+2. ``test_env_gate_off_no_op`` -- env unset → ``setup()`` and the
+   callback are no-ops (reservoirs untouched).
+3. ``test_checkpoint_round_trip`` -- dump → reload module →
+   load_checkpoint restores byte-identical reservoir state +
+   bookkeeping.
+4. ``test_two_segment_additivity_fill_only`` -- a fill-only split:
+   first N tokens + checkpoint + reload + remaining tokens ==
+   single-shot input slice. Exact (no randomness because every token
+   is accepted by Phase 1).
+5. ``test_persistent_buffer_clone`` -- callback clones ``unweighted``
+   at entry; post-callback mutation of the input does NOT alter the
+   stored reservoir row.
+6. ``test_dump_payload_shape_dtype_and_valid_count`` -- partial
+   accumulator (rank 0 only, two experts touched with different
+   valid counts) dumped → payload tensor is
+   ``[n_layers, n_experts, max_tokens, hidden]`` bf16; valid_count
+   matches the cell occupancies; rank-1 (untouched) is all zeros.
+"""
+from __future__ import annotations
+
+import importlib
+import os
+import sys
+from typing import Any
+
+import torch
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+
+def _reload_or(env: dict[str, str]) -> Any:
+    """Reload ``vllm.calibration_output_reservoir`` (and hooks) with a fresh env.
+
+    Module-level ``_CAPTURE_OUTPUT_RESERVOIR`` + ``_MAX_TOKENS`` are
+    sampled at import; per-test isolation requires a fresh import.
+    """
+    sys.modules.pop("vllm.calibration_output_reservoir", None)
+    sys.modules.pop("vllm.calibration_hooks", None)
+    for key in (
+        "VLLM_CALIB_CAPTURE_OUTPUT_RESERVOIR",
+        "VLLM_CALIB_OUTPUT_RESERVOIR_CAP",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED",
+        "VLLM_CALIB_CAPTURE_PER_EXPERT_MAX",
+        "VLLM_CALIB_CAPTURE_REAP_SCORES",
+        "VLLM_CALIB_CAPTURE_ROUTER",
+        "VLLM_CALIB_CAPTURE_IMATRIX",
+        "VLLM_CALIB_CAPTURE_EXPERT",
+        "VLLM_CALIB_CAPTURE_BLOCK",
+        "VLLM_CALIB_CAPTURE_EXPERT_MID",
+        "VLLM_CALIB_CAPTURE_INPUT_COV",
+    ):
+        os.environ.pop(key, None)
+    for k, v in env.items():
+        os.environ[k] = v
+    importlib.import_module("vllm.calibration_hooks")
+    return importlib.import_module("vllm.calibration_output_reservoir")
+
+
+def _seed_layer(or_: Any, layer_idx: int, rank: int, n_experts: int) -> None:
+    """Manually wire up the per-layer rank table the way setup() would."""
+    or_._LAYER_ID_TO_RANK[layer_idx] = rank
+    if rank + 1 > or_._N_LAYERS:
+        or_._N_LAYERS = rank + 1
+    if n_experts > or_._N_EXPERTS:
+        or_._N_EXPERTS = n_experts
+
+
+# ---------------------------------------------------------------------------
+# Test 1 -- accumulator math (single layer, fill-only regime)
+# ---------------------------------------------------------------------------
+
+
+def test_accumulator_math_fill_only():
+    """A synthetic dispatch with ``n_tok * top_k <= max_tokens`` populates
+    every reservoir cell with the routed input rows in order.
+
+    With ``max_tokens=8`` and 3 tokens × top_k=2 = 6 routed entries,
+    every entry hits Phase 1 (sequential fill) regardless of expert,
+    making the reservoir contents byte-equal to the input rows in
+    routing order.
+    """
+    or_ = _reload_or({
+        "VLLM_CALIB_CAPTURE_OUTPUT_RESERVOIR": "1",
+        "VLLM_CALIB_OUTPUT_RESERVOIR_CAP": "8",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    assert or_._MAX_TOKENS == 8
+    n_experts = 4
+    hidden = 3
+    _seed_layer(or_, layer_idx=0, rank=0, n_experts=n_experts)
+
+    # 3 tokens, top_k=2, hidden=3. Token (t, k) routes to topk_ids[t, k].
+    # Token 0: e=0, e=2
+    # Token 1: e=1, e=2
+    # Token 2: e=0, e=3
+    unweighted = torch.tensor([
+        [[ 1.0,  2.0,  3.0],   # t0 k0 -> e0
+         [ 4.0,  5.0,  6.0]],  # t0 k1 -> e2
+        [[ 7.0,  8.0,  9.0],   # t1 k0 -> e1
+         [10.0, 11.0, 12.0]],  # t1 k1 -> e2
+        [[13.0, 14.0, 15.0],   # t2 k0 -> e0
+         [16.0, 17.0, 18.0]],  # t2 k1 -> e3
+    ], dtype=torch.float32)
+    topk_ids = torch.tensor(
+        [[0, 2], [1, 2], [0, 3]], dtype=torch.int64,
+    )
+
+    or_._on_expert_out_unweighted(
+        layer_idx=0, unweighted=unweighted, topk_ids=topk_ids,
+    )
+
+    # Hand-computed reservoir contents (Phase 1 fill, routing order):
+    # e0: [t0k0=(1,2,3), t2k0=(13,14,15)]  -> valid_count=2
+    # e1: [t1k0=(7,8,9)]                   -> valid_count=1
+    # e2: [t0k1=(4,5,6), t1k1=(10,11,12)]  -> valid_count=2
+    # e3: [t2k1=(16,17,18)]                -> valid_count=1
+    # Unused expert: not in topk_ids → no reservoir allocated.
+    r0 = or_._RESERVOIR[(0, 0)]
+    assert r0.shape == (8, hidden)
+    assert torch.equal(r0[0], torch.tensor([1.0, 2.0, 3.0]))
+    assert torch.equal(r0[1], torch.tensor([13.0, 14.0, 15.0]))
+    # Remaining slots are zeros (initialized).
+    assert torch.equal(r0[2:], torch.zeros(6, hidden))
+    assert or_._VALID_COUNT[(0, 0)] == 2
+    assert or_._SEEN[(0, 0)] == 2
+
+    r1 = or_._RESERVOIR[(0, 1)]
+    assert torch.equal(r1[0], torch.tensor([7.0, 8.0, 9.0]))
+    assert or_._VALID_COUNT[(0, 1)] == 1
+    assert or_._SEEN[(0, 1)] == 1
+
+    r2 = or_._RESERVOIR[(0, 2)]
+    assert torch.equal(r2[0], torch.tensor([4.0, 5.0, 6.0]))
+    assert torch.equal(r2[1], torch.tensor([10.0, 11.0, 12.0]))
+    assert or_._VALID_COUNT[(0, 2)] == 2
+    assert or_._SEEN[(0, 2)] == 2
+
+    r3 = or_._RESERVOIR[(0, 3)]
+    assert torch.equal(r3[0], torch.tensor([16.0, 17.0, 18.0]))
+    assert or_._VALID_COUNT[(0, 3)] == 1
+    assert or_._SEEN[(0, 3)] == 1
+
+
+# ---------------------------------------------------------------------------
+# Test 2 -- env-off short-circuit
+# ---------------------------------------------------------------------------
+
+
+def test_env_gate_off_no_op():
+    """Env unset → setup() is a no-op, and the callback short-circuits
+    before touching any reservoir."""
+    or_ = _reload_or({})  # env cleared
+    assert or_._CAPTURE_OUTPUT_RESERVOIR is False
+
+    # setup() with a stub LLM -> should not register callbacks nor
+    # allocate reservoirs.
+    or_.setup(llm=None)
+    assert or_._RESERVOIR == {}
+    assert or_._SEEN == {}
+    assert or_._VALID_COUNT == {}
+
+    # Seed the rank table manually and call the callback. The internal
+    # env guard must short-circuit before any allocation.
+    n_experts = 2
+    _seed_layer(or_, layer_idx=0, rank=0, n_experts=n_experts)
+
+    unweighted = torch.tensor(
+        [[[1.0, 0.0], [0.0, 1.0]]], dtype=torch.float32,
+    )
+    topk_ids = torch.tensor([[0, 1]], dtype=torch.int64)
+    or_._on_expert_out_unweighted(
+        layer_idx=0, unweighted=unweighted, topk_ids=topk_ids,
+    )
+    assert or_._RESERVOIR == {}
+    assert or_._SEEN == {}
+    assert or_._VALID_COUNT == {}
+
+
+# ---------------------------------------------------------------------------
+# Test 3 -- checkpoint round-trip
+# ---------------------------------------------------------------------------
+
+
+def test_checkpoint_round_trip(tmp_path):
+    """Dump → reload module → load_checkpoint restores byte-identical state.
+
+    Validates the reservoir tensors, ``_SEEN``, ``_VALID_COUNT``,
+    ``_LAYER_ID_TO_RANK``, ``_N_LAYERS``, ``_N_EXPERTS``,
+    ``_MAX_TOKENS``, and ``_n_prompts_accumulated`` all round-trip.
+    """
+    or_ = _reload_or({
+        "VLLM_CALIB_CAPTURE_OUTPUT_RESERVOIR": "1",
+        "VLLM_CALIB_OUTPUT_RESERVOIR_CAP": "4",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    n_experts = 3
+    _seed_layer(or_, layer_idx=0, rank=0, n_experts=n_experts)
+    _seed_layer(or_, layer_idx=1, rank=1, n_experts=n_experts)
+
+    # Manually populate a couple of cells with deterministic data.
+    or_._RESERVOIR[(0, 0)] = torch.tensor(
+        [[1.0, 2.0], [3.0, 4.0], [0.0, 0.0], [0.0, 0.0]], dtype=torch.float32,
+    )
+    or_._SEEN[(0, 0)] = 2
+    or_._VALID_COUNT[(0, 0)] = 2
+    or_._RESERVOIR[(1, 2)] = torch.tensor(
+        [[9.0, 8.0], [7.0, 6.0], [5.0, 4.0], [3.0, 2.0]], dtype=torch.float32,
+    )
+    or_._SEEN[(1, 2)] = 7
+    or_._VALID_COUNT[(1, 2)] = 4
+    or_.set_n_prompts_accumulated(42)
+
+    ckpt = str(tmp_path / "test.or.ckpt")
+    or_.dump_output_reservoir_checkpoint(ckpt)
+    assert os.path.exists(ckpt)
+    assert not os.path.exists(ckpt + ".tmp")
+
+    # Fresh module load -- reservoirs must hydrate from disk.
+    or2 = _reload_or({
+        "VLLM_CALIB_CAPTURE_OUTPUT_RESERVOIR": "1",
+        "VLLM_CALIB_OUTPUT_RESERVOIR_CAP": "4",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    assert or2._RESERVOIR == {}  # fresh state
+    loaded = or2.load_output_reservoir_checkpoint(ckpt)
+    assert loaded == 42
+    assert or2.get_n_prompts_accumulated() == 42
+    assert or2._N_LAYERS == 2
+    assert or2._N_EXPERTS == n_experts
+    assert or2._LAYER_ID_TO_RANK == {0: 0, 1: 1}
+    assert or2._SEEN[(0, 0)] == 2
+    assert or2._VALID_COUNT[(0, 0)] == 2
+    assert torch.equal(
+        or2._RESERVOIR[(0, 0)],
+        torch.tensor(
+            [[1.0, 2.0], [3.0, 4.0], [0.0, 0.0], [0.0, 0.0]],
+            dtype=torch.float32,
+        ),
+    )
+    assert or2._SEEN[(1, 2)] == 7
+    assert or2._VALID_COUNT[(1, 2)] == 4
+    assert torch.equal(
+        or2._RESERVOIR[(1, 2)],
+        torch.tensor(
+            [[9.0, 8.0], [7.0, 6.0], [5.0, 4.0], [3.0, 2.0]],
+            dtype=torch.float32,
+        ),
+    )
+
+
+# ---------------------------------------------------------------------------
+# Test 4 -- two-segment additivity (fill-only so exact)
+# ---------------------------------------------------------------------------
+
+
+def test_two_segment_additivity_fill_only(tmp_path):
+    """Fill-only split: first N tokens + checkpoint + reload + remaining
+    tokens ≡ a single dispatch of all tokens.
+
+    Critical for spot-preemption: a reservoir-aggregating writer split
+    across two instance lifetimes must produce the same reservoir state
+    as a single run. Exact only in the fill-only regime (total tokens
+    per expert ≤ max_tokens) because Phase 2 sampling is stochastic.
+    """
+    n_experts = 2
+    top_k = 1
+    cap = 8
+    hidden = 2
+    # 6 tokens total, all routing to expert 0 → 6 <= 8 → fill-only.
+    torch.manual_seed(7)
+    n_tok = 6
+    uw_all = torch.randn(n_tok, top_k, hidden, dtype=torch.float32)
+    ids_all = torch.zeros(n_tok, top_k, dtype=torch.int64)
+
+    # --- single 6-token reference run ---------------------------------
+    ref = _reload_or({
+        "VLLM_CALIB_CAPTURE_OUTPUT_RESERVOIR": "1",
+        "VLLM_CALIB_OUTPUT_RESERVOIR_CAP": str(cap),
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    _seed_layer(ref, layer_idx=0, rank=0, n_experts=n_experts)
+    ref._on_expert_out_unweighted(
+        layer_idx=0, unweighted=uw_all, topk_ids=ids_all,
+    )
+    expected_reservoir = ref._RESERVOIR[(0, 0)].clone()
+    expected_seen = ref._SEEN[(0, 0)]
+    expected_valid = ref._VALID_COUNT[(0, 0)]
+
+    # --- split across two segments with a checkpoint + reload ----------
+    n_seg = 3
+    seg = _reload_or({
+        "VLLM_CALIB_CAPTURE_OUTPUT_RESERVOIR": "1",
+        "VLLM_CALIB_OUTPUT_RESERVOIR_CAP": str(cap),
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    _seed_layer(seg, layer_idx=0, rank=0, n_experts=n_experts)
+    seg._on_expert_out_unweighted(
+        layer_idx=0,
+        unweighted=uw_all[:n_seg],
+        topk_ids=ids_all[:n_seg],
+    )
+    seg.set_n_prompts_accumulated(1)
+    ckpt = str(tmp_path / "twoseg.or.ckpt")
+    seg.dump_output_reservoir_checkpoint(ckpt)
+
+    # Reload module + checkpoint -- simulates a process restart.
+    seg2 = _reload_or({
+        "VLLM_CALIB_CAPTURE_OUTPUT_RESERVOIR": "1",
+        "VLLM_CALIB_OUTPUT_RESERVOIR_CAP": str(cap),
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    seg2.load_output_reservoir_checkpoint(ckpt)
+    seg2._on_expert_out_unweighted(
+        layer_idx=0,
+        unweighted=uw_all[n_seg:],
+        topk_ids=ids_all[n_seg:],
+    )
+
+    assert torch.equal(seg2._RESERVOIR[(0, 0)], expected_reservoir)
+    assert seg2._SEEN[(0, 0)] == expected_seen
+    assert seg2._VALID_COUNT[(0, 0)] == expected_valid
+
+
+# ---------------------------------------------------------------------------
+# Test 5 -- persistent-buffer clone safety
+# ---------------------------------------------------------------------------
+
+
+def test_persistent_buffer_clone():
+    """Callback must clone ``unweighted`` at entry; post-callback mutation
+    of the input does NOT corrupt the reservoir."""
+    or_ = _reload_or({
+        "VLLM_CALIB_CAPTURE_OUTPUT_RESERVOIR": "1",
+        "VLLM_CALIB_OUTPUT_RESERVOIR_CAP": "4",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    n_experts = 2
+    _seed_layer(or_, layer_idx=0, rank=0, n_experts=n_experts)
+
+    # 1 token, top_k=1, hidden=3.
+    unweighted = torch.tensor([[[1.0, -2.5, 3.5]]], dtype=torch.float32)
+    topk_ids = torch.tensor([[1]], dtype=torch.int64)
+    or_._on_expert_out_unweighted(
+        layer_idx=0, unweighted=unweighted, topk_ids=topk_ids,
+    )
+    stored = or_._RESERVOIR[(0, 1)][0].clone()
+    assert torch.equal(stored, torch.tensor([1.0, -2.5, 3.5]))
+
+    # Mutate the persistent buffer in place (simulates the Triton
+    # kernel's next forward overwriting it). The stored reservoir row
+    # must NOT reflect the mutated contents.
+    unweighted.fill_(999.0)
+    assert torch.equal(or_._RESERVOIR[(0, 1)][0], stored)
+
+
+# ---------------------------------------------------------------------------
+# Test 6 -- dump payload shape + bf16 dtype + valid_count correctness
+# ---------------------------------------------------------------------------
+
+
+def test_dump_payload_shape_dtype_and_valid_count(tmp_path, monkeypatch):
+    """Partial accumulator dumped → payload tensor is
+    ``[n_layers, n_experts, max_tokens, hidden]`` bf16, valid_count matches
+    cell occupancies, and rank-1 (untouched) row is all zeros.
+    """
+    or_ = _reload_or({
+        "VLLM_CALIB_CAPTURE_OUTPUT_RESERVOIR": "1",
+        "VLLM_CALIB_OUTPUT_RESERVOIR_CAP": "4",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    n_experts = 3
+    hidden = 2
+    _seed_layer(or_, layer_idx=0, rank=0, n_experts=n_experts)
+    _seed_layer(or_, layer_idx=1, rank=1, n_experts=n_experts)
+
+    # Only rank 0 sees any traffic; experts 0 + 2 are touched with
+    # different valid counts. Expert 1 in rank 0, and ALL of rank 1,
+    # never see a dispatch.
+    or_._RESERVOIR[(0, 0)] = torch.tensor(
+        [[1.0, 2.0], [3.0, 4.0], [0.0, 0.0], [0.0, 0.0]], dtype=torch.float32,
+    )
+    or_._SEEN[(0, 0)] = 2
+    or_._VALID_COUNT[(0, 0)] = 2
+    or_._RESERVOIR[(0, 2)] = torch.tensor(
+        [[5.0, 6.0], [7.0, 8.0], [9.0, 10.0], [11.0, 12.0]],
+        dtype=torch.float32,
+    )
+    or_._SEEN[(0, 2)] = 6
+    or_._VALID_COUNT[(0, 2)] = 4
+
+    captured = {}
+
+    def _fake_save(payload, path):
+        captured["payload"] = payload
+        captured["path"] = path
+
+    import moe_compress.utils.cached_calibration_signals as ccs
+    monkeypatch.setattr(ccs, "save_output_reservoir", _fake_save)
+
+    jsonl = tmp_path / "trace.jsonl"
+    or_.dump_output_reservoir(jsonl)
+
+    payload = captured["payload"]
+    assert payload is not None
+    assert payload.schema_version == 1
+    assert payload.n_layers == 2
+    assert payload.n_experts == n_experts
+    assert payload.max_tokens == 4
+    # Shape and dtype contract.
+    assert payload.reservoir.shape == (2, n_experts, 4, hidden)
+    # The dump writes a fp32 tensor; save_output_reservoir casts to bf16.
+    # Here we asserted shape; the bf16 cast is exercised by the
+    # cached_calibration_signals round-trip test.
+    assert payload.valid_count.shape == (2, n_experts)
+    assert payload.total_seen.shape == (2, n_experts)
+    # Rank 0 / expert 0 contents preserved.
+    assert torch.equal(
+        payload.reservoir[0, 0],
+        torch.tensor(
+            [[1.0, 2.0], [3.0, 4.0], [0.0, 0.0], [0.0, 0.0]],
+            dtype=torch.float32,
+        ),
+    )
+    # Rank 0 / expert 2 contents preserved.
+    assert torch.equal(
+        payload.reservoir[0, 2],
+        torch.tensor(
+            [[5.0, 6.0], [7.0, 8.0], [9.0, 10.0], [11.0, 12.0]],
+            dtype=torch.float32,
+        ),
+    )
+    # Untouched cells are zeros.
+    assert torch.equal(
+        payload.reservoir[0, 1], torch.zeros(4, hidden, dtype=torch.float32),
+    )
+    assert torch.equal(
+        payload.reservoir[1], torch.zeros(n_experts, 4, hidden, dtype=torch.float32),
+    )
+    # valid_count matches the populated occupancies.
+    assert payload.valid_count[0, 0].item() == 2
+    assert payload.valid_count[0, 1].item() == 0
+    assert payload.valid_count[0, 2].item() == 4
+    assert torch.equal(
+        payload.valid_count[1], torch.zeros(n_experts, dtype=torch.int64),
+    )
+    # total_seen mirrors _SEEN.
+    assert payload.total_seen[0, 0].item() == 2
+    assert payload.total_seen[0, 2].item() == 6
+    assert payload.total_seen[0, 1].item() == 0
