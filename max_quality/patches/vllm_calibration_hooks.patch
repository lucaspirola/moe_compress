+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Per-(layer, expert, matrix) teacher input covariance capture for
+calibration-v2 (Item 1 of the writers campaign).
+
+Computes ``Σ_in[(layer, expert, matrix)] = Σ_t x_t^T x_t`` over the token
+positions that the router dispatches to each expert. Mirrors the on-disk
+dict-of-tensor shape used by Stage 2's
+``_stage2_input_covariance.pt`` writer (see
+``moe_compress/stage2/shared_io.py::_save_covariance``) so the same
+loaders in ``stage3/plugins/covariance_collection.py`` and
+``stage4/plugins/eora_inputs.py`` consume both interchangeably.
+
+Hook surface
+------------
+* ``expert_in`` (vllm/model_executor/layers/fused_moe/moe_runner.py)
+  dispatches ``(layer_idx, hidden_states, topk_ids)`` per MoE layer
+  forward, BEFORE the per-expert dispatch_combine. ``hidden_states`` is
+  the pre-routing hidden state -- the input that ``gate_proj`` (and
+  ``up_proj`` via the aliased entry, per Stage 2's
+  ``InputCovarianceAccumulator._alias_gate_up``) would see for any token
+  the router sends to each expert.
+
+Per the existing Stage 2 / 3 / 4 convention, this writer only emits
+``matrix_name="gate_proj"`` entries -- ``up_proj`` is served by the
+gate->up fallback in ``aa_svd_factor._cov_lookup``. ``down_proj`` would
+require an additional ``expert_mid`` hook against per-expert
+intermediates (post SwiGLU), which is out of scope for the input-cov
+writer (Stage 3 falls back to Corollary 3.3 / B-only for down_proj when
+no cross-cov is available -- see deviation D6 in
+``stage3/plugins/covariance_collection.py``).
+
+Env-var gating
+--------------
+``VLLM_CALIB_CAPTURE_INPUT_COV=1`` activates the module. Requires:
+
+* ``VLLM_CALIB_CAPTURE_EXPERT=1`` (so the ``expert_in`` hook fires from
+  the MoE forward path; the calibration_hooks dispatcher gates on this).
+
+The driver (``build_self_traces_calib_vllm.py``) sets both env vars
+BEFORE the first vllm import when ``--capture-input-covariance`` is
+passed.
+
+CUDA-graph compatibility
+------------------------
+Accumulators live on CPU (fp32). The callback is dispatched from Python
+synchronously after the kernel returns and clones the input before
+returning; no in-kernel allocation. Safe for CUDA-graph capture.
+
+Storage shape
+-------------
+For Qwen3.6-35B-A3B at hidden=2048, n_layers≈48, n_experts=256, the
+on-disk size is ~50-70 GB (matches the documented
+``_stage2_input_covariance.pt`` artifact; see
+``max_quality/docs/pipeline_status_2026-04-27.md``). Storage dtype on
+disk is fp16 (per deviation D-cov-storage-fp16); the live accumulator
+runs in fp32 to limit round-off across the millions of accumulation
+calls, casting only at ``dump_input_cov`` time inside
+``save_covariance``.
+
+Resumability
+------------
+Mirrors ``vllm.calibration_reap_scores``: periodic
+``dump_input_cov_checkpoint`` during the run,
+``load_input_cov_checkpoint`` on ``--resume``. The final
+``dump_input_cov`` writes the normalised payload via
+``moe_compress.utils.cached_calibration_signals.save_covariance`` (Item
+0 helper, schema v2).
+"""
+from __future__ import annotations
+
+import logging
+import os
+from pathlib import Path
+from typing import Any
+
+import torch
+
+import vllm.calibration_hooks as _ch
+
+log = logging.getLogger(__name__)
+
+__all__ = [
+    "setup",
+    "dump_input_cov",
+    "dump_input_cov_checkpoint",
+    "load_input_cov_checkpoint",
+    "get_n_prompts_accumulated",
+    "set_n_prompts_accumulated",
+]
+
+# Sampled at import time -- matches calibration_reap_scores / imatrix.
+_CAPTURE_INPUT_COV: bool = (
+    os.getenv("VLLM_CALIB_CAPTURE_INPUT_COV", "0") == "1"
+)
+
+# Per-(layer_idx, expert_idx, matrix_name) CPU accumulators (fp32).
+# Mirrors the on-disk shape of ``_stage2_input_covariance.pt``: the same
+# keys (with matrix_name == "gate_proj") and value Tensor[d_in, d_in].
+_COV_ACCUM: dict[tuple[int, int, str], torch.Tensor] = {}
+_COV_TOKEN_COUNTS: dict[tuple[int, int, str], int] = {}
+
+# Layer-ID -> rank map (kept for parity with reap_scores; consumed by
+# checkpoint payload serialization and downstream sanity assertions).
+_LAYER_ID_TO_RANK: dict[int, int] = {}
+_N_LAYERS: int = 0
+_N_EXPERTS: int = 0
+
+# Cumulative prompt counter mirroring reap_scores / imatrix.
+_n_prompts_accumulated: int = 0
+_CHECKPOINT_SCHEMA_VERSION: int = 1
+
+# Internal: keep d_in once seen so we can lazy-allocate per-expert
+# entries on the first dispatch. Used only by _on_expert_in.
+_D_IN: int | None = None
+
+
+def get_n_prompts_accumulated() -> int:
+    return _n_prompts_accumulated
+
+
+def set_n_prompts_accumulated(n: int) -> None:
+    global _n_prompts_accumulated
+    if n < 0:
+        raise ValueError(f"n must be >= 0; got {n}")
+    _n_prompts_accumulated = int(n)
+
+
+def _resolve_model(llm: Any) -> Any | None:
+    """Walk well-known attribute paths to find the live nn.Module."""
+    candidates = [
+        ("llm_engine", "model_executor", "driver_worker", "model_runner",
+         "model"),
+        ("llm_engine", "model_executor", "model_runner", "model"),
+        ("model_executor", "driver_worker", "model_runner", "model"),
+        ("model_runner", "model"),
+    ]
+    for path in candidates:
+        obj: Any = llm
+        ok = True
+        for attr in path:
+            obj = getattr(obj, attr, None)
+            if obj is None:
+                ok = False
+                break
+        if ok:
+            return obj
+    return None
+
+
+def setup(llm: Any) -> None:
+    """Discover MoE layers, build the layer_id_to_rank map, register
+    the ``expert_in`` callback. Idempotent: calling twice does not
+    double-register.
+
+    Per-expert accumulators are LAZILY allocated on the first dispatch
+    (we don't know ``d_in`` until the first hidden_states comes in -- the
+    model config exposes ``hidden_size`` but reading it requires the
+    same model-walk we already do here; the lazy path is simpler and
+    cheaper on the cold path).
+    """
+    global _N_LAYERS, _N_EXPERTS
+
+    if not _CAPTURE_INPUT_COV:
+        log.info("calibration_input_cov: env gate off; no-op setup.")
+        return
+
+    model = _resolve_model(llm)
+    if model is None:
+        log.warning(
+            "calibration_input_cov: could not resolve model from LLM; "
+            "callback will be registered but the layer_id_to_rank map "
+            "will be populated lazily from the first expert_in dispatch."
+        )
+
+    # Discover MoE layers by attribute presence (mirrors reap_scores).
+    n_layers = 0
+    n_experts_seen: int | None = None
+    if model is not None:
+        for name, module in model.named_modules():
+            moe_layer_id = getattr(module, "moe_layer_id", None)
+            num_experts = getattr(module, "num_experts", None)
+            if not (isinstance(moe_layer_id, int)
+                    and isinstance(num_experts, int) and num_experts > 0):
+                continue
+            _LAYER_ID_TO_RANK[moe_layer_id] = n_layers
+            if n_experts_seen is None:
+                n_experts_seen = num_experts
+            elif n_experts_seen != num_experts:
+                log.warning(
+                    "calibration_input_cov: mixed expert counts "
+                    "(%d vs first-seen %d at %s); using first.",
+                    num_experts, n_experts_seen, name,
+                )
+            n_layers += 1
+
+    _N_LAYERS = n_layers
+    _N_EXPERTS = int(n_experts_seen) if n_experts_seen is not None else 0
+
+    _ch.register_callback("expert_in", _on_expert_in)
+
+    log.info(
+        "calibration_input_cov: setup complete -- %d MoE layers, "
+        "%d experts/layer; callback registered for expert_in.",
+        _N_LAYERS, _N_EXPERTS,
+    )
+
+
+def _on_expert_in(layer_idx: int, hidden_states: torch.Tensor,
+                  topk_ids: torch.Tensor, **_: Any) -> None:
+    """Accumulate ``x^T @ x`` per (layer, expert, "gate_proj").
+
+    For each expert ``e``, gather the rows of ``hidden_states`` whose
+    ``topk_ids`` contain ``e`` and accumulate the matmul into the CPU
+    fp32 buffer. Matches Stage 2's ``InputCovarianceAccumulator.update``
+    semantics (the consumer side of the same dict shape).
+
+    CPU-residency rationale
+    -----------------------
+    ``hidden_states`` is ephemeral per the calibration_hooks contract,
+    but we read it into a CPU fp32 copy immediately so the workspace
+    overwrite on the next forward cannot corrupt our reads. The
+    ``x^T @ x`` matmul itself ALSO happens on CPU, deliberately. The
+    Stage 2 live ``InputCovarianceAccumulator.update`` keeps the matmul
+    on-device because it runs on a HuggingFace forward path WITHOUT
+    CUDA-graph capture; this writer runs from a vLLM ``expert_in``
+    dispatch INSIDE a CUDA-graph-captured region of the MoE forward,
+    where any device-side allocation or cross-stream sync risks a
+    capture-time crash (lazy alloc is forbidden under graph capture).
+    Keeping the accumulation entirely on CPU eliminates that hazard:
+    the only device-side work is the ``.to("cpu")`` copy, which is
+    safe under capture. Row counts per expert are small (~top_k tokens
+    per expert per forward), so the CPU matmul overhead is bounded.
+    A pre-flight benchmark on the real run will measure whether this
+    becomes a bottleneck; if so, the alternative is a per-batch
+    device-side coalesce -> single CPU copy, NOT a per-expert device
+    matmul (which re-introduces the multi-stream sync hazard).
+    """
+    if not _CAPTURE_INPUT_COV:
+        return
+
+    if layer_idx not in _LAYER_ID_TO_RANK:
+        # Lazy-discovered layer (setup() couldn't walk the model).
+        # Append a fresh rank so the checkpoint payload covers it.
+        rank = len(_LAYER_ID_TO_RANK)
+        _LAYER_ID_TO_RANK[layer_idx] = rank
+
+    global _D_IN, _N_LAYERS, _N_EXPERTS
+    hs = hidden_states.detach().to("cpu", dtype=torch.float32, copy=True)
+    if hs.numel() == 0:
+        return
+    if hs.dim() == 3:
+        # [batch, seq, hidden] -> [n_tok, hidden]
+        hs = hs.reshape(-1, hs.shape[-1])
+    if _D_IN is None:
+        _D_IN = int(hs.shape[-1])
+
+    ids = topk_ids.detach().to("cpu", dtype=torch.int64)
+    n_tok = hs.shape[0]
+    # ``ids`` may be [n_tok, top_k] or already [n_tok]; normalise.
+    if ids.dim() == 1:
+        ids = ids.unsqueeze(-1)
+    if ids.shape[0] != n_tok:
+        log.warning(
+            "calibration_input_cov: layer %d -- topk_ids first dim %d "
+            "does not match hidden_states n_tok %d; skipping.",
+            layer_idx, ids.shape[0], n_tok,
+        )
+        return
+
+    # Update the seen-expert ceiling so the checkpoint metadata reflects
+    # reality even when setup() couldn't read num_experts off the model.
+    seen_max = int(ids.max().item()) + 1 if ids.numel() > 0 else 0
+    if seen_max > _N_EXPERTS:
+        _N_EXPERTS = seen_max
+
+    # Per-expert accumulation. The router topk_ids selects which tokens
+    # contribute to which expert; a token may appear in top_k experts so
+    # its row contributes to top_k entries (matching the live Stage 2
+    # accumulator's behaviour where each expert's covariance is built
+    # from the rows the router dispatches to that expert).
+    for e in range(seen_max):
+        # Mask of (token, slot) pairs routed to expert e.
+        mask_2d = (ids == e)
+        if not mask_2d.any():
+            continue
+        # Token rows that route at least once to e. ``unique`` keeps each
+        # token at most once even if both top_k slots point at e (rare,
+        # but matches the Stage 2 update semantics where a single
+        # input_cb call appends the row once -- the per-call x.T @ x).
+        token_rows = mask_2d.any(dim=-1).nonzero(as_tuple=False).reshape(-1)
+        if token_rows.numel() == 0:
+            continue
+        sub = hs.index_select(0, token_rows)        # [n_e, d_in] fp32
+        contrib = sub.transpose(0, 1) @ sub          # [d_in, d_in]
+
+        key = (layer_idx, int(e), "gate_proj")
+        cur = _COV_ACCUM.get(key)
+        if cur is None:
+            _COV_ACCUM[key] = contrib
+        else:
+            cur.add_(contrib)
+        _COV_TOKEN_COUNTS[key] = (
+            _COV_TOKEN_COUNTS.get(key, 0) + int(token_rows.numel())
+        )
+
+    # _N_LAYERS may grow lazily if setup() couldn't pre-discover layers.
+    if len(_LAYER_ID_TO_RANK) > _N_LAYERS:
+        _N_LAYERS = len(_LAYER_ID_TO_RANK)
+
+
+def dump_input_cov(jsonl_path: str | Path) -> None:
+    """Write the final per-(layer, expert, matrix) Σ_in sidecar.
+
+    The accumulator already holds ``Σ_t x_t^T x_t`` (unnormalised sum --
+    matches Stage 2's ``_stage2_input_covariance.pt`` convention; the
+    downstream consumers in ``aa_svd_factor`` and EoRA do their own
+    normalisation by token count when needed). No per-key division
+    happens here; ``token_counts`` is persisted alongside for callers
+    that need ``E[x^T x]``.
+    """
+    if not _CAPTURE_INPUT_COV:
+        return
+
+    # Import here (not at module top) so the dependency is lazy.
+    from moe_compress.utils.cached_calibration_signals import (
+        CovariancePayload, save_covariance, SCHEMA_VERSIONS,
+    )
+
+    if not _COV_ACCUM:
+        log.warning(
+            "calibration_input_cov: no entries accumulated; skipping dump."
+        )
+        return
+
+    payload = CovariancePayload(
+        schema_version=SCHEMA_VERSIONS["covariance"],
+        n_experts=_N_EXPERTS,
+        n_layers=_N_LAYERS,
+        sigma_in=dict(_COV_ACCUM),
+        token_counts=dict(_COV_TOKEN_COUNTS),
+    )
+    save_covariance(payload, Path(jsonl_path))
+    log.info(
+        "calibration_input_cov: wrote %d (layer, expert) entries (%d "
+        "layers × %d experts) next to %s -- each entry stores the "
+        "'gate_proj' matrix representing the SHARED gate+up input "
+        "covariance (consumers alias up_proj -> gate_proj via "
+        "_cov_lookup); down_proj uses separate accumulators that this "
+        "writer does NOT emit (covered by Stage 3's B-only / Corollary "
+        "3.3 fallback).",
+        len(_COV_ACCUM), _N_LAYERS, _N_EXPERTS, jsonl_path,
+    )
+
+
+def dump_input_cov_checkpoint(ckpt_path: str) -> None:
+    """Atomic checkpoint of raw accumulator state for resume."""
+    if not _CAPTURE_INPUT_COV:
+        return
+    payload = {
+        "schema_version": _CHECKPOINT_SCHEMA_VERSION,
+        "n_prompts_accumulated": _n_prompts_accumulated,
+        "n_layers": _N_LAYERS,
+        "n_experts": _N_EXPERTS,
+        "d_in": _D_IN,
+        "layer_id_to_rank": dict(_LAYER_ID_TO_RANK),
+        # Clone every tensor so a concurrent _on_expert_in cannot mutate
+        # our snapshot mid-save (mirror of reap_scores's pattern).
+        "cov_accum": {k: v.clone() for k, v in _COV_ACCUM.items()},
+        "token_counts": dict(_COV_TOKEN_COUNTS),
+    }
+    tmp = ckpt_path + ".tmp"
+    with open(tmp, "wb") as f:
+        torch.save(payload, f)
+        f.flush()
+        os.fsync(f.fileno())
+    os.replace(tmp, ckpt_path)
+    _dir_fd = os.open(os.path.dirname(ckpt_path) or ".", os.O_RDONLY)
+    try:
+        os.fsync(_dir_fd)
+    except OSError:
+        pass
+    finally:
+        os.close(_dir_fd)
+
+
+def load_input_cov_checkpoint(ckpt_path: str) -> int:
+    """Hydrate accumulators from a previous run's checkpoint.
+
+    Returns ``n_prompts_accumulated``; 0 if file missing. Raises
+    ``ValueError`` on schema mismatch (caller deletes + restarts).
+    """
+    global _N_LAYERS, _N_EXPERTS, _D_IN, _n_prompts_accumulated
+    if not os.path.exists(ckpt_path):
+        return 0
+    payload = torch.load(ckpt_path, map_location="cpu", weights_only=False)
+    schema = int(payload.get("schema_version", 0))
+    if schema != _CHECKPOINT_SCHEMA_VERSION:
+        raise ValueError(
+            f"calibration_input_cov: checkpoint at {ckpt_path} has "
+            f"schema_version={schema}, expected {_CHECKPOINT_SCHEMA_VERSION}. "
+            f"Delete the checkpoint to restart from scratch."
+        )
+    _n_prompts_accumulated = int(payload["n_prompts_accumulated"])
+    _N_LAYERS = int(payload["n_layers"])
+    _N_EXPERTS = int(payload["n_experts"])
+    _D_IN = payload.get("d_in")
+    if _D_IN is not None:
+        _D_IN = int(_D_IN)
+    _LAYER_ID_TO_RANK.clear()
+    _LAYER_ID_TO_RANK.update({int(k): int(v) for k, v in payload.get(
+        "layer_id_to_rank", {}).items()})
+    _COV_ACCUM.clear()
+    _COV_TOKEN_COUNTS.clear()
+    for k, t in payload.get("cov_accum", {}).items():
+        # Normalise key element types (tuple of (int, int, str)).
+        li, e, name = k
+        nk = (int(li), int(e), str(name))
+        _COV_ACCUM[nk] = t.to(torch.float32).clone()
+    for k, n in payload.get("token_counts", {}).items():
+        li, e, name = k
+        nk = (int(li), int(e), str(name))
+        _COV_TOKEN_COUNTS[nk] = int(n)
+    return _n_prompts_accumulated
