+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Smoke tests for ``vllm.calibration_hooks``.
+
+These tests exercise the Python-side hook registry, the env-var gating
+contract, and the kernel-level unweighted numerical identity. They use
+synthetic tensors and stub callbacks so they can run on CPU in under 30
+seconds (and the kernel-numerics test is skipped without CUDA).
+
+Tests covered:
+
+1. Each hook (``router``, ``expert_in``, ``expert_out_weighted``,
+   ``expert_out_unweighted``, ``block_out``, ``linear_in``) fires with
+   the spec'd kwarg shapes when its gate is on and a callback is
+   registered.
+2. Hooks are no-ops when env vars are unset, even when a callback is
+   registered (the gate is sampled at import).
+3. ``layer_idx`` values delivered across many synthesised dispatches
+   cover the expected range without duplicates within one "forward".
+4. Partial enable: only ``VLLM_CALIB_CAPTURE_ROUTER`` is set; the other
+   hooks' callbacks never fire.
+5. Unweighted numerical identity:
+   ``unweighted[t, k, :] * topk_weights[t, k] ≈
+    weighted_intermediate_cache3[t, k, :]`` within bf16 precision
+   (relative err < 1e-3). Skipped on CPU-only environments.
+6. ``register_callback`` rejects unknown hook names.
+7. Persistent-buffer reuse: two consecutive ``apply()`` calls reuse the
+   same per-layer buffer (``data_ptr`` identity). CUDA-gated.
+8. Persistent-buffer slice contract: a caller that holds a raw reference
+   (no ``.clone()``) observes the in-place overwrite from the next
+   forward through the same MoE layer.
+9. Persistent-buffer OOB guard: when ``num_tokens > _calib_buf_rows``
+   (the prefill case for max_model_len=20480 with buf_rows=512), the
+   side-store is SKIPPED and a one-time WARNING is logged. The persistent
+   buffer survives intact and a subsequent within-bounds (decode) batch
+   continues to populate it normally.
+"""
+from __future__ import annotations
+
+import importlib
+import os
+import sys
+from collections import defaultdict
+from typing import Any
+
+import pytest
+import torch
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+
+def _reload_hooks(env: dict[str, str]) -> Any:
+    """Reload ``vllm.calibration_hooks`` with a freshly set env. The module
+    samples its gate flags at import time, so per-test isolation requires
+    a fresh import.
+    """
+    # Drop any cached copy.
+    sys.modules.pop("vllm.calibration_hooks", None)
+    # Set the env keys for this test, clearing the ones we don't want.
+    for key in (
+        "VLLM_CALIB_CAPTURE_ROUTER",
+        "VLLM_CALIB_CAPTURE_EXPERT",
+        "VLLM_CALIB_CAPTURE_BLOCK",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED",
+        "VLLM_CALIB_CAPTURE_IMATRIX",
+        "VLLM_CALIB_CAPTURE_EXPERT_MID",
+    ):
+        os.environ.pop(key, None)
+    for k, v in env.items():
+        os.environ[k] = v
+    return importlib.import_module("vllm.calibration_hooks")
+
+
+def _stub_callback(records: list[dict[str, Any]]):
+    """Make a callback that appends its kwargs to a shared list."""
+
+    def cb(**kwargs):
+        records.append(kwargs)
+
+    return cb
+
+
+# Synthesised forward-pass dimensions. Match the planner spec's small
+# config: 4 experts, top-k=2, hidden=64, intermediate=128, 2 MoE layers.
+N_TOK = 8
+N_EXPERTS = 4
+TOP_K = 2
+HIDDEN = 64
+
+
+def _mk_router_payload(layer_idx: int) -> dict[str, Any]:
+    return dict(
+        layer_idx=layer_idx,
+        router_logits=torch.randn(N_TOK, N_EXPERTS),
+        topk_weights=torch.softmax(torch.randn(N_TOK, TOP_K), dim=-1),
+        topk_ids=torch.randint(0, N_EXPERTS, (N_TOK, TOP_K)),
+    )
+
+
+def _mk_expert_in_payload(layer_idx: int) -> dict[str, Any]:
+    return dict(
+        layer_idx=layer_idx,
+        hidden_states=torch.randn(N_TOK, HIDDEN),
+        topk_ids=torch.randint(0, N_EXPERTS, (N_TOK, TOP_K)),
+    )
+
+
+def _mk_expert_out_weighted_payload(layer_idx: int) -> dict[str, Any]:
+    return dict(
+        layer_idx=layer_idx,
+        fused_output=torch.randn(N_TOK, HIDDEN),
+        topk_weights=torch.softmax(torch.randn(N_TOK, TOP_K), dim=-1),
+        topk_ids=torch.randint(0, N_EXPERTS, (N_TOK, TOP_K)),
+    )
+
+
+def _mk_expert_out_unweighted_payload(layer_idx: int) -> dict[str, Any]:
+    return dict(
+        layer_idx=layer_idx,
+        unweighted=torch.randn(N_TOK, TOP_K, HIDDEN, dtype=torch.bfloat16),
+        topk_ids=torch.randint(0, N_EXPERTS, (N_TOK, TOP_K)),
+    )
+
+
+def _mk_block_out_payload(layer_idx: int) -> dict[str, Any]:
+    return dict(
+        layer_idx=layer_idx,
+        output=torch.randn(N_TOK, HIDDEN),
+    )
+
+
+# Mid-activation tensor in the kernel-driver: post-SwiGLU pre-quantize.
+INTERMEDIATE_DIM = 128
+
+
+def _mk_expert_mid_payload(layer_idx: int) -> dict[str, Any]:
+    return dict(
+        layer_idx=layer_idx,
+        intermediate=torch.randn(N_TOK, TOP_K, INTERMEDIATE_DIM),
+        topk_ids=torch.randint(0, N_EXPERTS, (N_TOK, TOP_K)),
+    )
+
+
+def _mk_lm_head_in_payload() -> dict[str, Any]:
+    return dict(
+        x=torch.randn(N_TOK, HIDDEN),
+    )
+
+
+# ---------------------------------------------------------------------------
+# Test 1 — every hook fires with spec'd shapes when enabled
+# ---------------------------------------------------------------------------
+
+
+def test_every_hook_fires_with_expected_shapes():
+    ch = _reload_hooks({
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT": "1",
+        "VLLM_CALIB_CAPTURE_BLOCK": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+        "VLLM_CALIB_CAPTURE_IMATRIX": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_MID": "1",
+    })
+
+    records: dict[str, list[dict[str, Any]]] = defaultdict(list)
+    for name in ch.VALID_HOOK_NAMES:
+        ch.register_callback(name, _stub_callback(records[name]))
+
+    ch.dispatch("router", **_mk_router_payload(0))
+    ch.dispatch("expert_in", **_mk_expert_in_payload(0))
+    ch.dispatch(
+        "expert_out_weighted", **_mk_expert_out_weighted_payload(0)
+    )
+    ch.dispatch(
+        "expert_out_unweighted", **_mk_expert_out_unweighted_payload(0)
+    )
+    ch.dispatch("expert_mid", **_mk_expert_mid_payload(0))
+    ch.dispatch("block_out", **_mk_block_out_payload(0))
+    # linear_in is dispatched from the source-patched LinearBase subclasses
+    # in vllm/model_executor/layers/linear.py; here we synthesise the
+    # payload directly to exercise the dispatch path.
+    ch.dispatch(
+        "linear_in",
+        prefix="model.layers.0.self_attn.qkv_proj",
+        x=torch.randn(N_TOK, HIDDEN),
+    )
+    # lm_head_in is dispatched from the source-patched
+    # LogitsProcessor._get_logits in
+    # vllm/model_executor/layers/logits_processor.py.
+    ch.dispatch("lm_head_in", **_mk_lm_head_in_payload())
+
+    # Every hook fired exactly once.
+    assert {k: len(v) for k, v in records.items()} == {
+        "router": 1,
+        "expert_in": 1,
+        "expert_out_weighted": 1,
+        "expert_out_unweighted": 1,
+        "expert_mid": 1,
+        "block_out": 1,
+        "linear_in": 1,
+        "lm_head_in": 1,
+    }
+
+    # Shape contracts.
+    r = records["router"][0]
+    assert r["router_logits"].shape == (N_TOK, N_EXPERTS)
+    assert r["topk_weights"].shape == (N_TOK, TOP_K)
+    assert r["topk_ids"].shape == (N_TOK, TOP_K)
+    assert r["layer_idx"] == 0
+
+    ei = records["expert_in"][0]
+    assert ei["hidden_states"].shape == (N_TOK, HIDDEN)
+    assert ei["topk_ids"].shape == (N_TOK, TOP_K)
+
+    eow = records["expert_out_weighted"][0]
+    assert eow["fused_output"].shape == (N_TOK, HIDDEN)
+    assert eow["topk_weights"].shape == (N_TOK, TOP_K)
+    assert eow["topk_ids"].shape == (N_TOK, TOP_K)
+
+    eou = records["expert_out_unweighted"][0]
+    assert eou["unweighted"].shape == (N_TOK, TOP_K, HIDDEN)
+    assert eou["unweighted"].dtype == torch.bfloat16
+    assert eou["topk_ids"].shape == (N_TOK, TOP_K)
+
+    em = records["expert_mid"][0]
+    assert em["intermediate"].shape == (N_TOK, TOP_K, INTERMEDIATE_DIM)
+    assert em["topk_ids"].shape == (N_TOK, TOP_K)
+    assert em["layer_idx"] == 0
+
+    bo = records["block_out"][0]
+    assert bo["output"].shape == (N_TOK, HIDDEN)
+
+    li = records["linear_in"][0]
+    assert li["x"].shape == (N_TOK, HIDDEN)
+    assert li["prefix"] == "model.layers.0.self_attn.qkv_proj"
+
+    lh = records["lm_head_in"][0]
+    assert lh["x"].shape == (N_TOK, HIDDEN)
+
