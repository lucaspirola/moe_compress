+# ---------------------------------------------------------------------------
+# Tests 7 & 8 — persistent-buffer contract for ``expert_out_unweighted``
+# ---------------------------------------------------------------------------
+#
+# Real ``TritonExperts`` construction pulls in a wide slice of vLLM (MoE
+# configs, quant configs, a live ``VllmConfig``, …) and a CUDA build of the
+# Triton kernel. The two tests below isolate the *contract* the persistent
+# buffer must satisfy — lazy one-time allocation + sliced dispatch — using a
+# minimal stub that mirrors the production code path in
+# ``vllm.model_executor.layers.fused_moe.experts.triton_moe.TritonExperts``.
+# Drift between the stub and the real class is caught by the existing
+# kernel-numerical-identity test (Test 5) plus the boot-time assertion in
+# ``MoERunner`` (Test 1 path).
+
+
+class _PersistentBufStub:
+    """Mirror of the persistent-buffer lifecycle in ``TritonExperts``.
+
+    The stub deliberately reuses the exact attribute names so a refactor
+    that renames them on the real class is loud, not silent.
+    """
+
+    def __init__(self, *, capture: bool, buf_rows: int = 512):
+        self._capture = capture
+        # Production name: ``_calib_buf_rows`` (renamed from
+        # ``_calib_max_capture_size`` to reflect its dual role -- both
+        # the buffer's leading-dim shape AND the num_tokens upper bound
+        # for which the side-store is performed).
+        self._calib_buf_rows = buf_rows if capture else 0
+        self._calib_unweighted_buf = None  # type: ignore[assignment]
+        # Mirror of the production module-level "warned once" latch.
+        self._oversized_warned = False
+
+    def apply(self, *, num_tokens: int, top_k_num: int, K: int,
+              device: str, fill_value: float):
+        # Lazy persistent-buffer allocation (production code lives in
+        # TritonExperts.apply).
+        if self._calib_unweighted_buf is None and self._capture:
+            # We don't gate on ``is_current_stream_capturing`` here because
+            # the production assertion is exercised by the real CUDA-graph
+            # smoke run, not by this CPU contract test.
+            self._calib_unweighted_buf = torch.empty(
+                (self._calib_buf_rows, top_k_num, K),
+                dtype=torch.bfloat16,
+                device=device,
+            )
+        if self._calib_unweighted_buf is None:
+            return None
+        # OOB guard: production SKIPS the side-store when
+        # ``num_tokens > _calib_buf_rows`` to avoid a kernel OOB write.
+        # We log once and return None, mirroring the real path.
+        if num_tokens > self._calib_buf_rows:
+            if not self._oversized_warned:
+                import logging
+                logging.warning(
+                    "calibration: expert_out_unweighted capture SKIPPED "
+                    "for this batch -- num_tokens=%d exceeds the "
+                    "persistent buffer row capacity (_calib_buf_rows=%d).",
+                    num_tokens, self._calib_buf_rows,
+                )
+                self._oversized_warned = True
+            return None
+        # Slice + populate (the real kernel writes via tl.store; here we
+        # use a deterministic fill so Test 8 can detect overwrites).
+        sl = self._calib_unweighted_buf[:num_tokens, :, :]
+        sl.fill_(fill_value)
+        return sl
+
+
+@pytest.mark.skipif(not torch.cuda.is_available(), reason="CUDA required")
+def test_unweighted_persistent_buffer_reuse_data_ptr():
+    """Two consecutive apply() calls must reuse the same persistent buffer.
+
+    Asserts the lazy-allocation-then-slice contract: the per-layer buffer
+    is built exactly once and every subsequent dispatched slice points at
+    the same base allocation (offset 0, contiguous in the leading dim).
+    """
+    # ``_reload_hooks`` resamples the module-level env-gate booleans; the
+    # ``_current_layer_idx`` sentinel (-1) is also re-initialised on re-
+    # import, but this test does not exercise the dispatch path (the stub
+    # bypasses ``_ch.dispatch`` entirely), so the sentinel state is
+    # irrelevant here.
+    _reload_hooks({"VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1"})
+    stub = _PersistentBufStub(capture=True, buf_rows=64)
+
+    sl1 = stub.apply(
+        num_tokens=8, top_k_num=TOP_K, K=HIDDEN, device="cuda",
+        fill_value=1.0,
+    )
+    assert stub._calib_unweighted_buf is not None
+    buf_ptr_after_first = stub._calib_unweighted_buf.data_ptr()
+    assert sl1 is not None
+    # The slice starts at offset 0 of the persistent buffer.
+    assert sl1.data_ptr() == buf_ptr_after_first
+
+    # Second forward through the same layer with a different num_tokens.
+    sl2 = stub.apply(
+        num_tokens=16, top_k_num=TOP_K, K=HIDDEN, device="cuda",
+        fill_value=2.0,
+    )
+    assert sl2 is not None
+    # Buffer identity preserved across the two forwards.
+    assert stub._calib_unweighted_buf.data_ptr() == buf_ptr_after_first
+    # Slice still starts at offset 0.
+    assert sl2.data_ptr() == buf_ptr_after_first
+    # Second slice exposes the new num_tokens rows.
+    assert sl2.shape == (16, TOP_K, HIDDEN)
+
+
+def test_unweighted_slice_invalidated_on_next_forward():
+    """Caller NOT cloning sees mutated data on the next forward.
+
+    The persistent-buffer contract advertises that raw references to the
+    dispatched ``unweighted`` tensor are silently invalidated by the next
+    forward through the same MoE layer. This test pins that promise.
+    """
+    _reload_hooks({"VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1"})
+    stub = _PersistentBufStub(capture=True, buf_rows=64)
+
+    sl1 = stub.apply(
+        num_tokens=8, top_k_num=TOP_K, K=HIDDEN, device="cpu",
+        fill_value=1.0,
+    )
+    assert sl1 is not None
+    # Caller stashes the *reference* (no .clone()).
+    saved_reference = sl1
+    assert torch.all(saved_reference == 1.0)
+
+    # Second forward overwrites the same buffer region.
+    sl2 = stub.apply(
+        num_tokens=8, top_k_num=TOP_K, K=HIDDEN, device="cpu",
+        fill_value=2.0,
+    )
+    assert sl2 is not None
+    # The stale reference now reflects the NEW data — buffer was overwritten
+    # in place, exactly as the contract warns.
+    assert torch.all(saved_reference == 2.0), (
+        "Persistent buffer contract violated: stale reference did not "
+        "observe the in-place overwrite from the next forward."
+    )
+    # And the two slices alias the same underlying storage.
+    assert saved_reference.data_ptr() == sl2.data_ptr()
+
+
+# ---------------------------------------------------------------------------
+# Test 9 — oversized batch SKIPS the side-store and emits one warning
+# ---------------------------------------------------------------------------
+#
+# Pins the C-1 fix: PyTorch silently clamps a slice that exceeds the
+# leading dim, but the Triton kernel writes one row per element of
+# ``offs_token`` and would walk past the buffer end, corrupting
+# neighbouring CUDA allocations. The production guard SKIPS the
+# side-store when ``num_tokens > _calib_buf_rows`` and emits a one-time
+# WARNING. Decode-batch coverage continues normally.
+
+
+def test_unweighted_skipped_when_num_tokens_exceeds_buffer(caplog):
+    """Oversized batch must SKIP the side-store and log exactly one WARNING.
+
+    Simulates the prefill-batch case (max_model_len=20480, buffer rows=10)
+    that previously corrupted memory by walking 20*stride_dm bytes past the
+    buffer end. After the guard, the stub returns None and logs once.
+    """
+    import logging
+
+    _reload_hooks({"VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1"})
+    stub = _PersistentBufStub(capture=True, buf_rows=10)
+
+    with caplog.at_level(logging.WARNING):
+        # First oversized batch -> skip + warn.
+        sl_oversized_1 = stub.apply(
+            num_tokens=20, top_k_num=TOP_K, K=HIDDEN, device="cpu",
+            fill_value=9.0,
+        )
+        # Second oversized batch -> still skipped, but no extra warning.
+        sl_oversized_2 = stub.apply(
+            num_tokens=32, top_k_num=TOP_K, K=HIDDEN, device="cpu",
+            fill_value=9.0,
+        )
+
+    # Both oversized calls bypass the side-store entirely.
+    assert sl_oversized_1 is None
+    assert sl_oversized_2 is None
+
+    # Persistent buffer was still allocated (lazy alloc on first call,
+    # before the OOB guard fires) so its memory remains intact and the
+    # buffer rows we DID allocate were untouched.
+    assert stub._calib_unweighted_buf is not None
+    assert stub._calib_unweighted_buf.shape == (10, TOP_K, HIDDEN)
+
+    # A within-bounds decode-style follow-up still works.
+    sl_ok = stub.apply(
+        num_tokens=4, top_k_num=TOP_K, K=HIDDEN, device="cpu",
+        fill_value=1.0,
+    )
+    assert sl_ok is not None
+    assert sl_ok.shape == (4, TOP_K, HIDDEN)
+    assert torch.all(sl_ok == 1.0)
+
+    # Exactly one WARNING-level record about the skip was emitted (the
+    # second oversized batch must NOT re-log; the production code uses a
+    # module-level latch).
+    skip_warnings = [
+        rec
+        for rec in caplog.records
+        if rec.levelno == logging.WARNING
+        and "SKIPPED" in rec.getMessage()
+    ]
+    assert len(skip_warnings) == 1, (
+        f"Expected exactly 1 skip-warning, got {len(skip_warnings)}: "
+        f"{[r.getMessage() for r in skip_warnings]}"
+    )
+
+
+if __name__ == "__main__":
+    sys.exit(pytest.main([__file__, "-v"]))
