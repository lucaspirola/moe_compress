+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Per-(layer, expert) expert-output reservoir capture for calibration-v2
+(Item 6 of the writers campaign).
+
+Collects unweighted expert-output vectors per (layer, expert) via
+reservoir sampling (max ``VLLM_CALIB_OUTPUT_RESERVOIR_CAP`` tokens per
+cell, default 256). The on-disk payload mirrors the live
+``ExpertOutputAccumulator`` finalized state stored as a dense
+``[n_layers, n_experts, max_tokens, hidden_dim]`` bf16 tensor. The
+Stage 1 cache reader hydrates a pre-finalized accumulator from this
+payload into ``ctx["output_acc"]`` so the downstream CKADistancePlugin
+skips the live Phase-B forward pass that would otherwise rebuild the
+reservoir.
+
+The hook used here is ``expert_out_unweighted``
+(``vllm/model_executor/layers/fused_moe/experts/triton_moe.py``), which
+dispatches ``(layer_idx, unweighted, topk_ids)`` after
+``invoke_fused_moe_triton_kernel`` returns. The chained-callback
+registry in ``vllm.calibration_hooks`` (Item 1's review-fix) lets this
+writer subscribe alongside ``vllm.calibration_per_expert_max`` and
+``vllm.calibration_reap_scores`` without collision.
+
+Env-var gating
+--------------
+``VLLM_CALIB_CAPTURE_OUTPUT_RESERVOIR=1`` activates the module. Requires:
+
+* ``VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED=1`` (Triton kernel hook fires)
+* ``VLLM_USE_FLASHINFER_MOE_FP16=0`` (forces Triton MoE backend;
+  ``expert_out_unweighted`` is NOT available on the FlashInfer
+  monolithic path)
+
+``VLLM_CALIB_OUTPUT_RESERVOIR_CAP`` (default ``256``) controls the
+per-cell capacity. The driver
+(``build_self_traces_calib_vllm.py``) sets all gates BEFORE the first
+vllm import when ``--capture-output-reservoir`` is passed.
+
+Reservoir-sampling math
+-----------------------
+Replicates :meth:`ExpertOutputAccumulator.update` semantics exactly:
+
+* Per dispatch, flatten ``unweighted`` from ``[n_tok, top_k, hidden]``
+  to ``[n_tok * top_k, hidden]`` and ``topk_ids`` to
+  ``[n_tok * top_k]``.
+* For every UNIQUE expert id appearing in the flattened ``topk_ids``,
+  gather the rows routed to that expert as one ``[n_e, hidden]`` batch.
+* Phase 1 (fill): if ``seen < max_tokens``, write
+  ``min(max_tokens - seen, n_e)`` tokens sequentially into the head of
+  the reservoir.
+* Phase 2 (sample): for each of the remaining ``n_e_tail`` tokens
+  (indexed 1..n_e_tail), draw a uniform u and accept with probability
+  ``max_tokens / (seen + n_fill + j)``; on accept, choose a uniformly
+  random reservoir slot and overwrite it. PyTorch's indexed-assign is
+  last-wins on collisions, which keeps the slot occupancy uniform.
+
+This is the SAME two-phase fill+sample logic used by the live path; a
+fill-only regime (``total_seen <= max_tokens``) produces a byte-exact
+match against the input slice. The combined-segment additivity test
+(``test_two_segment_additivity``) confirms a checkpoint+reload
+preserves the math.
+
+CUDA-graph compatibility
+------------------------
+Reservoirs live on CPU. The callback is dispatched from Python
+synchronously after the kernel returns; ``unweighted`` is cloned at
+callback entry so subsequent kernel writes into the persistent buffer
+cannot corrupt the sampled tokens.
+
+Resumability
+------------
+Mirrors ``vllm.calibration_per_expert_max``: periodic
+``dump_output_reservoir_checkpoint`` during the run,
+``load_output_reservoir_checkpoint`` on ``--resume``. The final
+``dump_output_reservoir`` writes the payload via
+``moe_compress.utils.cached_calibration_signals.save_output_reservoir``
+(Item 0).
+"""
+from __future__ import annotations
+
+import logging
+import os
+from pathlib import Path
+from typing import Any
+
+import torch
+
+import vllm.calibration_hooks as _ch
+
+log = logging.getLogger(__name__)
+
+__all__ = [
+    "setup",
+    "dump_output_reservoir",
+    "dump_output_reservoir_checkpoint",
+    "load_output_reservoir_checkpoint",
+    "get_n_prompts_accumulated",
+    "set_n_prompts_accumulated",
+]
+
+# Sampled at import time -- matches calibration_imatrix / per_expert_max pattern.
+_CAPTURE_OUTPUT_RESERVOIR: bool = (
+    os.getenv("VLLM_CALIB_CAPTURE_OUTPUT_RESERVOIR", "0") == "1"
+)
+# Reservoir capacity. Sampled at import so checkpoint roundtrips with a
+# changed CAP raise via the schema-mismatch path on the cached cap field.
+_MAX_TOKENS: int = int(
+    os.getenv("VLLM_CALIB_OUTPUT_RESERVOIR_CAP", "256")
+)
+
+# Per-(rank, expert_id) CPU reservoirs. Lazily allocated on the first
+# dispatch that observes that expert (matches the live accumulator's
+# lazy allocation; saves the trivial allocation for expert ids that
+# never appear in topk_ids for that layer).
+_RESERVOIR: dict[tuple[int, int], torch.Tensor] = {}  # (rank, e) -> [cap, hidden] fp32
+_SEEN: dict[tuple[int, int], int] = {}                # (rank, e) -> total tokens seen
+_VALID_COUNT: dict[tuple[int, int], int] = {}         # (rank, e) -> min(seen, cap)
+# Per-(rank, expert_id) CPU RNG generators for the Phase-2 reservoir-sample
+# draws. Seeded deterministically per cell at lazy allocation and
+# serialized/restored across checkpoints so a kill+resume run reproduces the
+# single-run sampling decisions byte-for-byte (CPU MT19937 is portable across
+# machines; NEVER use a CUDA generator -- cross-arch CUDA RNG is not
+# bit-identical and the checkpoint is device-agnostic).
+_GEN: dict[tuple[int, int], torch.Generator] = {}     # (rank, e) -> CPU generator
+
+_LAYER_ID_TO_RANK: dict[int, int] = {}
+_N_LAYERS: int = 0
+_N_EXPERTS: int = 0
+
+# Cumulative prompt counter mirroring imatrix / per_expert_max.
+_n_prompts_accumulated: int = 0
+_CHECKPOINT_SCHEMA_VERSION: int = 2
+
+# Base seed for the per-cell Phase-2 RNG. base-0 ``int()`` auto-detects the
+# ``0x`` prefix (a bare ``int("0x5eed")`` would raise); override via
+# ``VLLM_CALIB_OUTPUT_RESERVOIR_SEED`` to re-key the whole run's sampling
+# stream. A checkpoint written under a different base seed is rejected on
+# load (the stream would diverge); see ``load_output_reservoir_checkpoint``.
+_RESERVOIR_RNG_BASE_SEED: int = int(
+    os.getenv("VLLM_CALIB_OUTPUT_RESERVOIR_SEED", "0x5eed"), 0
+)
+
+
+def _cell_seed(rank: int, e: int) -> int:
+    """Deterministic, cell-unique 63-bit seed for the (rank, expert) RNG.
+
+    Independent of dispatch order so two distinct cells never share a stream
+    and the seed is reproducible across a kill+resume. The Phase-2 draws
+    (``rand`` then ``randint``) use this generator; their op order is
+    load-bearing for byte-identity across resume (do not reorder/fuse).
+    """
+    return (_RESERVOIR_RNG_BASE_SEED * 0x9E3779B97F4A7C15
+            + (rank << 20) + e) & 0x7FFFFFFFFFFFFFFF
+
+
+def get_n_prompts_accumulated() -> int:
+    return _n_prompts_accumulated
+
+
+def set_n_prompts_accumulated(n: int) -> None:
+    global _n_prompts_accumulated
+    if n < 0:
+        raise ValueError(f"n must be >= 0; got {n}")
+    _n_prompts_accumulated = int(n)
+
+
+def _resolve_model(llm: Any) -> Any | None:
+    """Walk well-known attribute paths to find the live nn.Module."""
+    candidates = [
+        ("llm_engine", "model_executor", "driver_worker", "model_runner",
+         "model"),
+        ("llm_engine", "model_executor", "model_runner", "model"),
+        ("model_executor", "driver_worker", "model_runner", "model"),
+        ("model_runner", "model"),
+    ]
+    for path in candidates:
+        obj: Any = llm
+        ok = True
+        for attr in path:
+            obj = getattr(obj, attr, None)
+            if obj is None:
+                ok = False
+                break
+        if ok:
+            return obj
+    return None
+
+
+def setup(llm: Any) -> None:
+    """Discover MoE layers, register callback.
+
+    Idempotent: calling twice does not double-register (the registry
+    de-duplicates by callable identity).
+    """
+    global _N_LAYERS, _N_EXPERTS
+
+    if not _CAPTURE_OUTPUT_RESERVOIR:
+        log.info("calibration_output_reservoir: env gate off; no-op setup.")
+        return
+
+    model = _resolve_model(llm)
+    if model is None:
+        log.warning(
+            "calibration_output_reservoir: could not resolve model from LLM; "
+            "callback will be registered but reservoir cells will be lazily "
+            "allocated at first expert_out_unweighted dispatch."
+        )
+
+    # Discover MoE layers by attribute presence. Use the same
+    # named_modules() + moe_layer_id ordering as the other writers so
+    # all three (REAP / per_expert_max / output_reservoir) agree on
+    # layer-rank.
+    n_layers = 0
+    n_experts_seen: int | None = None
+    if model is not None:
+        for name, module in model.named_modules():
+            moe_layer_id = getattr(module, "moe_layer_id", None)
+            num_experts = getattr(module, "num_experts", None)
+            if not (isinstance(moe_layer_id, int)
+                    and isinstance(num_experts, int) and num_experts > 0):
+                continue
+            _LAYER_ID_TO_RANK[moe_layer_id] = n_layers
+            if n_experts_seen is None:
+                n_experts_seen = num_experts
+            elif n_experts_seen != num_experts:
+                log.warning(
+                    "calibration_output_reservoir: mixed expert counts "
+                    "(%d vs first-seen %d at %s); using first.",
+                    num_experts, n_experts_seen, name,
+                )
+            n_layers += 1
+
+    _N_LAYERS = n_layers
+    _N_EXPERTS = int(n_experts_seen) if n_experts_seen is not None else 0
+
+    _ch.register_callback("expert_out_unweighted", _on_expert_out_unweighted)
+
+    log.info(
+        "calibration_output_reservoir: setup complete -- %d MoE layers, "
+        "%d experts/layer, cap=%d; callback registered for "
+        "expert_out_unweighted.",
+        _N_LAYERS, _N_EXPERTS, _MAX_TOKENS,
+    )
+
+
+def _on_expert_out_unweighted(layer_idx: int, unweighted: torch.Tensor,
+                              topk_ids: torch.Tensor, **_: Any) -> None:
+    """Two-phase reservoir-sample per-(layer, expert) into the reservoir.
+
+    ``unweighted`` is ``[n_tok, top_k, hidden]`` bf16 (a slice of the
+    persistent buffer in the Triton kernel); cloned at entry so post-
+    callback mutation of the underlying buffer cannot corrupt the
+    reservoir samples.
+    """
+    if not _CAPTURE_OUTPUT_RESERVOIR:
+        return
+
+    rank = _LAYER_ID_TO_RANK.get(layer_idx)
+    if rank is None:
+        raise RuntimeError(
+            f"calibration_output_reservoir: layer_idx={layer_idx} was not "
+            f"discovered by setup() — the MoE layer must be visible via "
+            f"named_modules() with the moe_layer_id attribute set. "
+            f"Late-discovered layers would force the rank table to grow, "
+            f"breaking the cross-writer rank consistency invariant. Fix "
+            f"the setup() pass to find ALL MoE layers (or this layer's "
+            f"FusedMoE module is missing the moe_layer_id attribute)."
+        )
+
+    if unweighted is None or unweighted.numel() == 0:
+        return
+
+    # Clone immediately + move to CPU + float32 for the math. The clone
+    # is critical: ``unweighted`` is a slice of a persistent Triton
+    # buffer; the next forward overwrites it in place.
+    uw = unweighted.detach().clone().cpu().to(torch.float32)   # [n_tok, top_k, hidden]
+    hidden_dim = uw.shape[-1]
+    flat_uw = uw.reshape(-1, hidden_dim)                       # [n_tok * top_k, hidden]
+    flat_ids = topk_ids.detach().cpu().to(torch.int64).reshape(-1)
+
+    # Group by expert id (only iterate experts that actually appear in
+    # this dispatch — saves work on the typical sparse routing pattern
+    # where < n_experts unique ids show up per micro-batch).
+    unique_ids = torch.unique(flat_ids).tolist()
+    for e_int in unique_ids:
+        e = int(e_int)
+        mask = flat_ids == e
+        rows = flat_uw[mask]                                   # [n_e, hidden]
+        n_e = int(rows.shape[0])
+        if n_e == 0:
+            continue
+        key = (rank, e)
+        reservoir = _RESERVOIR.get(key)
+        if reservoir is None:
+            reservoir = torch.zeros(
+                _MAX_TOKENS, hidden_dim, dtype=torch.float32,
+            )
+            _RESERVOIR[key] = reservoir
+        gen = _GEN.get(key)
+        if gen is None:
+            gen = torch.Generator(device="cpu")
+            gen.manual_seed(_cell_seed(rank, e))
+            _GEN[key] = gen
+
+
+        seen = _SEEN.get(key, 0)
+        cap = _MAX_TOKENS
+        n_filled = min(seen, cap)
+
+        # Phase 1: fill empty slots with the head of rows. Always-accept
+        # regime — equivalent to ``seen + i <= cap``.
+        n_to_fill = min(cap - n_filled, n_e)
+        if n_to_fill > 0:
+            reservoir[n_filled:n_filled + n_to_fill] = rows[:n_to_fill]
+
+        # Phase 2: reservoir sampling for tokens beyond capacity.
+        n_remaining = n_e - n_to_fill
+        if n_remaining > 0:
+            # Token at remaining-index j (1-indexed within the tail) is at
+            # global position (seen + n_to_fill + j). Acceptance
+            # probability cap / position. Matches
+            # ExpertOutputAccumulator.update() in activation_hooks.py.
+            positions = (
+                seen + n_to_fill
+                + torch.arange(1, n_remaining + 1, dtype=torch.float32)
+            )
+            probs = float(cap) / positions                       # [n_remaining]
+            u = torch.rand(n_remaining, generator=gen)
+            accept_mask = u < probs                              # [n_remaining]
+            slots = torch.randint(0, cap, (n_remaining,), generator=gen)
+            accepted = accept_mask.nonzero(as_tuple=True)[0]
+            if accepted.numel() > 0:
+                src_rows = rows[n_to_fill + accepted]
+                dst_slots = slots[accepted]
+                # Last-wins on collision; uniform reservoir-sample preserved.
+                reservoir[dst_slots] = src_rows
+
+        new_seen = seen + n_e
+        _SEEN[key] = new_seen
+        _VALID_COUNT[key] = min(new_seen, cap)
+
+
+def dump_output_reservoir(jsonl_path: str | Path) -> None:
+    """Write the final output-reservoir sidecar via the Item-0 helper.
+
+    Stacks all per-(rank, e) reservoirs into a dense
+    ``[n_layers, n_experts, max_tokens, hidden]`` bf16 tensor (unfilled
+    cells are zero-padded), plus per-(rank, e) ``valid_count`` and
+    ``total_seen`` int64 tensors.
+    """
+    if not _CAPTURE_OUTPUT_RESERVOIR:
+        return
+
+    # Lazy import so the moe_compress dependency is not imposed at module
+    # import time (the dump path is only ever called by the driver).
+    from moe_compress.utils.cached_calibration_signals import (
+        OutputReservoirPayload, save_output_reservoir, SCHEMA_VERSIONS,
+    )
+
+    if _N_LAYERS == 0 or _N_EXPERTS == 0:
+        log.warning(
+            "calibration_output_reservoir: no MoE layers seen; skipping dump."
+        )
+        return
+
+    # Discover hidden_dim from the first allocated reservoir. If NO
+    # reservoirs were ever populated we cannot determine hidden_dim and
+    # the sidecar cannot be written.
+    hidden_dim: int | None = None
+    for t in _RESERVOIR.values():
+        hidden_dim = int(t.shape[-1])
+        break
+    if hidden_dim is None:
+        log.warning(
+            "calibration_output_reservoir: zero reservoirs populated "
+            "(no expert_out_unweighted dispatches fired); skipping dump."
+        )
+        return
+
+    # Dense [n_layers, n_experts, max_tokens, hidden] payload. Zero-pad
+    # cells with no traffic (they will be excluded by the cache reader's
+    # valid_count > 0 filter).
+    reservoir_dense = torch.zeros(
+        _N_LAYERS, _N_EXPERTS, _MAX_TOKENS, hidden_dim, dtype=torch.float32,
+    )
+    valid_count = torch.zeros(_N_LAYERS, _N_EXPERTS, dtype=torch.int64)
+    total_seen = torch.zeros(_N_LAYERS, _N_EXPERTS, dtype=torch.int64)
+
+    for (rank, e), t in _RESERVOIR.items():
+        if 0 <= rank < _N_LAYERS and 0 <= e < _N_EXPERTS:
+            reservoir_dense[rank, e] = t
+        valid_count[rank, e] = int(_VALID_COUNT.get((rank, e), 0))
+        total_seen[rank, e] = int(_SEEN.get((rank, e), 0))
+
+    payload = OutputReservoirPayload(
+        schema_version=SCHEMA_VERSIONS["output_reservoir"],
+        n_experts=_N_EXPERTS,
+        n_layers=_N_LAYERS,
+        reservoir=reservoir_dense,
+        valid_count=valid_count,
+        total_seen=total_seen,
+        max_tokens=_MAX_TOKENS,
+    )
+    save_output_reservoir(payload, Path(jsonl_path))
+    log.info(
+        "calibration_output_reservoir: wrote %d-layer × %d-expert × %d-tok × "
+        "%d-hidden sidecar next to %s",
+        _N_LAYERS, _N_EXPERTS, _MAX_TOKENS, hidden_dim, jsonl_path,
+    )
+
+
+def dump_output_reservoir_checkpoint(ckpt_path: str) -> None:
+    """Atomic checkpoint of raw reservoir state for resume.
+
+    ``hidden_dim`` is implicitly stored as part of each per-(rank, e)
+    tensor's shape; on load we reconstruct that shape verbatim.
+    """
+    if not _CAPTURE_OUTPUT_RESERVOIR:
+        return
+    payload = {
+        "schema_version": _CHECKPOINT_SCHEMA_VERSION,
+        "n_prompts_accumulated": _n_prompts_accumulated,
+        "n_layers": _N_LAYERS,
+        "n_experts": _N_EXPERTS,
+        "max_tokens": _MAX_TOKENS,
+        "layer_id_to_rank": dict(_LAYER_ID_TO_RANK),
+        "reservoir": {k: v.clone() for k, v in _RESERVOIR.items()},
+        "seen": dict(_SEEN),
+        "valid_count": dict(_VALID_COUNT),
+        "generator_state": {k: g.get_state().clone() for k, g in _GEN.items()},
+        "rng_base_seed": _RESERVOIR_RNG_BASE_SEED,
+    }
+    tmp = ckpt_path + ".tmp"
+    with open(tmp, "wb") as f:
+        torch.save(payload, f)
+        f.flush()
+        os.fsync(f.fileno())
+    os.replace(tmp, ckpt_path)
+    _dir_fd = os.open(os.path.dirname(ckpt_path) or ".", os.O_RDONLY)
+    try:
+        os.fsync(_dir_fd)
+    except OSError:
+        pass
+    finally:
+        os.close(_dir_fd)
+
+
+def load_output_reservoir_checkpoint(ckpt_path: str) -> int:
+    """Hydrate reservoir state from a previous run's checkpoint. Returns
+    n_prompts_accumulated; 0 if file missing."""
+    global _N_LAYERS, _N_EXPERTS, _n_prompts_accumulated
+    if not os.path.exists(ckpt_path):
+        return 0
+    payload = torch.load(ckpt_path, map_location="cpu", weights_only=False)
+    schema = int(payload.get("schema_version", 0))
+    if schema != _CHECKPOINT_SCHEMA_VERSION:
+        raise ValueError(
+            f"calibration_output_reservoir: checkpoint at {ckpt_path} has "
+            f"schema_version={schema}, expected {_CHECKPOINT_SCHEMA_VERSION}. "
+            f"Delete the checkpoint to restart from scratch."
+        )
+    ckpt_cap = int(payload.get("max_tokens", _MAX_TOKENS))
+    if ckpt_cap != _MAX_TOKENS:
+        raise ValueError(
+            f"calibration_output_reservoir: checkpoint at {ckpt_path} was "
+            f"written with max_tokens={ckpt_cap} but the current run is "
+            f"configured for max_tokens={_MAX_TOKENS}. The two-phase "
+            f"reservoir-sample math depends on a consistent cap across the "
+            f"full run -- delete the checkpoint or restore the matching "
+            f"VLLM_CALIB_OUTPUT_RESERVOIR_CAP."
+        )
+    _n_prompts_accumulated = int(payload["n_prompts_accumulated"])
+    _N_LAYERS = int(payload["n_layers"])
+    _N_EXPERTS = int(payload["n_experts"])
+    _LAYER_ID_TO_RANK.clear()
+    _LAYER_ID_TO_RANK.update({int(k): int(v) for k, v in payload.get(
+        "layer_id_to_rank", {}).items()})
+    _RESERVOIR.clear()
+    _SEEN.clear()
+    _VALID_COUNT.clear()
+    for k, t in payload.get("reservoir", {}).items():
+        rk = (int(k[0]), int(k[1]))
+        _RESERVOIR[rk] = t.to(torch.float32).clone()
+    for k, v in payload.get("seen", {}).items():
+        _SEEN[(int(k[0]), int(k[1]))] = int(v)
+    for k, v in payload.get("valid_count", {}).items():
+        _VALID_COUNT[(int(k[0]), int(k[1]))] = int(v)
+    _GEN.clear()
+    saved_base = int(payload.get("rng_base_seed", _RESERVOIR_RNG_BASE_SEED))
+    if saved_base != _RESERVOIR_RNG_BASE_SEED:
+        raise ValueError(
+            f"calibration_output_reservoir: checkpoint at {ckpt_path} has "
+            f"rng_base_seed={saved_base} but the current run is configured "
+            f"for {_RESERVOIR_RNG_BASE_SEED}. The Phase-2 reservoir-sample "
+            f"stream would diverge from the single-run counterfactual. "
+            f"Delete the checkpoint or restore the matching "
+            f"VLLM_CALIB_OUTPUT_RESERVOIR_SEED."
+        )
+    for k, state in payload.get("generator_state", {}).items():
+        rk = (int(k[0]), int(k[1]))
+        g = torch.Generator(device="cpu")
+        g.set_state(state.to(torch.uint8))
+        _GEN[rk] = g
+    return _n_prompts_accumulated
