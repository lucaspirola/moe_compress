diff --git a/vllm/calibration_wanda_scalar_row.py b/vllm/calibration_wanda_scalar_row.py
new file mode 100644
index 0000000..0000001
--- /dev/null
+++ b/vllm/calibration_wanda_scalar_row.py
@@ -0,0 +1,474 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Per-(layer, expert, matrix) Wanda ``scalar_row`` calibration capture.
+
+W-1 (audit `tasks/AUDIT_CALIBRATION_COMPLETENESS_V2.md` §W-1).
+Plan: `tasks/PLAN_W1_WANDA_SCALAR_ROW_CAPTURE.md`.
+
+Computes per-(layer_idx, expert_idx, matrix_name) running mean of
+``(x_t · g_{e,t})^2`` per input channel ``c`` during a calibration
+forward pass, via two source-patched hooks (router-stash + expert-in
+reader, mirroring `vllm.calibration_reap_scores` at
+``max_quality/patches/vllm_calibration_hooks.patch:8134-8473``):
+
+* ``router`` (vllm/model_executor/layers/fused_moe/moe_runner.py)
+  dispatches ``(layer_idx, router_logits, topk_weights, topk_ids)`` per
+  MoE layer forward. This module stashes ``topk_weights`` keyed by
+  ``layer_idx`` for the immediately-following ``expert_in`` callback to
+  match.
+
+* ``expert_in`` (vllm/model_executor/layers/fused_moe/moe_runner.py)
+  dispatches ``(layer_idx, hidden_states, topk_ids)`` per MoE layer
+  forward, BEFORE the per-expert dispatch_combine. ``hidden_states`` is
+  the pre-routing hidden state (gate_proj / up_proj input). We
+  scatter-accumulate per-(layer, expert, "gate_proj") sum-of-squares of
+  ``(x_t · g_{e,t})`` per input channel into CPU fp32 buffers, plus
+  ``token_counts``.
+
+``down_proj`` input is the post-act intermediate — NOT visible at
+``expert_in`` (which fires on the pre-routing hidden state). The
+``down_proj`` scalar_row is therefore NOT captured by this writer; the
+plugin's cache-MISS fallback path (the existing in-process calibration
+sweep at ``stage3/plugins/wanda_intra_expert_score.py:498-528``)
+captures both ``gate_proj`` and ``down_proj``. The down_proj entry is
+simply absent from the sidecar payload, and the consumer's
+``_compute_scores`` already skips matrices without a scalar_row.
+
+Stash lifecycle — overwrite-on-router-fire, NO explicit clear
+-------------------------------------------------------------
+The per-layer ``_ROUTER_WEIGHTS_STASH`` is overwritten on each
+``_on_router(layer_idx=…)`` call; it is NOT cleared by the
+``_on_expert_in`` reader. The stale entry sits inert until the next
+``_on_router`` for the same layer overwrites it. The steady-state
+per-layer dispatch order (router(N) → expert_in(N) → router(N+1) → …)
+makes this safe.
+
+Mirrors ``vllm.calibration_reap_scores._ROUTER_WEIGHTS_STASH`` at
+``vllm_calibration_hooks.patch:8219`` (the inline comment there claims
+"cleared after each use" — verified empirically as stale; this module's
+docstring states the correct contract).
+
+Env-var gating
+--------------
+``VLLM_CALIB_CAPTURE_WANDA_SCALAR_ROW=1`` activates the module. Requires:
+
+* ``VLLM_CALIB_CAPTURE_ROUTER=1`` (router hook fires from MoE forward)
+* ``VLLM_CALIB_CAPTURE_EXPERT=1`` (expert_in hook fires)
+
+The driver (``build_self_traces_calib_vllm.py``) sets all three env
+vars BEFORE the first vllm import when ``--capture-wanda-scalar-row``
+is passed.
+
+CUDA-graph compatibility
+------------------------
+Accumulators live on CPU (fp32). The callbacks dispatch from Python
+synchronously after the kernel returns; ``hidden_states`` / ``topk_*``
+are cloned (via ``.detach().cpu()``) at callback entry. Safe for
+CUDA-graph capture.
+
+Resumability
+------------
+Mirrors ``vllm.calibration_reap_scores`` / ``vllm.calibration_input_cov``:
+periodic ``dump_wanda_scalar_row_checkpoint`` during the run,
+``load_wanda_scalar_row_checkpoint`` on ``--resume``. The final
+``dump_wanda_scalar_row`` writes the normalised payload via
+``moe_compress.utils.cached_calibration_signals.save_wanda_scalar_row``
+(Pattern O — atomic write + manifest-last).
+
+Storage shape
+-------------
+For Qwen3.6-35B-A3B at hidden=2048, n_layers≈40, n_experts=256, the
+on-disk size is ~80 MB (gate_proj scalar_row, fp32). down_proj scalar_row
+is not captured here — see "down_proj input is the post-act
+intermediate" note above.
+"""
+from __future__ import annotations
+
+import logging
+import os
+from pathlib import Path
+from typing import Any
+
+import torch
+
+import vllm.calibration_hooks as _ch
+
+log = logging.getLogger(__name__)
+
+__all__ = [
+    "setup",
+    "dump_wanda_scalar_row",
+    "dump_wanda_scalar_row_checkpoint",
+    "load_wanda_scalar_row_checkpoint",
+    "get_n_prompts_accumulated",
+    "set_n_prompts_accumulated",
+]
+
+# Sampled at import time -- matches calibration_reap_scores / input_cov.
+_CAPTURE_WANDA_SCALAR_ROW: bool = (
+    os.getenv("VLLM_CALIB_CAPTURE_WANDA_SCALAR_ROW", "0") == "1"
+)
+
+# Per-(layer_idx, expert_idx, matrix_name) CPU sum-of-squares accumulators.
+# Stored as raw running SUMS (NOT means) so checkpoint resumability is
+# additive — the final ``dump_wanda_scalar_row`` divides by the matching
+# ``_WANDA_TOKEN_COUNTS`` entry to produce the per-channel mean. The
+# in-process plugin accumulator's running-mean form is reconstructed
+# from this sum + count pair at consume time (see
+# ``_WandaScalarRowAccumulator.from_payload``).
+_WANDA_SCALAR_ROW_SUM: dict[tuple[int, int, str], torch.Tensor] = {}
+_WANDA_TOKEN_COUNTS: dict[tuple[int, int, str], int] = {}
+
+# Per-layer router-weight stash. Overwrite-on-router-fire, NOT cleared
+# by the expert_in reader — the per-layer dispatch order guarantees the
+# router fires before the expert_in for every layer in every forward.
+# See module docstring for the correct lifecycle (the comment at
+# vllm_calibration_hooks.patch:8218 for REAP is stale).
+_ROUTER_WEIGHTS_STASH: dict[int, torch.Tensor] = {}
+
+# Per-layer top-k width (sampled from the first router fire; consumed by
+# expert_in to size the per-token routing-weight gather).
+_TOP_K: int | None = None
+
+_LAYER_ID_TO_RANK: dict[int, int] = {}
+_N_LAYERS: int = 0
+_N_EXPERTS: int = 0
+# d_in is sampled lazily on the first expert_in dispatch so checkpoint
+# metadata reflects reality even when setup() couldn't pre-walk the model.
+_D_IN: int | None = None
+
+# Cumulative prompt counter mirroring reap_scores / input_cov / imatrix.
+_n_prompts_accumulated: int = 0
+_CHECKPOINT_SCHEMA_VERSION: int = 1
+
+
+def get_n_prompts_accumulated() -> int:
+    return _n_prompts_accumulated
+
+
+def set_n_prompts_accumulated(n: int) -> None:
+    global _n_prompts_accumulated
+    if n < 0:
+        raise ValueError(f"n must be >= 0; got {n}")
+    _n_prompts_accumulated = int(n)
+
+
+def _resolve_model(llm: Any) -> Any | None:
+    """Walk well-known attribute paths to find the live nn.Module."""
+    candidates = [
+        ("llm_engine", "model_executor", "driver_worker", "model_runner",
+         "model"),
+        ("llm_engine", "model_executor", "model_runner", "model"),
+        ("model_executor", "driver_worker", "model_runner", "model"),
+        ("model_runner", "model"),
+    ]
+    for path in candidates:
+        obj: Any = llm
+        ok = True
+        for attr in path:
+            obj = getattr(obj, attr, None)
+            if obj is None:
+                ok = False
+                break
+        if ok:
+            return obj
+    return None
+
+
+def setup(llm: Any) -> None:
+    """Discover MoE layers, build the layer_id_to_rank map, register
+    the ``router`` + ``expert_in`` callbacks. Idempotent: calling twice
+    does not double-register.
+    """
+    global _N_LAYERS, _N_EXPERTS
+
+    if not _CAPTURE_WANDA_SCALAR_ROW:
+        log.info("calibration_wanda_scalar_row: env gate off; no-op setup.")
+        return
+
+    model = _resolve_model(llm)
+    if model is None:
+        log.warning(
+            "calibration_wanda_scalar_row: could not resolve model from "
+            "LLM; callbacks will be registered but the layer_id_to_rank "
+            "map will be populated lazily from the first router dispatch."
+        )
+
+    # Discover MoE layers by attribute presence (mirrors reap_scores +
+    # input_cov).
+    n_layers = 0
+    n_experts_seen: int | None = None
+    if model is not None:
+        for name, module in model.named_modules():
+            moe_layer_id = getattr(module, "moe_layer_id", None)
+            num_experts = getattr(module, "num_experts", None)
+            if not (isinstance(moe_layer_id, int)
+                    and isinstance(num_experts, int) and num_experts > 0):
+                continue
+            _LAYER_ID_TO_RANK[moe_layer_id] = n_layers
+            if n_experts_seen is None:
+                n_experts_seen = num_experts
+            elif n_experts_seen != num_experts:
+                log.warning(
+                    "calibration_wanda_scalar_row: mixed expert counts "
+                    "(%d vs first-seen %d at %s); using first.",
+                    num_experts, n_experts_seen, name,
+                )
+            n_layers += 1
+
+    _N_LAYERS = n_layers
+    _N_EXPERTS = int(n_experts_seen) if n_experts_seen is not None else 0
+
+    _ch.register_callback("router", _on_router)
+    _ch.register_callback("expert_in", _on_expert_in)
+
+    log.info(
+        "calibration_wanda_scalar_row: setup complete -- %d MoE layers, "
+        "%d experts/layer; callbacks registered for router + expert_in.",
+        _N_LAYERS, _N_EXPERTS,
+    )
+
+
+def _on_router(layer_idx: int, router_logits: torch.Tensor,
+               topk_weights: torch.Tensor, topk_ids: torch.Tensor,
+               **_: Any) -> None:
+    """Stash per-layer topk_weights for the matching expert_in callback.
+
+    Lifecycle: overwrite-on-fire, NO explicit clear (see module
+    docstring + ``_ROUTER_WEIGHTS_STASH`` declaration comment).
+    """
+    if not _CAPTURE_WANDA_SCALAR_ROW:
+        return
+    global _TOP_K
+    tw = topk_weights.detach().cpu().to(torch.float32)
+    _ROUTER_WEIGHTS_STASH[layer_idx] = tw
+    if _TOP_K is None and tw.dim() >= 2:
+        _TOP_K = int(tw.shape[1])
+
+
+def _on_expert_in(layer_idx: int, hidden_states: torch.Tensor,
+                  topk_ids: torch.Tensor, **_: Any) -> None:
+    """Accumulate per-(layer, expert, "gate_proj") sum of
+    ``(x_t · g_{e,t})^2`` per input channel.
+
+    For each expert ``e`` and each token ``t`` routed to ``e``, the
+    contribution is ``(x_t * g_{e,t}) ** 2`` per channel, where
+    ``g_{e,t}`` is the topk_weight assigned to the slot at which expert
+    ``e`` was selected for token ``t``.
+
+    Reads topk_weights from ``_ROUTER_WEIGHTS_STASH[layer_idx]`` (stashed
+    by the matching ``_on_router`` call earlier in the same forward).
+    On router-stash miss (out-of-order dispatch — does NOT occur in
+    production), emits one-shot ERROR log + skips the layer (does NOT
+    silently zero the row).
+    """
+    if not _CAPTURE_WANDA_SCALAR_ROW:
+        return
+
+    tw = _ROUTER_WEIGHTS_STASH.get(layer_idx)
+    if tw is None:
+        log.error(
+            "calibration_wanda_scalar_row: expert_in at layer %d "
+            "without a preceding router dispatch (stash miss); "
+            "skipping. Did you forget VLLM_CALIB_CAPTURE_ROUTER=1?",
+            layer_idx,
+        )
+        return
+
+    if layer_idx not in _LAYER_ID_TO_RANK:
+        rank = len(_LAYER_ID_TO_RANK)
+        _LAYER_ID_TO_RANK[layer_idx] = rank
+
+    global _D_IN, _N_LAYERS, _N_EXPERTS
+    hs = hidden_states.detach().to("cpu", dtype=torch.float32, copy=True)
+    if hs.numel() == 0:
+        return
+    if hs.dim() == 3:
+        # [batch, seq, hidden] -> [n_tok, hidden]
+        hs = hs.reshape(-1, hs.shape[-1])
+    if _D_IN is None:
+        _D_IN = int(hs.shape[-1])
+
+    ids = topk_ids.detach().to("cpu", dtype=torch.int64)
+    n_tok = hs.shape[0]
+    if ids.dim() == 1:
+        ids = ids.unsqueeze(-1)
+    if ids.shape[0] != n_tok:
+        log.warning(
+            "calibration_wanda_scalar_row: layer %d -- topk_ids first "
+            "dim %d does not match hidden_states n_tok %d; skipping.",
+            layer_idx, ids.shape[0], n_tok,
+        )
+        return
+
+    # Trim/align topk_weights to the (n_tok, top_k) shape of ids.
+    tw_aligned = tw[:n_tok, :ids.shape[1]]
+    if tw_aligned.shape != ids.shape:
+        log.warning(
+            "calibration_wanda_scalar_row: layer %d -- topk_weights "
+            "shape %s does not align with topk_ids shape %s; skipping.",
+            layer_idx, tuple(tw.shape), tuple(ids.shape),
+        )
+        return
+
+    # Update seen-expert ceiling for checkpoint metadata.
+    seen_max = int(ids.max().item()) + 1 if ids.numel() > 0 else 0
+    if seen_max > _N_EXPERTS:
+        _N_EXPERTS = seen_max
+
+    # Per-expert accumulation. A token may appear in top_k slots so its
+    # contribution is added per slot — matching the live plugin
+    # accumulator's semantics (each (token, slot) routed to expert e
+    # contributes the (x_t * g_{e,t,slot}) ** 2 per-channel
+    # sum-of-squares).
+    for e in range(seen_max):
+        mask_2d = (ids == e)  # [n_tok, top_k]
+        if not mask_2d.any():
+            continue
+        # For each (token, slot) where ids == e, gather the per-token
+        # row and the matching scalar g. The same token may appear
+        # multiple times if both slots selected expert e — the per-slot
+        # contribution is added separately (mirrors the in-process
+        # accumulator's semantics where instrument_experts dispatches
+        # per (token, slot) routed to e).
+        token_idx, slot_idx = mask_2d.nonzero(as_tuple=True)
+        if token_idx.numel() == 0:
+            continue
+        sub_x = hs.index_select(0, token_idx)             # [n_e, d_in]
+        sub_g = tw_aligned[token_idx, slot_idx]            # [n_e]
+        weighted = sub_x * sub_g.reshape(-1, 1)            # [n_e, d_in]
+        sq_per_channel = weighted.pow(2).sum(dim=0)        # [d_in]
+
+        key = (layer_idx, int(e), "gate_proj")
+        cur = _WANDA_SCALAR_ROW_SUM.get(key)
+        if cur is None:
+            _WANDA_SCALAR_ROW_SUM[key] = sq_per_channel
+        else:
+            cur.add_(sq_per_channel)
+        _WANDA_TOKEN_COUNTS[key] = (
+            _WANDA_TOKEN_COUNTS.get(key, 0) + int(token_idx.numel())
+        )
+
+    # _N_LAYERS may grow lazily if setup() couldn't pre-discover layers.
+    if len(_LAYER_ID_TO_RANK) > _N_LAYERS:
+        _N_LAYERS = len(_LAYER_ID_TO_RANK)
+
+
+def dump_wanda_scalar_row(jsonl_path: str | Path) -> None:
+    """Write the final per-(layer, expert, "gate_proj") scalar_row sidecar.
+
+    Divides the raw sum-of-squares accumulators by the matching
+    ``token_counts`` to produce the per-channel running mean
+    (``E_t[(x_t * g_{e,t})^2]``), then delegates to
+    ``moe_compress.utils.cached_calibration_signals.save_wanda_scalar_row``
+    which writes the payload + manifest atomically (Pattern O).
+    """
+    if not _CAPTURE_WANDA_SCALAR_ROW:
+        return
+
+    # Import here (not at module top) so the dependency is lazy.
+    from moe_compress.utils.cached_calibration_signals import (
+        SCHEMA_VERSIONS, WandaScalarRowPayload, save_wanda_scalar_row,
+    )
+
+    if not _WANDA_SCALAR_ROW_SUM:
+        log.warning(
+            "calibration_wanda_scalar_row: no entries accumulated; "
+            "skipping dump."
+        )
+        return
+
+    sigma_x_g_squared: dict = {}
+    token_counts: dict = {}
+    for key, sumsq in _WANDA_SCALAR_ROW_SUM.items():
+        count = _WANDA_TOKEN_COUNTS.get(key, 0)
+        safe = max(1, count)
+        sigma_x_g_squared[key] = sumsq / float(safe)
+        token_counts[key] = int(count)
+
+    payload = WandaScalarRowPayload(
+        schema_version=SCHEMA_VERSIONS["wanda_scalar_row"],
+        n_experts=_N_EXPERTS,
+        n_layers=_N_LAYERS,
+        sigma_x_g_squared=sigma_x_g_squared,
+        token_counts=token_counts,
+    )
+    save_wanda_scalar_row(payload, Path(jsonl_path))
+    log.info(
+        "calibration_wanda_scalar_row: wrote %d (layer, expert, matrix) "
+        "entries (%d layers x %d experts) next to %s",
+        len(sigma_x_g_squared), _N_LAYERS, _N_EXPERTS, jsonl_path,
+    )
+
+
+def dump_wanda_scalar_row_checkpoint(ckpt_path: str) -> None:
+    """Atomic checkpoint of raw accumulator state for resume.
+
+    Stores the RAW sum-of-squares (NOT the normalised mean) so a
+    kill-mid-calibration + resume can additively combine the new chunks
+    with the saved sums. See T6 in
+    ``tasks/PLAN_W1_WANDA_SCALAR_ROW_CAPTURE.md`` §9.
+    """
+    if not _CAPTURE_WANDA_SCALAR_ROW:
+        return
+    payload = {
+        "schema_version": _CHECKPOINT_SCHEMA_VERSION,
+        "n_prompts_accumulated": _n_prompts_accumulated,
+        "n_layers": _N_LAYERS,
+        "n_experts": _N_EXPERTS,
+        "d_in": _D_IN,
+        "top_k": _TOP_K,
+        "layer_id_to_rank": dict(_LAYER_ID_TO_RANK),
+        # Clone every tensor so a concurrent _on_expert_in cannot mutate
+        # our snapshot mid-save (mirror of reap_scores's pattern).
+        "scalar_row_sum": {
+            k: v.clone() for k, v in _WANDA_SCALAR_ROW_SUM.items()
+        },
+        "token_counts": dict(_WANDA_TOKEN_COUNTS),
+    }
+    tmp = ckpt_path + ".tmp"
+    torch.save(payload, tmp)
+    os.replace(tmp, ckpt_path)
+
+
+def load_wanda_scalar_row_checkpoint(ckpt_path: str) -> int:
+    """Hydrate accumulators from a previous run's checkpoint.
+
+    Returns ``n_prompts_accumulated``; 0 if file missing. Raises
+    ``ValueError`` on schema mismatch (caller deletes + restarts).
+    """
+    global _N_LAYERS, _N_EXPERTS, _D_IN, _TOP_K, _n_prompts_accumulated
+    if not os.path.exists(ckpt_path):
+        return 0
+    payload = torch.load(ckpt_path, map_location="cpu", weights_only=False)
+    schema = int(payload.get("schema_version", 0))
+    if schema != _CHECKPOINT_SCHEMA_VERSION:
+        raise ValueError(
+            f"calibration_wanda_scalar_row: checkpoint at {ckpt_path} "
+            f"has schema_version={schema}, expected "
+            f"{_CHECKPOINT_SCHEMA_VERSION}. "
+            f"Delete the checkpoint to restart from scratch."
+        )
+    _n_prompts_accumulated = int(payload["n_prompts_accumulated"])
+    _N_LAYERS = int(payload["n_layers"])
+    _N_EXPERTS = int(payload["n_experts"])
+    _D_IN = payload.get("d_in")
+    if _D_IN is not None:
+        _D_IN = int(_D_IN)
+    _TOP_K = payload.get("top_k")
+    if _TOP_K is not None:
+        _TOP_K = int(_TOP_K)
+    _LAYER_ID_TO_RANK.clear()
+    _LAYER_ID_TO_RANK.update({int(k): int(v) for k, v in payload.get(
+        "layer_id_to_rank", {}).items()})
+    _WANDA_SCALAR_ROW_SUM.clear()
+    _WANDA_TOKEN_COUNTS.clear()
+    for k, t in payload.get("scalar_row_sum", {}).items():
+        li, e, name = k
+        nk = (int(li), int(e), str(name))
+        _WANDA_SCALAR_ROW_SUM[nk] = t.to(torch.float32).clone()
+    for k, n in payload.get("token_counts", {}).items():
+        li, e, name = k
+        nk = (int(li), int(e), str(name))
+        _WANDA_TOKEN_COUNTS[nk] = int(n)
+    return _n_prompts_accumulated
