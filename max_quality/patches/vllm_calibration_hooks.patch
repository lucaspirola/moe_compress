@@ -0,0 +1,400 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Smoke tests for ``vllm.calibration_reap_scores``.
+
+These exercise the per-(layer, expert) accumulator, the env-gate
+contract, checkpoint round-trip + two-segment additivity, the silent
+"router stash miss" guard, and the dump-normalization math.
+
+Tests:
+
+1. ``test_accumulator_math`` -- a synthetic router + expert_out_unweighted
+   pair populates the per-expert accumulators with the expected
+   ``g_j · ||f_j||_2`` contributions.
+2. ``test_no_accumulation_when_env_off`` -- env unset → callbacks dispatched
+   manually leave accumulators at zero (the source-patched dispatch in
+   ``calibration_hooks`` short-circuits, AND the module's own
+   ``_CAPTURE_REAP_SCORES`` guard returns early).
+3. ``test_checkpoint_roundtrip`` -- dump → reload module → load_checkpoint
+   restores byte-identical accumulator state plus the prompt counter.
+4. ``test_two_segment_additivity`` -- 10 tokens + checkpoint + reload +
+   another 10 tokens equals 20-token single run (cumulative addition).
+5. ``test_router_stash_miss_skips_silently`` -- expert_out_unweighted
+   fired without a preceding router dispatch leaves accumulators at zero
+   and logs a warning.
+6. ``test_dump_normalization`` -- single contribution to expert 0 →
+   ``reap_scores[0, 0]`` equals the raw value (count=1), other cells zero.
+"""
+from __future__ import annotations
+
+import importlib
+import os
+import sys
+from typing import Any
+
+import torch
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+
+def _reload_reap_scores(env: dict[str, str]) -> Any:
+    """Reload ``vllm.calibration_reap_scores`` (and hooks) with a fresh env.
+
+    Module-level ``_CAPTURE_REAP_SCORES`` is sampled at import; per-test
+    isolation requires a fresh import.
+    """
+    sys.modules.pop("vllm.calibration_reap_scores", None)
+    sys.modules.pop("vllm.calibration_hooks", None)
+    for key in (
+        "VLLM_CALIB_CAPTURE_REAP_SCORES",
+        "VLLM_CALIB_CAPTURE_ROUTER",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED",
+        "VLLM_CALIB_CAPTURE_IMATRIX",
+        "VLLM_CALIB_CAPTURE_EXPERT",
+        "VLLM_CALIB_CAPTURE_BLOCK",
+        "VLLM_CALIB_CAPTURE_EXPERT_MID",
+    ):
+        os.environ.pop(key, None)
+    for k, v in env.items():
+        os.environ[k] = v
+    importlib.import_module("vllm.calibration_hooks")
+    return importlib.import_module("vllm.calibration_reap_scores")
+
+
+def _seed_layer(rs: Any, layer_idx: int, rank: int, n_experts: int) -> None:
+    """Manually wire up the per-layer accumulators the way setup() would."""
+    rs._LAYER_ID_TO_RANK[layer_idx] = rank
+    if rank + 1 > rs._N_LAYERS:
+        rs._N_LAYERS = rank + 1
+    if n_experts > rs._N_EXPERTS:
+        rs._N_EXPERTS = n_experts
+    rs._REAP_SCORE_ACCUM[rank] = torch.zeros(n_experts, dtype=torch.float32)
+    rs._REAP_TOKEN_COUNTS[rank] = torch.zeros(n_experts, dtype=torch.int64)
+
+
+# ---------------------------------------------------------------------------
+# Test 1 -- accumulator math
+# ---------------------------------------------------------------------------
+
+
+def test_accumulator_math():
+    """Synthetic router + expert_out_unweighted populate accumulators with
+    the expected ``g_j · ||f_j||_2`` contributions."""
+    rs = _reload_reap_scores({
+        "VLLM_CALIB_CAPTURE_REAP_SCORES": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    n_experts = 4
+    _seed_layer(rs, layer_idx=0, rank=0, n_experts=n_experts)
+
+    # Two tokens, top-k=2. Token 0 routes to (expert 0, expert 2) with
+    # weights (0.7, 0.3); token 1 routes to (expert 1, expert 2) with
+    # weights (0.6, 0.4). Hidden dim = 3.
+    topk_weights = torch.tensor(
+        [[0.7, 0.3], [0.6, 0.4]], dtype=torch.float32,
+    )
+    topk_ids = torch.tensor([[0, 2], [1, 2]], dtype=torch.int64)
+    # Expert outputs per (token, slot): hidden vectors with known norms.
+    # Use orthonormal-ish small vectors so we can hand-compute norms.
+    unweighted = torch.tensor([
+        [[3.0, 4.0, 0.0],   # token 0 slot 0 (expert 0): norm = 5
+         [0.0, 0.0, 2.0]],  # token 0 slot 1 (expert 2): norm = 2
+        [[1.0, 0.0, 0.0],   # token 1 slot 0 (expert 1): norm = 1
+         [0.0, 3.0, 4.0]],  # token 1 slot 1 (expert 2): norm = 5
+    ], dtype=torch.float32)
+
+    rs._on_router(layer_idx=0, router_logits=torch.zeros(2, n_experts),
+                  topk_weights=topk_weights, topk_ids=topk_ids)
+    rs._on_expert_out_unweighted(layer_idx=0, unweighted=unweighted,
+                                 topk_ids=topk_ids)
+
+    # Hand-computed S_j sum (numerators, before /count normalization):
+    # expert 0: 0.7 * 5 = 3.5
+    # expert 1: 0.6 * 1 = 0.6
+    # expert 2: 0.3 * 2 + 0.4 * 5 = 0.6 + 2.0 = 2.6
+    # expert 3: 0
+    expected_scores = torch.tensor(
+        [3.5, 0.6, 2.6, 0.0], dtype=torch.float32,
+    )
+    expected_counts = torch.tensor([1, 1, 2, 0], dtype=torch.int64)
+    got_scores = rs._REAP_SCORE_ACCUM[0]
+    got_counts = rs._REAP_TOKEN_COUNTS[0]
+    assert torch.allclose(got_scores, expected_scores, atol=1e-5), (
+        f"scores: got {got_scores}, expected {expected_scores}"
+    )
+    assert torch.equal(got_counts, expected_counts), (
+        f"counts: got {got_counts}, expected {expected_counts}"
+    )
+
+
+# ---------------------------------------------------------------------------
+# Test 2 -- env-off short-circuits
+# ---------------------------------------------------------------------------
+
+
+def test_no_accumulation_when_env_off():
+    """Env unset → both the source-patched dispatch and the module's own
+    ``_CAPTURE_REAP_SCORES`` guard keep accumulators at zero."""
+    rs = _reload_reap_scores({})  # env cleared
+    assert rs._CAPTURE_REAP_SCORES is False
+
+    n_experts = 3
+    _seed_layer(rs, layer_idx=0, rank=0, n_experts=n_experts)
+
+    topk_weights = torch.tensor([[0.5, 0.5]], dtype=torch.float32)
+    topk_ids = torch.tensor([[0, 1]], dtype=torch.int64)
+    unweighted = torch.tensor([[[1.0, 0.0], [0.0, 1.0]]], dtype=torch.float32)
+
+    # Call the callbacks directly -- their internal env guard must short-
+    # circuit before touching the accumulators.
+    rs._on_router(layer_idx=0, router_logits=torch.zeros(1, n_experts),
+                  topk_weights=topk_weights, topk_ids=topk_ids)
+    rs._on_expert_out_unweighted(layer_idx=0, unweighted=unweighted,
+                                 topk_ids=topk_ids)
+
+    assert torch.equal(
+        rs._REAP_SCORE_ACCUM[0], torch.zeros(n_experts, dtype=torch.float32),
+    )
+    assert torch.equal(
+        rs._REAP_TOKEN_COUNTS[0], torch.zeros(n_experts, dtype=torch.int64),
+    )
+
+
+# ---------------------------------------------------------------------------
+# Test 3 -- checkpoint round-trip
+# ---------------------------------------------------------------------------
+
+
+def test_checkpoint_roundtrip(tmp_path):
+    """Dump → reload module → load_checkpoint restores byte-identical state."""
+    rs = _reload_reap_scores({
+        "VLLM_CALIB_CAPTURE_REAP_SCORES": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    n_experts = 3
+    _seed_layer(rs, layer_idx=0, rank=0, n_experts=n_experts)
+    _seed_layer(rs, layer_idx=1, rank=1, n_experts=n_experts)
+
+    rs._REAP_SCORE_ACCUM[0] = torch.tensor([1.5, 2.5, 0.0], dtype=torch.float32)
+    rs._REAP_TOKEN_COUNTS[0] = torch.tensor([3, 5, 0], dtype=torch.int64)
+    rs._REAP_SCORE_ACCUM[1] = torch.tensor([0.5, 0.0, 4.0], dtype=torch.float32)
+    rs._REAP_TOKEN_COUNTS[1] = torch.tensor([1, 0, 7], dtype=torch.int64)
+    rs.set_n_prompts_accumulated(42)
+
+    ckpt = str(tmp_path / "test.reap.ckpt")
+    rs.dump_reap_scores_checkpoint(ckpt)
+    assert os.path.exists(ckpt)
+    assert not os.path.exists(ckpt + ".tmp")
+
+    # Fresh module load -- accumulators must hydrate from disk.
+    rs2 = _reload_reap_scores({
+        "VLLM_CALIB_CAPTURE_REAP_SCORES": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    assert rs2._REAP_SCORE_ACCUM == {}  # fresh state
+    loaded = rs2.load_reap_scores_checkpoint(ckpt)
+    assert loaded == 42
+    assert rs2.get_n_prompts_accumulated() == 42
+    assert rs2._N_LAYERS == 2
+    assert rs2._N_EXPERTS == n_experts
+    assert torch.equal(
+        rs2._REAP_SCORE_ACCUM[0],
+        torch.tensor([1.5, 2.5, 0.0], dtype=torch.float32),
+    )
+    assert torch.equal(
+        rs2._REAP_TOKEN_COUNTS[0],
+        torch.tensor([3, 5, 0], dtype=torch.int64),
+    )
+    assert torch.equal(
+        rs2._REAP_SCORE_ACCUM[1],
+        torch.tensor([0.5, 0.0, 4.0], dtype=torch.float32),
+    )
+    assert torch.equal(
+        rs2._REAP_TOKEN_COUNTS[1],
+        torch.tensor([1, 0, 7], dtype=torch.int64),
+    )
+    assert rs2._LAYER_ID_TO_RANK == {0: 0, 1: 1}
+
+
+# ---------------------------------------------------------------------------
+# Test 4 -- two-segment additivity
+# ---------------------------------------------------------------------------
+
+
+def test_two_segment_additivity(tmp_path):
+    """10 tokens + checkpoint + reload + 10 tokens == 20-token single run.
+
+    Critical for spot-preemption: a run split across two instance
+    lifetimes must produce the same accumulator state as a single run.
+    """
+    n_experts = 4
+    n_tokens_per = 10
+    top_k = 2
+
+    # Deterministic data.
+    torch.manual_seed(7)
+    tw_all = torch.rand(2 * n_tokens_per, top_k, dtype=torch.float32)
+    ids_all = torch.randint(0, n_experts, (2 * n_tokens_per, top_k),
+                            dtype=torch.int64)
+    uw_all = torch.randn(2 * n_tokens_per, top_k, 5, dtype=torch.float32)
+
+    # --- single 20-token reference run ---------------------------------
+    ref = _reload_reap_scores({
+        "VLLM_CALIB_CAPTURE_REAP_SCORES": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    _seed_layer(ref, layer_idx=0, rank=0, n_experts=n_experts)
+    ref._on_router(layer_idx=0, router_logits=torch.zeros(2 * n_tokens_per, n_experts),
+                   topk_weights=tw_all, topk_ids=ids_all)
+    ref._on_expert_out_unweighted(layer_idx=0, unweighted=uw_all,
+                                  topk_ids=ids_all)
+    expected_scores = ref._REAP_SCORE_ACCUM[0].clone()
+    expected_counts = ref._REAP_TOKEN_COUNTS[0].clone()
+
+    # --- split across two segments with a checkpoint + reload ----------
+    seg = _reload_reap_scores({
+        "VLLM_CALIB_CAPTURE_REAP_SCORES": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    _seed_layer(seg, layer_idx=0, rank=0, n_experts=n_experts)
+    # First 10 tokens.
+    seg._on_router(layer_idx=0, router_logits=torch.zeros(n_tokens_per, n_experts),
+                   topk_weights=tw_all[:n_tokens_per],
+                   topk_ids=ids_all[:n_tokens_per])
+    seg._on_expert_out_unweighted(layer_idx=0,
+                                  unweighted=uw_all[:n_tokens_per],
+                                  topk_ids=ids_all[:n_tokens_per])
+    seg.set_n_prompts_accumulated(1)
+    ckpt = str(tmp_path / "twoseg.reap.ckpt")
+    seg.dump_reap_scores_checkpoint(ckpt)
+
+    # Reload module + checkpoint -- simulates a process restart.
+    seg2 = _reload_reap_scores({
+        "VLLM_CALIB_CAPTURE_REAP_SCORES": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    seg2.load_reap_scores_checkpoint(ckpt)
+    # Second 10 tokens.
+    seg2._on_router(layer_idx=0, router_logits=torch.zeros(n_tokens_per, n_experts),
+                    topk_weights=tw_all[n_tokens_per:],
+                    topk_ids=ids_all[n_tokens_per:])
+    seg2._on_expert_out_unweighted(layer_idx=0,
+                                   unweighted=uw_all[n_tokens_per:],
+                                   topk_ids=ids_all[n_tokens_per:])
+
+    assert torch.allclose(seg2._REAP_SCORE_ACCUM[0], expected_scores, atol=1e-5)
+    assert torch.equal(seg2._REAP_TOKEN_COUNTS[0], expected_counts)
+
+
+# ---------------------------------------------------------------------------
+# Test 5 -- router stash miss
+# ---------------------------------------------------------------------------
+
+
+def test_router_stash_miss_skips_silently():
+    """expert_out_unweighted without a preceding router fire → no
+    accumulation, warning logged. The vllm.* loggers set propagate=False
+    via vllm.logger.DEFAULT_LOGGING_CONFIG, so we install a temporary
+    handler directly on the module's logger to capture records here."""
+    import logging
+    rs = _reload_reap_scores({
+        "VLLM_CALIB_CAPTURE_REAP_SCORES": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    n_experts = 3
+    _seed_layer(rs, layer_idx=5, rank=0, n_experts=n_experts)
+
+    captured: list[logging.LogRecord] = []
+
+    class _ListHandler(logging.Handler):
+        def emit(self, record):
+            captured.append(record)
+
+    handler = _ListHandler(level=logging.WARNING)
+    target_logger = logging.getLogger("vllm.calibration_reap_scores")
+    prev_level = target_logger.level
+    target_logger.addHandler(handler)
+    target_logger.setLevel(logging.WARNING)
+    try:
+        topk_ids = torch.tensor([[0, 1]], dtype=torch.int64)
+        unweighted = torch.tensor(
+            [[[1.0, 0.0], [0.0, 1.0]]], dtype=torch.float32,
+        )
+        # Don't fire router; just call expert_out_unweighted directly.
+        rs._on_expert_out_unweighted(layer_idx=5, unweighted=unweighted,
+                                     topk_ids=topk_ids)
+    finally:
+        target_logger.removeHandler(handler)
+        target_logger.setLevel(prev_level)
+
+    # Accumulator untouched.
+    assert torch.equal(
+        rs._REAP_SCORE_ACCUM[0], torch.zeros(n_experts, dtype=torch.float32),
+    )
+    assert torch.equal(
+        rs._REAP_TOKEN_COUNTS[0], torch.zeros(n_experts, dtype=torch.int64),
+    )
+    # Warning surfaced.
+    assert any("stash miss" in rec.getMessage().lower()
+               or "without a preceding router" in rec.getMessage().lower()
+               for rec in captured), (
+        f"expected stash-miss warning; got {[r.getMessage() for r in captured]}"
+    )
+
+
+# ---------------------------------------------------------------------------
+# Test 6 -- dump normalization
+# ---------------------------------------------------------------------------
+
+
+def test_dump_normalization(tmp_path, monkeypatch):
+    """1 token to expert 0 → reap_scores[0,0] equals raw value, others zero."""
+    rs = _reload_reap_scores({
+        "VLLM_CALIB_CAPTURE_REAP_SCORES": "1",
+        "VLLM_CALIB_CAPTURE_ROUTER": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    n_experts = 3
+    _seed_layer(rs, layer_idx=0, rank=0, n_experts=n_experts)
+    # Manually seed: contribution 4.2 to expert 0, count = 1.
+    rs._REAP_SCORE_ACCUM[0][0] = 4.2
+    rs._REAP_TOKEN_COUNTS[0][0] = 1
+
+    # Spy on save_reap_scores to capture the payload (the dump helper
+    # imports it lazily inside the function body).
+    captured = {}
+
+    def _fake_save(payload, path):
+        captured["payload"] = payload
+        captured["path"] = path
+
+    import moe_compress.utils.cached_calibration_signals as ccs
+    monkeypatch.setattr(ccs, "save_reap_scores", _fake_save)
+
+    jsonl = tmp_path / "trace.jsonl"
+    rs.dump_reap_scores(jsonl)
+
+    payload = captured["payload"]
+    assert payload is not None
+    assert payload.schema_version == 1
+    assert payload.n_layers == 1
+    assert payload.n_experts == n_experts
+    assert torch.allclose(
+        payload.reap_scores[0],
+        torch.tensor([4.2, 0.0, 0.0], dtype=torch.float32),
+        atol=1e-5,
+    )
+    assert torch.equal(
+        payload.token_counts[0],
+        torch.tensor([1, 0, 0], dtype=torch.int64),
+    )
