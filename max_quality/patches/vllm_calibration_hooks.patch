index 0000000..1644034
--- /dev/null
+++ b/vllm/calibration_router_logits_stats.py
@@ -0,0 +1,455 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Per-(layer, expert) sink-vs-normal router-score aggregate writer for
+calibration-v2 (Item 4 of the writers campaign).
+
+Computes the aggregate quantities the project's
+:class:`SinkTokenRoutingAccumulator` finalizes after Phase B -- per-
+(layer, expert) sum of router scores on sink tokens, sum on normal
+tokens, fire-count on sink tokens (i.e. how many times each expert was
+in the routed top-k for a sink token) -- plus the per-layer sink /
+normal token counts needed to invert the sums back into means.
+
+All POST-softmax (the writer softmaxes the ``router_logits`` payload
+inline before accumulating; the schema name "router_logits_stats"
+reflects the upstream HOOK name, not the on-disk dtype).
+
+Env-var gating
+--------------
+``VLLM_CALIB_CAPTURE_ROUTER_LOGITS_STATS=1`` activates the module.
+Requires:
+
+* ``VLLM_CALIB_CAPTURE_ROUTER=1`` (router hook fires).
+
+The driver (``build_self_traces_calib_vllm.py``) sets both BEFORE the
+first vllm import when ``--capture-router-logits-stats`` is passed.
+
+Sink-token definition (writer-side)
+-----------------------------------
+The project's :class:`SinkTokenRoutingAccumulator` defines a sink token
+as ``input_id == bos_token_id`` ∪ ``position == 0``. Today's vLLM router
+dispatch (``vllm.model_executor.layers.fused_moe.runner.moe_runner``)
+does NOT include ``input_ids`` in the payload -- the dispatch kwargs
+are ``layer_idx`` / ``router_logits`` / ``topk_weights`` / ``topk_ids``
+only. So in practice the FALLBACK branch (position-0-only sink) is the
+de facto active path. The writer is forward-compatible: if a future
+dispatch grows the ``input_ids`` kwarg, the writer will pick it up
+automatically and use the BOS-id branch (with the leading-position
+union, matching :class:`SinkTokenRoutingAccumulator`).
+
+CUDA-graph compatibility
+------------------------
+Accumulators live on CPU. The callback is dispatched from Python
+synchronously after the router runs; ``router_logits`` / ``topk_ids``
+are cloned (via ``.detach().cpu()``) at callback entry.
+
+Resumability
+------------
+Mirrors :mod:`vllm.calibration_routing_stats` / per-expert-max /
+input-cov: periodic ``dump_router_logits_stats_checkpoint`` during the
+run, ``load_router_logits_stats_checkpoint`` on ``--resume``. The final
+``dump_router_logits_stats`` writes the payload via
+``moe_compress.utils.cached_calibration_signals.save_router_logits_stats``
+(Item 0).
+
+No-immediate-consumer-divergence note
+-------------------------------------
+Unlike Item 3 (routing_stats), Item 4 DOES have an immediate downstream
+consumer: ``Stage1RouterLogitsStatsCacheProvider`` hydrates a
+pre-finalized :class:`SinkTokenRoutingAccumulator` directly into the
+``sink_acc`` ctx slot, allowing :class:`SinkTokenDetectorPlugin.run`
+to skip the live router-logits + softmax + top-k accumulator pass
+entirely. The Stage 1 orchestrator's STEP 4.7 drops ``"sink_routing"``
+from ``needed`` on cache hit so the live HookSpec is NOT registered.
+"""
+from __future__ import annotations
+
+import logging
+import os
+from pathlib import Path
+from typing import Any
+
+import torch
+
+import vllm.calibration_hooks as _ch
+
+log = logging.getLogger(__name__)
+
+__all__ = [
+    "setup",
+    "dump_router_logits_stats",
+    "dump_router_logits_stats_checkpoint",
+    "load_router_logits_stats_checkpoint",
+    "get_n_prompts_accumulated",
+    "set_n_prompts_accumulated",
+]
+
+# Sampled at import time -- matches calibration_imatrix / per_expert_max /
+# routing_stats pattern.
+_CAPTURE_ROUTER_LOGITS_STATS: bool = (
+    os.getenv("VLLM_CALIB_CAPTURE_ROUTER_LOGITS_STATS", "0") == "1"
+)
+
+# Per-layer-rank CPU accumulators.
+# All shapes are ``[n_experts]`` (per-rank), stacked at dump time into
+# ``[n_layers, n_experts]``.
+_SCORE_SINK_SUM: dict[int, torch.Tensor] = {}     # rank -> [n_experts] float32
+_SCORE_NORMAL_SUM: dict[int, torch.Tensor] = {}   # rank -> [n_experts] float32
+_FIRE_ON_SINK: dict[int, torch.Tensor] = {}       # rank -> [n_experts] int64
+# Per-rank scalar counts of sink/normal tokens seen so far. Stored as
+# ``[1]`` int64 tensors for clean checkpoint round-trip (matches the
+# tensor-only torch.save contract).
+_N_SINK_TOKENS: dict[int, torch.Tensor] = {}      # rank -> [1] int64
+_N_NORMAL_TOKENS: dict[int, torch.Tensor] = {}    # rank -> [1] int64
+
+_LAYER_ID_TO_RANK: dict[int, int] = {}
+_N_LAYERS: int = 0
+_N_EXPERTS: int = 0
+_BOS_TOKEN_ID: int | None = None
+
+# Cumulative prompt counter mirroring imatrix / reap_scores /
+# per_expert_max / routing_stats.
+_n_prompts_accumulated: int = 0
+_CHECKPOINT_SCHEMA_VERSION: int = 1
+
+
+def get_n_prompts_accumulated() -> int:
+    return _n_prompts_accumulated
+
+
+def set_n_prompts_accumulated(n: int) -> None:
+    global _n_prompts_accumulated
+    if n < 0:
+        raise ValueError(f"n must be >= 0; got {n}")
+    _n_prompts_accumulated = int(n)
+
+
+def _resolve_model(llm: Any) -> Any | None:
+    """Walk well-known attribute paths to find the live nn.Module."""
+    candidates = [
+        ("llm_engine", "model_executor", "driver_worker", "model_runner",
+         "model"),
+        ("llm_engine", "model_executor", "model_runner", "model"),
+        ("model_executor", "driver_worker", "model_runner", "model"),
+        ("model_runner", "model"),
+    ]
+    for path in candidates:
+        obj: Any = llm
+        ok = True
+        for attr in path:
+            obj = getattr(obj, attr, None)
+            if obj is None:
+                ok = False
+                break
+        if ok:
+            return obj
+    return None
+
+
+def setup(llm: Any, bos_token_id: int | None = None) -> None:
+    """Discover MoE layers, pre-allocate accumulators, register callback.
+
+    Stores ``bos_token_id`` on the module so the per-batch callback can
+    build a sink mask when the upstream dispatch supplies ``input_ids``.
+    When the dispatch does NOT supply ``input_ids`` (the current vLLM
+    contract -- see module docstring), the BOS id is unused and the
+    callback falls back to position-0-only sink classification.
+
+    Idempotent: calling twice does not double-allocate (the callback is
+    deduplicated by the chained-callback registry, and the per-rank
+    accumulator dicts are guarded by ``if rank not in ...``).
+    """
+    global _N_LAYERS, _N_EXPERTS, _BOS_TOKEN_ID
+
+    if not _CAPTURE_ROUTER_LOGITS_STATS:
+        log.info("calibration_router_logits_stats: env gate off; no-op setup.")
+        return
+
+    _BOS_TOKEN_ID = int(bos_token_id) if bos_token_id is not None else None
+
+    model = _resolve_model(llm)
+    if model is None:
+        log.warning(
+            "calibration_router_logits_stats: could not resolve model from "
+            "LLM; callback will be registered but accumulators will not have "
+            "their layer->rank mapping populated until first dispatch."
+        )
+
+    # Discover MoE layers by attribute presence -- same pattern as
+    # calibration_reap_scores / calibration_per_expert_max /
+    # calibration_routing_stats so the rank ordering matches across all
+    # writers' sidecars.
+    n_layers = 0
+    n_experts_seen: int | None = None
+    if model is not None:
+        for name, module in model.named_modules():
+            moe_layer_id = getattr(module, "moe_layer_id", None)
+            num_experts = getattr(module, "num_experts", None)
+            if not (isinstance(moe_layer_id, int)
+                    and isinstance(num_experts, int) and num_experts > 0):
+                continue
+            _LAYER_ID_TO_RANK[moe_layer_id] = n_layers
+            if n_experts_seen is None:
+                n_experts_seen = num_experts
+            elif n_experts_seen != num_experts:
+                log.warning(
+                    "calibration_router_logits_stats: mixed expert counts "
+                    "(%d vs first-seen %d at %s); using first.",
+                    num_experts, n_experts_seen, name,
+                )
+            n_layers += 1
+
+    _N_LAYERS = n_layers
+    _N_EXPERTS = int(n_experts_seen) if n_experts_seen is not None else 0
+
+    # Pre-allocate CPU accumulators with zeros (additive accumulators; no
+    # -inf sentinels needed).
+    for rank in range(_N_LAYERS):
+        if rank not in _SCORE_SINK_SUM:
+            _SCORE_SINK_SUM[rank] = torch.zeros(
+                _N_EXPERTS, dtype=torch.float32,
+            )
+            _SCORE_NORMAL_SUM[rank] = torch.zeros(
+                _N_EXPERTS, dtype=torch.float32,
+            )
+            _FIRE_ON_SINK[rank] = torch.zeros(
+                _N_EXPERTS, dtype=torch.int64,
+            )
+            _N_SINK_TOKENS[rank] = torch.zeros(1, dtype=torch.int64)
+            _N_NORMAL_TOKENS[rank] = torch.zeros(1, dtype=torch.int64)
+
+    _ch.register_callback("router", _on_router)
+
+    log.info(
+        "calibration_router_logits_stats: setup complete -- %d MoE layers, "
+        "%d experts/layer; bos_token_id=%s; callback registered for router.",
+        _N_LAYERS, _N_EXPERTS, _BOS_TOKEN_ID,
+    )
+
+
+def _on_router(layer_idx: int, router_logits: torch.Tensor,
+               topk_weights: torch.Tensor, topk_ids: torch.Tensor,
+               input_ids: torch.Tensor | None = None,
+               **_: Any) -> None:
+    """Accumulate per-(layer, expert) sink-vs-normal aggregates.
+
+    Sink mask source-of-truth:
+    1. If ``input_ids is not None and _BOS_TOKEN_ID is not None``:
+       ``sink_mask = (input_ids == _BOS_TOKEN_ID)``. Mirrors the leading
+       position-0 union in :class:`SinkTokenRoutingAccumulator` ONLY
+       when the dispatch supplies the full ``[B, T]`` ids tensor; the
+       writer keeps the conservative BOS-id branch here because the
+       current vLLM dispatch does not -- a forward-only refinement to
+       add the leading-position union would require the dispatch site
+       to grow the kwarg AND surface the per-batch positional metadata
+       to the callback.
+    2. Otherwise: position-0-only sink (``sink_mask = [True, False, ...,
+       False]``) -- the de facto active path on today's dispatch.
+
+    ``router_logits`` is ``[n_tok, n_experts]``; we softmax over the
+    expert dim, then scatter-add per-token rows into the per-(layer,
+    expert) sum accumulators. ``topk_ids[sink_mask]`` is reshaped and
+    scatter-added (one per top-k selection) into ``fire_on_sink``.
+    """
+    if not _CAPTURE_ROUTER_LOGITS_STATS:
+        return
+
+    rank = _LAYER_ID_TO_RANK.get(layer_idx)
+    if rank is None:
+        raise RuntimeError(
+            f"calibration_router_logits_stats: layer_idx={layer_idx} was "
+            f"not discovered by setup() -- the MoE layer must be visible "
+            f"via named_modules() with the moe_layer_id attribute set. "
+            f"Late-discovered layers would force the accumulators to "
+            f"grow, corrupting already-allocated buffers for other "
+            f"layers. Fix the setup() pass to find ALL MoE layers (or "
+            f"this layer's FusedMoE module is missing the moe_layer_id "
+            f"attribute)."
+        )
+
+    # Softmax over experts -- POST-softmax aggregates per the schema.
+    post_softmax = router_logits.detach().to(
+        "cpu", dtype=torch.float32,
+    ).softmax(dim=-1)                                            # [n_tok, E]
+    n_tok = post_softmax.shape[0]
+
+    # Sink mask.
+    if input_ids is not None and _BOS_TOKEN_ID is not None:
+        sink_mask = (input_ids == _BOS_TOKEN_ID).reshape(-1).cpu()
+        # Defensive: dispatch shape disagreement would silently mis-mask.
+        if sink_mask.numel() != n_tok:
+            raise RuntimeError(
+                f"calibration_router_logits_stats: input_ids has "
+                f"{sink_mask.numel()} elements but router_logits has "
+                f"{n_tok} tokens -- the upstream dispatch is supplying "
+                f"a mismatched [B, T] tensor."
+            )
+    else:
+        sink_mask = torch.zeros(n_tok, dtype=torch.bool)
+        if n_tok > 0:
+            sink_mask[0] = True
+
+    # Score sums.
+    if sink_mask.any():
+        _SCORE_SINK_SUM[rank] += post_softmax[sink_mask].sum(dim=0)
+    normal_mask = ~sink_mask
+    if normal_mask.any():
+        _SCORE_NORMAL_SUM[rank] += post_softmax[normal_mask].sum(dim=0)
+
+    # Fire-on-sink: for each sink token, every expert in the top-k
+    # contributes +1 to its expert slot in fire_on_sink[rank].
+    if sink_mask.any():
+        topk_ids_cpu = topk_ids.detach().cpu().to(torch.int64)
+        topk_ids_sink = topk_ids_cpu[sink_mask].reshape(-1)
+        if topk_ids_sink.numel() > 0:
+            ones = torch.ones_like(topk_ids_sink, dtype=torch.int64)
+            _FIRE_ON_SINK[rank].scatter_add_(0, topk_ids_sink, ones)
+
+    # Token counts.
+    n_sink = int(sink_mask.sum().item())
+    _N_SINK_TOKENS[rank] += n_sink
+    _N_NORMAL_TOKENS[rank] += n_tok - n_sink
+
+
+def dump_router_logits_stats(jsonl_path: str | Path) -> None:
+    """Write the final router-logits-stats sidecar via the Item-0 helper.
+
+    Stacks the per-rank accumulator dicts into ``[n_layers, n_experts]``
+    tensors (and ``[n_layers]`` for token counts). Zero-traffic layers
+    fall through as zeros.
+    """
+    if not _CAPTURE_ROUTER_LOGITS_STATS:
+        return
+
+    # Import here (not at module top) so the dependency is lazy.
+    from moe_compress.utils.cached_calibration_signals import (
+        RouterLogitsStatsPayload, save_router_logits_stats, SCHEMA_VERSIONS,
+    )
+
+    if _N_LAYERS == 0 or _N_EXPERTS == 0:
+        log.warning(
+            "calibration_router_logits_stats: no MoE layers seen; "
+            "skipping dump."
+        )
+        return
+
+    sink_rows = []
+    normal_rows = []
+    fire_rows = []
+    n_sink_rows = []
+    n_normal_rows = []
+    for rank in range(_N_LAYERS):
+        sink = _SCORE_SINK_SUM.get(rank)
+        normal = _SCORE_NORMAL_SUM.get(rank)
+        fire = _FIRE_ON_SINK.get(rank)
+        n_sink = _N_SINK_TOKENS.get(rank)
+        n_normal = _N_NORMAL_TOKENS.get(rank)
+        if (sink is None or normal is None or fire is None
+                or n_sink is None or n_normal is None):
+            sink_rows.append(torch.zeros(_N_EXPERTS, dtype=torch.float32))
+            normal_rows.append(torch.zeros(_N_EXPERTS, dtype=torch.float32))
+            fire_rows.append(torch.zeros(_N_EXPERTS, dtype=torch.int64))
+            n_sink_rows.append(torch.zeros(1, dtype=torch.int64))
+            n_normal_rows.append(torch.zeros(1, dtype=torch.int64))
+            continue
+        sink_rows.append(sink.clone())
+        normal_rows.append(normal.clone())
+        fire_rows.append(fire.clone())
+        n_sink_rows.append(n_sink.clone())
+        n_normal_rows.append(n_normal.clone())
+
+    payload = RouterLogitsStatsPayload(
+        schema_version=SCHEMA_VERSIONS["router_logits_stats"],
+        n_experts=_N_EXPERTS,
+        n_layers=_N_LAYERS,
+        score_sink_sum=torch.stack(sink_rows),
+        score_normal_sum=torch.stack(normal_rows),
+        fire_on_sink=torch.stack(fire_rows),
+        n_sink_tokens=torch.cat(n_sink_rows),         # [n_layers]
+        n_normal_tokens=torch.cat(n_normal_rows),     # [n_layers]
+        bos_token_id=_BOS_TOKEN_ID,
+    )
+    save_router_logits_stats(payload, Path(jsonl_path))
+    log.info(
+        "calibration_router_logits_stats: wrote %d-layer x %d-expert "
+        "sidecar next to %s (bos_token_id=%s)",
+        _N_LAYERS, _N_EXPERTS, jsonl_path, _BOS_TOKEN_ID,
+    )
+
+
+def dump_router_logits_stats_checkpoint(ckpt_path: str) -> None:
+    """Atomic checkpoint of raw accumulator state for resume."""
+    if not _CAPTURE_ROUTER_LOGITS_STATS:
+        return
+    payload = {
+        "schema_version": _CHECKPOINT_SCHEMA_VERSION,
+        "n_prompts_accumulated": _n_prompts_accumulated,
+        "n_layers": _N_LAYERS,
+        "n_experts": _N_EXPERTS,
+        "bos_token_id": _BOS_TOKEN_ID,
+        "layer_id_to_rank": dict(_LAYER_ID_TO_RANK),
+        "score_sink_sum": {r: v.clone() for r, v in _SCORE_SINK_SUM.items()},
+        "score_normal_sum": {
+            r: v.clone() for r, v in _SCORE_NORMAL_SUM.items()
+        },
+        "fire_on_sink": {r: v.clone() for r, v in _FIRE_ON_SINK.items()},
+        "n_sink_tokens": {r: v.clone() for r, v in _N_SINK_TOKENS.items()},
+        "n_normal_tokens": {
+            r: v.clone() for r, v in _N_NORMAL_TOKENS.items()
+        },
+    }
+    tmp = ckpt_path + ".tmp"
+    with open(tmp, "wb") as f:
+        torch.save(payload, f)
+        f.flush()
+        os.fsync(f.fileno())
+    os.replace(tmp, ckpt_path)
+    _dir_fd = os.open(os.path.dirname(ckpt_path) or ".", os.O_RDONLY)
+    try:
+        os.fsync(_dir_fd)
+    except OSError:
+        pass
+    finally:
+        os.close(_dir_fd)
+
+
+def load_router_logits_stats_checkpoint(ckpt_path: str) -> int:
+    """Hydrate accumulators from a previous run's checkpoint. Returns
+    n_prompts_accumulated; 0 if file missing."""
+    global _N_LAYERS, _N_EXPERTS, _n_prompts_accumulated, _BOS_TOKEN_ID
+    if not os.path.exists(ckpt_path):
+        return 0
+    payload = torch.load(ckpt_path, map_location="cpu", weights_only=False)
+    schema = int(payload.get("schema_version", 0))
+    if schema != _CHECKPOINT_SCHEMA_VERSION:
+        raise ValueError(
+            f"calibration_router_logits_stats: checkpoint at {ckpt_path} "
+            f"has schema_version={schema}, expected "
+            f"{_CHECKPOINT_SCHEMA_VERSION}. Delete the checkpoint to "
+            f"restart from scratch."
+        )
+    _n_prompts_accumulated = int(payload["n_prompts_accumulated"])
+    _N_LAYERS = int(payload["n_layers"])
+    _N_EXPERTS = int(payload["n_experts"])
+    bos = payload.get("bos_token_id", None)
+    _BOS_TOKEN_ID = int(bos) if bos is not None else None
+    _LAYER_ID_TO_RANK.clear()
+    _LAYER_ID_TO_RANK.update({
+        int(k): int(v) for k, v in payload.get("layer_id_to_rank", {}).items()
+    })
+    _SCORE_SINK_SUM.clear()
+    _SCORE_NORMAL_SUM.clear()
+    _FIRE_ON_SINK.clear()
+    _N_SINK_TOKENS.clear()
+    _N_NORMAL_TOKENS.clear()
+    for r, t in payload.get("score_sink_sum", {}).items():
+        _SCORE_SINK_SUM[int(r)] = t.to(torch.float32).clone()
+    for r, t in payload.get("score_normal_sum", {}).items():
+        _SCORE_NORMAL_SUM[int(r)] = t.to(torch.float32).clone()
+    for r, t in payload.get("fire_on_sink", {}).items():
+        _FIRE_ON_SINK[int(r)] = t.to(torch.int64).clone()
+    for r, t in payload.get("n_sink_tokens", {}).items():
+        _N_SINK_TOKENS[int(r)] = t.to(torch.int64).clone()
+    for r, t in payload.get("n_normal_tokens", {}).items():
+        _N_NORMAL_TOKENS[int(r)] = t.to(torch.int64).clone()
+    return _n_prompts_accumulated
