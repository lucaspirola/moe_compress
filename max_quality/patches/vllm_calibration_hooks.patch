--- /dev/null
+++ b/tests/test_calibration_per_expert_max_smoke.py
@@ -0,0 +1,391 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Smoke tests for ``vllm.calibration_per_expert_max``.
+
+These exercise the per-(layer, expert) scatter-amax accumulator, the
+env-gate contract, checkpoint round-trip + two-segment additivity, the
+persistent-buffer clone guard, and the dump-payload shape + zero-fill
+contract.
+
+Tests:
+
+1. ``test_accumulator_math_single_layer`` -- a synthetic
+   ``[3, 2, 4]`` unweighted + known ``topk_ids`` populates the per-
+   expert accumulator with the expected scatter-amax of
+   ``abs().amax(dim=-1)``.
+2. ``test_env_gate_off_no_op`` -- env unset → ``setup()`` and the
+   callback are no-ops (accumulators untouched).
+3. ``test_checkpoint_round_trip`` -- dump → reload module →
+   load_checkpoint restores byte-identical accumulator state.
+4. ``test_two_segment_additivity`` -- max over 10 tokens + checkpoint +
+   reload + max over 10 more tokens == max over 20 tokens straight.
+5. ``test_persistent_buffer_clone`` -- callback clones ``unweighted`` at
+   entry; post-callback mutation of the input does NOT change the
+   accumulator.
+6. ``test_dump_payload_shape_and_zero_fill`` -- partial accumulator
+   (rank 0 only with some -inf cells) dumped → payload has
+   ``[n_layers, n_experts]`` shape, untouched rank-1 row is all zeros
+   (not -inf), and rank-0's -inf cells are zero-filled.
+"""
+from __future__ import annotations
+
+import importlib
+import os
+import sys
+from typing import Any
+
+import torch
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+
+def _reload_pem(env: dict[str, str]) -> Any:
+    """Reload ``vllm.calibration_per_expert_max`` (and hooks) with a fresh env.
+
+    Module-level ``_CAPTURE_PER_EXPERT_MAX`` is sampled at import; per-test
+    isolation requires a fresh import.
+    """
+    sys.modules.pop("vllm.calibration_per_expert_max", None)
+    sys.modules.pop("vllm.calibration_hooks", None)
+    for key in (
+        "VLLM_CALIB_CAPTURE_PER_EXPERT_MAX",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED",
+        "VLLM_CALIB_CAPTURE_REAP_SCORES",
+        "VLLM_CALIB_CAPTURE_ROUTER",
+        "VLLM_CALIB_CAPTURE_IMATRIX",
+        "VLLM_CALIB_CAPTURE_EXPERT",
+        "VLLM_CALIB_CAPTURE_BLOCK",
+        "VLLM_CALIB_CAPTURE_EXPERT_MID",
+        "VLLM_CALIB_CAPTURE_INPUT_COV",
+    ):
+        os.environ.pop(key, None)
+    for k, v in env.items():
+        os.environ[k] = v
+    importlib.import_module("vllm.calibration_hooks")
+    return importlib.import_module("vllm.calibration_per_expert_max")
+
+
+def _seed_layer(pem: Any, layer_idx: int, rank: int, n_experts: int) -> None:
+    """Manually wire up the per-layer accumulators the way setup() would."""
+    pem._LAYER_ID_TO_RANK[layer_idx] = rank
+    if rank + 1 > pem._N_LAYERS:
+        pem._N_LAYERS = rank + 1
+    if n_experts > pem._N_EXPERTS:
+        pem._N_EXPERTS = n_experts
+    pem._PEM_ACCUM[rank] = torch.full(
+        (n_experts,), float("-inf"), dtype=torch.float32,
+    )
+    pem._PEM_TOKEN_COUNTS[rank] = torch.zeros(n_experts, dtype=torch.int64)
+
+
+# ---------------------------------------------------------------------------
+# Test 1 -- accumulator math (single layer)
+# ---------------------------------------------------------------------------
+
+
+def test_accumulator_math_single_layer():
+    """Synthetic ``[3, 2, 4]`` unweighted populates the accumulator with
+    the hand-computed scatter-amax of ``abs().amax(dim=-1)``."""
+    pem = _reload_pem({
+        "VLLM_CALIB_CAPTURE_PER_EXPERT_MAX": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    n_experts = 5
+    _seed_layer(pem, layer_idx=0, rank=0, n_experts=n_experts)
+
+    # 3 tokens, top_k=2, hidden=4. Token (t, k) routes to expert
+    # topk_ids[t, k]; magnitude per (t, k) is abs(uw[t, k]).amax(-1).
+    # Token 0: (e=0 magnitude=3, e=2 magnitude=-2 -> 2)
+    # Token 1: (e=1 magnitude=1, e=2 magnitude=5)   <- expert 2 takes 5
+    # Token 2: (e=0 magnitude=4, e=3 magnitude=0.5) <- expert 0 takes max(3, 4)=4
+    unweighted = torch.tensor([
+        [[ 3.0, 0.0, -1.0, 2.0],   # t0 k0 e0: amax=3
+         [ 0.0, 0.0, -2.0, 1.0]],  # t0 k1 e2: amax=2
+        [[ 1.0, 0.0,  0.0, 0.0],   # t1 k0 e1: amax=1
+         [ 5.0, 0.0,  0.0, 0.0]],  # t1 k1 e2: amax=5
+        [[ 4.0, 0.0,  0.0, 0.0],   # t2 k0 e0: amax=4
+         [ 0.5, 0.0,  0.0, 0.0]],  # t2 k1 e3: amax=0.5
+    ], dtype=torch.float32)
+    topk_ids = torch.tensor(
+        [[0, 2], [1, 2], [0, 3]], dtype=torch.int64,
+    )
+
+    pem._on_expert_out_unweighted(
+        layer_idx=0, unweighted=unweighted, topk_ids=topk_ids,
+    )
+
+    # Hand-computed scatter-amax per expert:
+    # e0: max(3, 4) = 4
+    # e1: 1
+    # e2: max(2, 5) = 5
+    # e3: 0.5
+    # e4: -inf (no traffic)
+    got = pem._PEM_ACCUM[0]
+    assert got[0].item() == 4.0
+    assert got[1].item() == 1.0
+    assert got[2].item() == 5.0
+    assert got[3].item() == 0.5
+    assert got[4].item() == float("-inf")
+
+    # Token counts: e0 sees 2 tokens, e1 1, e2 2, e3 1, e4 0.
+    expected_counts = torch.tensor([2, 1, 2, 1, 0], dtype=torch.int64)
+    assert torch.equal(pem._PEM_TOKEN_COUNTS[0], expected_counts)
+
+
+# ---------------------------------------------------------------------------
+# Test 2 -- env-off short-circuit
+# ---------------------------------------------------------------------------
+
+
+def test_env_gate_off_no_op():
+    """Env unset → setup() is a no-op, and the callback short-circuits
+    before touching any accumulator."""
+    pem = _reload_pem({})  # env cleared
+    assert pem._CAPTURE_PER_EXPERT_MAX is False
+
+    # setup() with a stub LLM -> should not register callbacks nor
+    # allocate accumulators.
+    pem.setup(llm=None)
+    assert pem._PEM_ACCUM == {}
+    assert pem._PEM_TOKEN_COUNTS == {}
+
+    # Manually seed accumulators, then call the callback. The internal
+    # env guard must short-circuit before scatter_reduce_.
+    n_experts = 3
+    _seed_layer(pem, layer_idx=0, rank=0, n_experts=n_experts)
+
+    unweighted = torch.tensor(
+        [[[1.0, 0.0], [0.0, 1.0]]], dtype=torch.float32,
+    )
+    topk_ids = torch.tensor([[0, 1]], dtype=torch.int64)
+    pem._on_expert_out_unweighted(
+        layer_idx=0, unweighted=unweighted, topk_ids=topk_ids,
+    )
+    # Accumulator still at the -inf seed value because the env guard
+    # short-circuits before scatter_reduce_.
+    assert pem._PEM_ACCUM[0][0].item() == float("-inf")
+    assert pem._PEM_ACCUM[0][1].item() == float("-inf")
+    assert torch.equal(
+        pem._PEM_TOKEN_COUNTS[0], torch.zeros(n_experts, dtype=torch.int64),
+    )
+
+
+# ---------------------------------------------------------------------------
+# Test 3 -- checkpoint round-trip
+# ---------------------------------------------------------------------------
+
+
+def test_checkpoint_round_trip(tmp_path):
+    """Dump → reload module → load_checkpoint restores byte-identical state."""
+    pem = _reload_pem({
+        "VLLM_CALIB_CAPTURE_PER_EXPERT_MAX": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    n_experts = 3
+    _seed_layer(pem, layer_idx=0, rank=0, n_experts=n_experts)
+    _seed_layer(pem, layer_idx=1, rank=1, n_experts=n_experts)
+
+    pem._PEM_ACCUM[0] = torch.tensor([1.5, 2.5, float("-inf")], dtype=torch.float32)
+    pem._PEM_TOKEN_COUNTS[0] = torch.tensor([3, 5, 0], dtype=torch.int64)
+    pem._PEM_ACCUM[1] = torch.tensor([0.5, float("-inf"), 4.0], dtype=torch.float32)
+    pem._PEM_TOKEN_COUNTS[1] = torch.tensor([1, 0, 7], dtype=torch.int64)
+    pem.set_n_prompts_accumulated(42)
+
+    ckpt = str(tmp_path / "test.pem.ckpt")
+    pem.dump_per_expert_max_checkpoint(ckpt)
+    assert os.path.exists(ckpt)
+    assert not os.path.exists(ckpt + ".tmp")
+
+    # Fresh module load -- accumulators must hydrate from disk.
+    pem2 = _reload_pem({
+        "VLLM_CALIB_CAPTURE_PER_EXPERT_MAX": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    assert pem2._PEM_ACCUM == {}  # fresh state
+    loaded = pem2.load_per_expert_max_checkpoint(ckpt)
+    assert loaded == 42
+    assert pem2.get_n_prompts_accumulated() == 42
+    assert pem2._N_LAYERS == 2
+    assert pem2._N_EXPERTS == n_experts
+    # -inf cells survive serialization.
+    assert pem2._PEM_ACCUM[0][0].item() == 1.5
+    assert pem2._PEM_ACCUM[0][1].item() == 2.5
+    assert pem2._PEM_ACCUM[0][2].item() == float("-inf")
+    assert torch.equal(
+        pem2._PEM_TOKEN_COUNTS[0],
+        torch.tensor([3, 5, 0], dtype=torch.int64),
+    )
+    assert pem2._PEM_ACCUM[1][0].item() == 0.5
+    assert pem2._PEM_ACCUM[1][1].item() == float("-inf")
+    assert pem2._PEM_ACCUM[1][2].item() == 4.0
+    assert torch.equal(
+        pem2._PEM_TOKEN_COUNTS[1],
+        torch.tensor([1, 0, 7], dtype=torch.int64),
+    )
+    assert pem2._LAYER_ID_TO_RANK == {0: 0, 1: 1}
+
+
+# ---------------------------------------------------------------------------
+# Test 4 -- two-segment additivity (max is idempotent over segment split)
+# ---------------------------------------------------------------------------
+
+
+def test_two_segment_additivity(tmp_path):
+    """max(10 tokens) + ckpt + reload + max(10 tokens) == max(20 tokens).
+
+    Critical for spot-preemption: a max-aggregating writer split across
+    two instance lifetimes must produce the same accumulator state as a
+    single run.
+    """
+    n_experts = 4
+    n_tokens_per = 10
+    top_k = 2
+
+    # Deterministic data.
+    torch.manual_seed(13)
+    ids_all = torch.randint(0, n_experts, (2 * n_tokens_per, top_k),
+                            dtype=torch.int64)
+    uw_all = torch.randn(2 * n_tokens_per, top_k, 5, dtype=torch.float32)
+
+    # --- single 20-token reference run ---------------------------------
+    ref = _reload_pem({
+        "VLLM_CALIB_CAPTURE_PER_EXPERT_MAX": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    _seed_layer(ref, layer_idx=0, rank=0, n_experts=n_experts)
+    ref._on_expert_out_unweighted(
+        layer_idx=0, unweighted=uw_all, topk_ids=ids_all,
+    )
+    expected_max = ref._PEM_ACCUM[0].clone()
+    expected_counts = ref._PEM_TOKEN_COUNTS[0].clone()
+
+    # --- split across two segments with a checkpoint + reload ----------
+    seg = _reload_pem({
+        "VLLM_CALIB_CAPTURE_PER_EXPERT_MAX": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    _seed_layer(seg, layer_idx=0, rank=0, n_experts=n_experts)
+    seg._on_expert_out_unweighted(
+        layer_idx=0,
+        unweighted=uw_all[:n_tokens_per],
+        topk_ids=ids_all[:n_tokens_per],
+    )
+    seg.set_n_prompts_accumulated(1)
+    ckpt = str(tmp_path / "twoseg.pem.ckpt")
+    seg.dump_per_expert_max_checkpoint(ckpt)
+
+    # Reload module + checkpoint -- simulates a process restart.
+    seg2 = _reload_pem({
+        "VLLM_CALIB_CAPTURE_PER_EXPERT_MAX": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    seg2.load_per_expert_max_checkpoint(ckpt)
+    seg2._on_expert_out_unweighted(
+        layer_idx=0,
+        unweighted=uw_all[n_tokens_per:],
+        topk_ids=ids_all[n_tokens_per:],
+    )
+
+    assert torch.allclose(seg2._PEM_ACCUM[0], expected_max, atol=1e-6)
+    assert torch.equal(seg2._PEM_TOKEN_COUNTS[0], expected_counts)
+
+
+# ---------------------------------------------------------------------------
+# Test 5 -- persistent-buffer clone safety
+# ---------------------------------------------------------------------------
+
+
+def test_persistent_buffer_clone():
+    """Callback must clone ``unweighted`` at entry; post-callback mutation
+    of the input does NOT corrupt the accumulator."""
+    pem = _reload_pem({
+        "VLLM_CALIB_CAPTURE_PER_EXPERT_MAX": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    n_experts = 3
+    _seed_layer(pem, layer_idx=0, rank=0, n_experts=n_experts)
+
+    # 1 token, top_k=1, hidden=2. Magnitude = 2.5.
+    unweighted = torch.tensor([[[1.0, -2.5]]], dtype=torch.float32)
+    topk_ids = torch.tensor([[1]], dtype=torch.int64)
+    pem._on_expert_out_unweighted(
+        layer_idx=0, unweighted=unweighted, topk_ids=topk_ids,
+    )
+    assert pem._PEM_ACCUM[0][1].item() == 2.5
+
+    # Now mutate the persistent buffer in place (simulates the Triton
+    # kernel's next forward overwriting it with huge values). The
+    # accumulator must NOT reflect the mutated contents.
+    unweighted.fill_(999.0)
+    assert pem._PEM_ACCUM[0][1].item() == 2.5
+    assert pem._PEM_ACCUM[0][0].item() == float("-inf")
+    assert pem._PEM_ACCUM[0][2].item() == float("-inf")
+
+
+# ---------------------------------------------------------------------------
+# Test 6 -- dump payload shape + zero-fill of -inf cells
+# ---------------------------------------------------------------------------
+
+
+def test_dump_payload_shape_and_zero_fill(tmp_path, monkeypatch):
+    """Partial accumulator (rank 0 only with some -inf cells) dumped →
+    payload has ``[n_layers, n_experts]`` shape; rank-1 (untouched) row
+    is all zeros; rank-0's -inf cells are zero-filled, not -inf."""
+    pem = _reload_pem({
+        "VLLM_CALIB_CAPTURE_PER_EXPERT_MAX": "1",
+        "VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED": "1",
+    })
+    n_experts = 4
+    _seed_layer(pem, layer_idx=0, rank=0, n_experts=n_experts)
+    _seed_layer(pem, layer_idx=1, rank=1, n_experts=n_experts)
+    # Only rank 0 sees any traffic; expert 1 + 3 remain at -inf.
+    pem._PEM_ACCUM[0] = torch.tensor(
+        [2.5, float("-inf"), 1.25, float("-inf")], dtype=torch.float32,
+    )
+    pem._PEM_TOKEN_COUNTS[0] = torch.tensor([4, 0, 2, 0], dtype=torch.int64)
+    # Rank 1 stays at -inf (allocated by _seed_layer above).
+
+    # Spy on save_per_expert_max to capture the payload (the dump helper
+    # imports it lazily inside the function body).
+    captured = {}
+
+    def _fake_save(payload, path):
+        captured["payload"] = payload
+        captured["path"] = path
+
+    import moe_compress.utils.cached_calibration_signals as ccs
+    monkeypatch.setattr(ccs, "save_per_expert_max", _fake_save)
+
+    jsonl = tmp_path / "trace.jsonl"
+    pem.dump_per_expert_max(jsonl)
+
+    payload = captured["payload"]
+    assert payload is not None
+    assert payload.schema_version == 1
+    assert payload.n_layers == 2
+    assert payload.n_experts == n_experts
+    # Shape is [n_layers, n_experts].
+    assert payload.per_expert_max.shape == (2, n_experts)
+    assert payload.token_counts.shape == (2, n_experts)
+    # Rank 0: -inf cells zero-filled; positive values preserved.
+    assert torch.equal(
+        payload.per_expert_max[0],
+        torch.tensor([2.5, 0.0, 1.25, 0.0], dtype=torch.float32),
+    )
+    # Rank 1: was all -inf, now all zeros (not -inf).
+    assert torch.equal(
+        payload.per_expert_max[1],
+        torch.zeros(n_experts, dtype=torch.float32),
+    )
+    # Token counts mirror the accumulators (rank 1 stays at zero).
+    assert torch.equal(
+        payload.token_counts[0],
+        torch.tensor([4, 0, 2, 0], dtype=torch.int64),
+    )
+    assert torch.equal(
+        payload.token_counts[1],
+        torch.zeros(n_experts, dtype=torch.int64),
+    )
diff --git a/tests/test_calibration_reap_scores_smoke.py b/tests/test_calibration_reap_scores_smoke.py
