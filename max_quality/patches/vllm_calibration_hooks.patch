@@ -0,0 +1,140 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Smoke tests for the L2 ``_CALIB_MAX_LAYER`` early-exit gate.
+
+These tests cover the calibration-side surface of L2:
+
+1. Module default: ``_CALIB_MAX_LAYER is None`` when the env var is unset
+   (the loop bound on the model side stays ``self.end_layer`` => byte-
+   identical to the unpatched forward).
+2. ``VLLM_CALIB_MAX_LAYER`` is sampled at import: setting it to ``"5"``
+   before importing the module yields ``_CALIB_MAX_LAYER == 5``.
+3. The literal env value ``"-1"`` and the empty string both map to
+   ``None`` (the "disabled" sentinel) so a launcher can clear the gate
+   by passing ``-1`` without unsetting the variable.
+4. Malformed env values (``"foo"``, ``"1.5"``) fall back to ``None``
+   rather than raising — a misconfigured env should not crash a run.
+5. Runtime ``set_calibration_max_layer(N)`` round-trips through
+   ``get_calibration_max_layer()``.
+6. ``set_calibration_max_layer(None)`` and ``set_calibration_max_layer(-1)``
+   both clear the gate.
+7. ``set_calibration_max_layer`` rejects non-int / non-None inputs with
+   ``TypeError`` (a string "5" is a bug, not a coerce).
+8. The early-exit math used by ``Qwen3MoeModel.forward`` matches the
+   spec: for a model with ``start_layer=0, end_layer=24``, setting
+   ``_CALIB_MAX_LAYER=0`` yields ``effective_end=1`` (one layer), and
+   ``_CALIB_MAX_LAYER=23`` yields ``effective_end=24`` (full forward).
+   Out-of-range values clamp to the model boundary.
+"""
+from __future__ import annotations
+
+import importlib
+import os
+import sys
+
+import pytest
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+
+def _reload_hooks(env_value: str | None):
+    """Reload ``vllm.calibration_hooks`` with a chosen ``VLLM_CALIB_MAX_LAYER``.
+
+    Passing ``None`` clears the env var so the import sees the unset state.
+    """
+    sys.modules.pop("vllm.calibration_hooks", None)
+    if env_value is None:
+        os.environ.pop("VLLM_CALIB_MAX_LAYER", None)
+    else:
+        os.environ["VLLM_CALIB_MAX_LAYER"] = env_value
+    return importlib.import_module("vllm.calibration_hooks")
+
+
+def _effective_end(
+    start_layer: int, end_layer: int, max_layer: int | None
+) -> int:
+    """Mirror the exact arithmetic used by ``Qwen3MoeModel.forward``."""
+    if max_layer is None:
+        return end_layer
+    return min(end_layer, max(start_layer, max_layer + 1))
+
+
+# ---------------------------------------------------------------------------
+# Tests
+# ---------------------------------------------------------------------------
+
+
+def test_default_max_layer_is_none():
+    ch = _reload_hooks(None)
+    assert ch._CALIB_MAX_LAYER is None
+    assert ch.get_calibration_max_layer() is None
+
+
+@pytest.mark.parametrize("env_value, expected", [("0", 0), ("5", 5), ("23", 23)])
+def test_env_value_is_sampled_at_import(env_value, expected):
+    ch = _reload_hooks(env_value)
+    assert ch._CALIB_MAX_LAYER == expected
+    assert ch.get_calibration_max_layer() == expected
+
+
+@pytest.mark.parametrize("env_value", ["", "-1", "-7"])
+def test_disabled_sentinels_map_to_none(env_value):
+    ch = _reload_hooks(env_value)
+    assert ch._CALIB_MAX_LAYER is None
+
+
+@pytest.mark.parametrize("env_value", ["foo", "1.5", "0x5", " "])
+def test_malformed_env_falls_back_to_none(env_value):
+    ch = _reload_hooks(env_value)
+    assert ch._CALIB_MAX_LAYER is None
+
+
+def test_runtime_setter_round_trip():
+    ch = _reload_hooks(None)
+    ch.set_calibration_max_layer(11)
+    assert ch._CALIB_MAX_LAYER == 11
+    assert ch.get_calibration_max_layer() == 11
+    ch.set_calibration_max_layer(0)
+    assert ch.get_calibration_max_layer() == 0
+
+
+def test_runtime_setter_clears_with_none_or_negative():
+    ch = _reload_hooks("5")
+    assert ch._CALIB_MAX_LAYER == 5
+    ch.set_calibration_max_layer(None)
+    assert ch._CALIB_MAX_LAYER is None
+    ch.set_calibration_max_layer(7)
+    assert ch._CALIB_MAX_LAYER == 7
+    ch.set_calibration_max_layer(-1)
+    assert ch._CALIB_MAX_LAYER is None
+    ch.set_calibration_max_layer(3)
+    ch.set_calibration_max_layer(-99)
+    assert ch._CALIB_MAX_LAYER is None
+
+
+@pytest.mark.parametrize("bad", ["5", 5.0, [5], (5,), object()])
+def test_runtime_setter_rejects_non_int(bad):
+    ch = _reload_hooks(None)
+    with pytest.raises(TypeError):
+        ch.set_calibration_max_layer(bad)
+    # And the gate stays at its previous value (None).
+    assert ch._CALIB_MAX_LAYER is None
+
+
+def test_effective_end_math_matches_forward_spec():
+    # Single-rank model: start_layer=0, end_layer=num_hidden_layers.
+    assert _effective_end(0, 24, None) == 24  # default -> full forward
+    assert _effective_end(0, 24, 0) == 1  # only layer 0 runs
+    assert _effective_end(0, 24, 5) == 6  # layers 0..5 (six layers)
+    assert _effective_end(0, 24, 23) == 24  # last legal layer == full
+    # Out-of-range clamps to model boundary (no IndexError, no underflow).
+    assert _effective_end(0, 24, 99) == 24
+    # Pipeline-parallel shard: start_layer=12, end_layer=24.
+    assert _effective_end(12, 24, None) == 24
+    assert _effective_end(12, 24, 15) == 16  # layers 12..15 on this shard
+    # A max_layer BELOW this shard's start collapses to running zero
+    # layers on the shard (still bounded by start_layer, never < it).
+    assert _effective_end(12, 24, 5) == 12  # islice(layers, 12, 12) => empty
