index 0000000..8505da3
--- /dev/null
+++ b/vllm/calibration_imatrix.py
@@ -0,0 +1,997 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Imatrix capture for llama.cpp-compatible activation statistics.
+
+This module accumulates per-input-channel squared-activation statistics
+(``Σ x_in[i]²``) for every linear layer reached during a calibration
+forward, then writes them out in the legacy ``.imatrix.dat`` binary format
+that ``llama-quantize`` consumes via its ``--imatrix`` flag.
+
+Activation surfaces covered
+---------------------------
+The hook surface is threefold and uses the **source-patch** dispatch path
+in :mod:`vllm.calibration_hooks` (no runtime class wrapping anywhere):
+
+* **Dense linear projections** — the three concrete ``LinearBase``
+  subclasses (``ReplicatedLinear``, ``ColumnParallelLinear``,
+  ``RowParallelLinear``) are source-patched in
+  ``vllm/model_executor/layers/linear.py`` to call
+  ``_ch.dispatch("linear_in", prefix=self.prefix, x=x.detach())`` at the
+  top of each ``forward``. ``QKVParallelLinear`` and
+  ``MergedColumnParallelLinear`` inherit ``ColumnParallelLinear.forward``
+  and therefore need no separate insertion. QKV-style prefixes are
+  demuxed at dump time into separate ``attn_q`` / ``attn_k`` / ``attn_v``
+  entries that share the same statistics (Q/K/V share post-layernorm
+  input).
+* **LM head input** — ``ParallelLMHead.forward`` is a ``raise
+  RuntimeError`` stub in vLLM v0.21 and is never actually invoked. The
+  real lm_head matmul lives in ``LogitsProcessor._get_logits`` which is
+  source-patched to dispatch ``lm_head_in`` immediately before the
+  ``lm_head.quant_method.apply(...)`` call. This module registers
+  :func:`_on_lm_head_in` to feed the final-hidden activations into the
+  ``output`` accumulator.
+* **MoE expert inputs** — the ``expert_in`` hook from
+  :mod:`vllm.calibration_hooks` (also a source-patch in the runner) is
+  registered; per-(token, top-k) hidden states are scatter-reduced per
+  expert into the ``ffn_gate_exps`` / ``ffn_up_exps`` accumulators
+  (which share the same input).
+* **MoE expert mid-activation** — the ``expert_mid`` hook source-patched
+  into ``TritonExperts.apply()`` (between the SwiGLU activation and the
+  down-projection quantize) surfaces the per-(token, top-k)
+  ``silu(gate)·up`` tensor needed for the ``ffn_down_exps`` imatrix
+  entry. This module registers :func:`_on_expert_mid` to scatter-reduce
+  that tensor per expert.
+
+Skipped surfaces:
+
+* ``token_embd`` (embedding lookup, not a linear layer; llama.cpp
+  imatrix files do not include it).
+
+Ephemeral-tensor contract
+-------------------------
+The source-patch sites read ``x`` synchronously before any downstream
+mutation; the accumulator update is an in-place ``add_`` into a
+callback-owned buffer. We never hold the original ``x`` past the
+dispatch return, so the same ephemeral-tensor contract documented in
+:mod:`vllm.calibration_hooks` applies transparently here.
+
+Performance contract
+--------------------
+``_IMATRIX_MIN_TOKENS`` (env var ``VLLM_CALIB_IMATRIX_MIN_TOKENS``,
+default 8) gates accumulation: when ``x.shape[0] < min_tokens`` the
+update is skipped. This filters single-token decode steps (which would
+multiply accumulator cost by ~one update per generated token) while
+keeping prefill batches and chunk-sized prefill micro-batches fully
+covered. The result is +1-2 minutes total overhead on a 5-hour
+calibration run vs +25-35 minutes without the guard.
+
+CUDA-graph compatibility
+------------------------
+``setup(llm)`` iterates ``model.named_modules()`` and pre-allocates the
+accumulator tensors for every ``LinearBase`` / ``ParallelLMHead`` /
+``FusedMoE`` instance BEFORE the first captured forward. This eliminates
+the lazy-alloc-during-capture risk that would otherwise produce a
+``CUDA error: operation not permitted when stream is capturing``.
+
+Known limitations
+-----------------
+1. ``token_embd`` is not captured (llama.cpp convention).
+2. Requires ``VLLM_CALIB_CAPTURE_EXPERT=1`` and
+   ``VLLM_CALIB_CAPTURE_EXPERT_MID=1`` to be set so the ``expert_in``
+   and ``expert_mid`` hooks in :mod:`vllm.calibration_hooks` dispatch;
+   the build script's ``--capture-imatrix`` flag sets all three.
+3. Requires the same ``cudagraph_num_of_warmups >= 1`` setting as the
+   existing patch's ``expert_out_unweighted`` path — first-touch
+   allocation must precede the captured forward.
+
+Env-var gating
+--------------
+Accumulation is active only when ``VLLM_CALIB_CAPTURE_IMATRIX=1`` AND
+this module is imported AND :func:`setup` registered the callbacks. The
+build script (``--capture-imatrix``) imports it lazily; vLLM itself
+never imports it, so the cost when the flag is off is exactly one extra
+module on the import path of the build script and nothing else. The
+source-patched dispatch sites themselves only test the module-level
+flag in :mod:`vllm.calibration_hooks` — when off, they are a single
+``LOAD_ATTR + POP_JUMP_IF_FALSE`` and incur no further cost.
+
+Output format
+-------------
+:func:`dump_imatrix` writes the legacy llama.cpp ``.dat`` binary format
+(NOT GGUF) since ``llama-quantize`` accepts both and ``.dat`` has zero
+external dependency::
+
+    int32 n_entries
+    for each entry:
+        int32 name_len
+        char[name_len] name
+        int32 ncall
+        int32 nval
+        float32[nval] values
+    int32 m_last_chunk
+    int32 dataset_len
+    char[dataset_len] dataset
+
+All little-endian.
+"""
+from __future__ import annotations
+
+import logging
+import os
+import re
+import struct
+from typing import Any, Callable
+
+import torch
+
+import vllm.calibration_hooks as _ch
+
+log = logging.getLogger(__name__)
+
+
+__all__ = [
+    "setup",
+    "dump_imatrix",
+    "dump_imatrix_checkpoint",
+    "load_imatrix_checkpoint",
+    "get_n_prompts_accumulated",
+    "set_n_prompts_accumulated",
+]
+
+
+# ---------------------------------------------------------------------------
+# Module-level flags. Sampled once at import.
+# ---------------------------------------------------------------------------
+_CAPTURE_IMATRIX: bool = (
+    os.getenv("VLLM_CALIB_CAPTURE_IMATRIX", "0") == "1"
+)
+_IMATRIX_MIN_TOKENS: int = int(
+    os.getenv("VLLM_CALIB_IMATRIX_MIN_TOKENS", "8")
+)
+
+
+# ---------------------------------------------------------------------------
+# Accumulator state. ``_accumulators`` holds the running Σ(x²) for dense
+# layers (key = GGUF name). ``_token_counts`` holds the corresponding token
+# count for the ``ncall`` field of the legacy .dat format.
+#
+# MoE expert accumulators are kept separately because they require per-
+# expert scatter-reduce (one row per expert): the storage is
+# ``[n_experts, hidden]`` (or ``[n_experts, intermediate]`` for the
+# down-projection input) and the corresponding ``*_token_counts_per_expert``
+# tensors are ``[n_experts]`` int64.
+# ---------------------------------------------------------------------------
+_accumulators: dict[str, torch.Tensor] = {}
+_token_counts: dict[str, int] = {}
+_moe_accumulators: dict[str, torch.Tensor] = {}
+_moe_token_counts_per_expert: dict[str, torch.Tensor] = {}
+_moe_down_accumulators: dict[str, torch.Tensor] = {}
+_moe_down_token_counts_per_expert: dict[str, torch.Tensor] = {}
+_N_EXPERTS: int | None = None
+
+# Map from module-prefix (e.g. "model.layers.3.self_attn.qkv_proj") to its
+# pre-allocated accumulator key(s). Populated by ``setup(llm)``.
+_prefix_to_keys: dict[str, list[str]] = {}
+
+# ---------------------------------------------------------------------------
+# Spot-preemption resumability (added in calib-v2-imatrix-resumable).
+#
+# ``_n_prompts_accumulated`` is the cumulative count of prompts whose
+# activations have been folded into the accumulators above, across ALL
+# instance lifetimes (it survives ``load_imatrix_checkpoint``). The driver
+# updates it at each chunk boundary; ``dump_imatrix`` reads it for the
+# ``m_last_chunk`` field of the final .dat file.
+#
+# Callbacks do NOT touch this counter — they see tokens / sub-batches and
+# can't tell which (token, slot) pair belongs to which prompt without an
+# extra round-trip from the driver. Keeping the counter driver-owned avoids
+# the bookkeeping ambiguity.
+# ---------------------------------------------------------------------------
+_n_prompts_accumulated: int = 0
+
+# Bump on incompatible changes to the .imatrix.ckpt dict layout; the loader
+# raises ValueError on schema mismatch so a stale checkpoint can't silently
+# corrupt the accumulators.
+_CHECKPOINT_SCHEMA_VERSION: int = 1
+
+
+# ---------------------------------------------------------------------------
+# Name mapping: vLLM module prefix → GGUF tensor name(s)
+# ---------------------------------------------------------------------------
+# Compiled regexes for the vLLM-prefix → GGUF-name conversion. Each entry is
+# (compiled regex, callable(match) -> list[str]). The callable returns a
+# list because QKV demuxes into three entries.
+
+_NAME_RULES: list[tuple[re.Pattern, Callable[[re.Match], list[str]]]] = [
+    # Attention QKV: demuxed into three entries that share the same input
+    # statistics. Pattern matches both standard naming and prefixed naming.
+    (
+        re.compile(r".*?layers\.(\d+)\.self_attn\.qkv_proj$"),
+        lambda m: [
+            f"blk.{m.group(1)}.attn_q",
+            f"blk.{m.group(1)}.attn_k",
+            f"blk.{m.group(1)}.attn_v",
+        ],
+    ),
+    # Attention output projection.
+    (
+        re.compile(r".*?layers\.(\d+)\.self_attn\.o_proj$"),
+        lambda m: [f"blk.{m.group(1)}.attn_output"],
+    ),
+    # MoE router gate.
+    (
+        re.compile(r".*?layers\.(\d+)\.mlp\.gate$"),
+        lambda m: [f"blk.{m.group(1)}.ffn_gate_inp"],
+    ),
+    # Shared-expert gate_up_proj (Qwen3-MoE-style fused gate+up).
+    (
+        re.compile(r".*?layers\.(\d+)\.mlp\.shared_expert\.gate_up_proj$"),
+        lambda m: [
+            f"blk.{m.group(1)}.ffn_gate_shexp",
+            f"blk.{m.group(1)}.ffn_up_shexp",
+        ],
+    ),
+    # Shared-expert down_proj.
+    (
+        re.compile(r".*?layers\.(\d+)\.mlp\.shared_expert\.down_proj$"),
+        lambda m: [f"blk.{m.group(1)}.ffn_down_shexp"],
+    ),
+    # Dense MLP gate_up_proj (non-MoE layers, fallback).
+    (
+        re.compile(r".*?layers\.(\d+)\.mlp\.gate_up_proj$"),
+        lambda m: [
+            f"blk.{m.group(1)}.ffn_gate",
+            f"blk.{m.group(1)}.ffn_up",
+        ],
+    ),
+    # Dense MLP down_proj (non-MoE layers, fallback).
+    (
+        re.compile(r".*?layers\.(\d+)\.mlp\.down_proj$"),
+        lambda m: [f"blk.{m.group(1)}.ffn_down"],
+    ),
+    # LM head (handled via the lm_head_in source-patch in
+    # LogitsProcessor._get_logits, but include here for completeness — the
+    # caller may pre-populate from named_modules()).
+    (
+        re.compile(r"(?:^|.*\.)lm_head$"),
+        lambda m: ["output"],
+    ),
+]
+
+
+def _vllm_prefix_to_gguf_name(prefix: str) -> list[str]:
+    """Map a vLLM module FQN prefix to one or more GGUF tensor names.
+
+    Returns an empty list if the prefix does not match any known rule
+    (e.g. ``model.layers.3.mlp.experts.w13_weight`` -- handled via the
+    expert_in / expert_mid hooks, not the dense linear source-patch).
+    """
+    for pat, fn in _NAME_RULES:
+        m = pat.match(prefix)
+        if m is not None:
+            return fn(m)
+    return []
+
+
+# ---------------------------------------------------------------------------
+# Accumulator update primitives
+# ---------------------------------------------------------------------------
+
+
+def _imatrix_accumulate_linear(prefix: str, x: torch.Tensor) -> None:
+    """Update Σ(x²) for every accumulator key associated with ``prefix``.
+
+    Called from the source-patched dispatch sites in
+    ``vllm/model_executor/layers/linear.py`` (and from
+    :func:`_on_lm_head_in` for the pseudo-prefix ``"__lm_head__"``). The
+    flatten-to-2D pattern matches how llama.cpp's imatrix tool sums
+    activations: every leading dim is collapsed into the "token" axis.
+    """
+    if not _CAPTURE_IMATRIX:
+        return
+    keys = _prefix_to_keys.get(prefix)
+    if not keys:
+        return
+    # Flatten any leading dims into a 2D matrix (n_tok, in_features).
+    if x.dim() > 2:
+        x2 = x.reshape(-1, x.shape[-1])
+    else:
+        x2 = x
+    n_tok = x2.shape[0]
+    if n_tok < _IMATRIX_MIN_TOKENS:
+        return
+    # In-place fp32 square-sum, all keys share the same statistic (QKV).
+    sq = x2.to(torch.float32).pow(2).sum(dim=0)
+    for k in keys:
+        acc = _accumulators.get(k)
+        if acc is None:
+            # Late allocation guard: if a prefix appears for the first
+            # time outside setup(), allocate on the spot. This avoids
+            # crashing during a run if a layer was missed by the static
+            # scan; the cost of one allocation is negligible.
+            acc = torch.zeros_like(sq)
+            _accumulators[k] = acc
+            _token_counts[k] = 0
+        acc.add_(sq)
+        _token_counts[k] = _token_counts.get(k, 0) + n_tok
+
+
+# ---------------------------------------------------------------------------
+# Callbacks registered with vllm.calibration_hooks
+# ---------------------------------------------------------------------------
+
+
+def _on_linear_in(prefix: str, x: torch.Tensor, **_: Any) -> None:
+    """Callback for the ``linear_in`` source-patched dispatch.
+
+    Thin wrapper that forwards to :func:`_imatrix_accumulate_linear`.
+    The accumulator state and min-token gate live there.
+    """
+    _imatrix_accumulate_linear(prefix, x)
+
+
+def _on_lm_head_in(x: torch.Tensor, **_: Any) -> None:
+    """Callback for the ``lm_head_in`` source-patched dispatch.
+
+    Always feeds the ``output`` accumulator under the fixed pseudo-prefix
+    ``"__lm_head__"`` because lm_head naming varies across models but
+    llama.cpp's GGUF always uses the literal name ``output``.
+    """
+    _imatrix_accumulate_linear("__lm_head__", x)
+
+
+def _on_expert_in(layer_idx: int, hidden_states: torch.Tensor,
+                  topk_ids: torch.Tensor, **_: Any) -> None:
+    """Scatter-reduce per-expert squared inputs into the MoE accumulators.
+
+    Registered with :mod:`vllm.calibration_hooks` as the ``expert_in``
+    callback. ``hidden_states`` is ``[n_tok, hidden]`` and ``topk_ids`` is
+    ``[n_tok, top_k]``. For each expert ``e``, we sum ``x²`` across all
+    tokens whose top-k routing includes ``e``.
+
+    The accumulator key uses the same ``blk.{i}.ffn_*_exps`` prefix that
+    llama.cpp expects.
+    """
+    if _N_EXPERTS is None:
+        return
+    n_tok = hidden_states.shape[0]
+    if n_tok < _IMATRIX_MIN_TOKENS:
+        return
+    x_sq = hidden_states.to(torch.float32).pow(2)  # [n_tok, hidden]
+    # ffn_gate_exps and ffn_up_exps share input -- same accumulator twice.
+    for gguf_suffix in ("ffn_gate_exps", "ffn_up_exps"):
+        key = f"blk.{layer_idx}.{gguf_suffix}"
+        acc = _moe_accumulators.get(key)
+        tok_cnt = _moe_token_counts_per_expert.get(key)
+        if acc is None or tok_cnt is None:
+            acc = torch.zeros(
+                _N_EXPERTS, hidden_states.shape[-1],
+                device=hidden_states.device, dtype=torch.float32,
+            )
+            tok_cnt = torch.zeros(
+                _N_EXPERTS, device=hidden_states.device, dtype=torch.int64,
+            )
+            _moe_accumulators[key] = acc
+            _moe_token_counts_per_expert[key] = tok_cnt
+        # For each expert e, mask tokens whose any-top-k slot == e.
+        for e in range(_N_EXPERTS):
+            mask = (topk_ids == e).any(dim=1)
+            n_assigned = int(mask.sum().item())
+            if n_assigned == 0:
+                continue
+            acc[e].add_(x_sq[mask].sum(dim=0))
+            tok_cnt[e] += n_assigned
+
+
+def _on_expert_mid(layer_idx: int, intermediate: torch.Tensor,
+                   topk_ids: torch.Tensor, **_: Any) -> None:
+    """Scatter-reduce per-expert mid-activation Σ(x²) for ffn_down_exps.
+
+    Registered with :mod:`vllm.calibration_hooks` as the ``expert_mid``
+    callback. ``intermediate`` is ``[n_tok, top_k, intermediate_dim]`` --
+    the post-SwiGLU pre-quantize tensor that feeds the down projection.
+    ``topk_ids`` is ``[n_tok, top_k]``. For each (token, slot) pair
+    assigned to expert ``e``, we add ``intermediate[t, k]²`` into the
+    expert-``e`` row.
+
+    Note: this hook uses the (token, slot) accounting axis rather than
+    the per-expert any-top-k mask used by :func:`_on_expert_in`. Each
+    (token, slot) pair maps to exactly one expert, so the scatter is
+    unambiguous and the per-expert token count matches the number of
+    routing assignments seen by that expert (NOT the number of distinct
+    tokens). This is the correct denominator for the down-projection
+    input statistic because the kernel computes one down_proj matmul per
+    (token, slot) pair.
+    """
+    if _N_EXPERTS is None:
+        return
+    n_tok = intermediate.shape[0]
+    if n_tok < _IMATRIX_MIN_TOKENS:
+        return
+    intermediate_dim = intermediate.shape[-1]
+    key = f"blk.{layer_idx}.ffn_down_exps"
+    acc = _moe_down_accumulators.get(key)
+    tok_cnt = _moe_down_token_counts_per_expert.get(key)
+    if acc is None or tok_cnt is None:
+        acc = torch.zeros(
+            _N_EXPERTS, intermediate_dim,
+            device=intermediate.device, dtype=torch.float32,
+        )
+        tok_cnt = torch.zeros(
+            _N_EXPERTS, device=intermediate.device, dtype=torch.int64,
+        )
+        _moe_down_accumulators[key] = acc
+        _moe_down_token_counts_per_expert[key] = tok_cnt
+    # [n_tok, top_k, intermediate] squared in fp32.
+    x_sq = intermediate.to(torch.float32).pow(2)
+    # Per-expert assignment: each (t, k) pair maps to exactly one expert.
+    flat_ids = topk_ids.reshape(-1)                 # [n_tok * top_k]
+    flat_sq = x_sq.reshape(-1, intermediate_dim)    # [n_tok * top_k, intd]
+    for e in range(_N_EXPERTS):
+        mask = (flat_ids == e)
+        n_assigned = int(mask.sum().item())
+        if n_assigned == 0:
+            continue
+        acc[e].add_(flat_sq[mask].sum(dim=0))
+        tok_cnt[e] += n_assigned
+
+
+# ---------------------------------------------------------------------------
+# Public API
+# ---------------------------------------------------------------------------
+
+
+def setup(llm: Any) -> None:
+    """Pre-allocate accumulators and register callbacks before CUDA graph capture.
+
+    Iterates ``model.named_modules()`` for every ``LinearBase`` (or
+    ``ParallelLMHead``) instance and pre-allocates a zero-filled fp32
+    accumulator on the layer's device. For each MoE layer it also pre-
+    allocates the per-expert ``ffn_gate_exps`` / ``ffn_up_exps`` /
+    ``ffn_down_exps`` accumulators. This avoids the lazy-alloc-during-
+    CUDA-graph-capture pitfall.
+
+    Also discovers ``_N_EXPERTS`` from the first MoE layer it finds and
+    sets the module-level constant for the expert_in / expert_mid
+    callbacks. Finally registers all four callbacks with
+    :mod:`vllm.calibration_hooks`.
+
+    Idempotent: calling twice does not double-allocate (accumulators that
+    already exist are left untouched) and re-registering callbacks is a
+    safe overwrite to the same handler.
+
+    Args:
+        llm: A vLLM ``LLM`` instance. The wrapped model is found via
+            ``llm.llm_engine.model_executor.driver_worker.model_runner.model``
+            in current vLLM v0.21; we use ``hasattr`` lookups to stay
+            forward-compatible.
+    """
+    global _N_EXPERTS
+    if not _CAPTURE_IMATRIX:
+        return
+
+    model = _resolve_model(llm)
+    if model is None:
+        log.warning(
+            "calibration_imatrix: could not resolve model from LLM "
+            "instance; accumulators will be lazily allocated at first "
+            "forward (CUDA-graph risk)."
+        )
+        return
+
+    from vllm.model_executor.layers.linear import LinearBase
+    from vllm.model_executor.layers.vocab_parallel_embedding import (
+        ParallelLMHead,
+    )
+
+    n_linear = 0
+    n_skipped = 0
+    for name, module in model.named_modules():
+        if isinstance(module, ParallelLMHead):
+            # lm_head uses a fixed pseudo-prefix because the GGUF tensor
+            # name is always "output" regardless of vLLM's naming.
+            keys = ["output"]
+            _prefix_to_keys["__lm_head__"] = keys
+            # Allocate on the layer's device using a sample weight as
+            # device hint.
+            device = next(module.parameters()).device
+            in_features = module.embedding_dim
+            for k in keys:
+                if k not in _accumulators:
+                    _accumulators[k] = torch.zeros(
+                        in_features, device=device, dtype=torch.float32,
+                    )
+                    _token_counts[k] = 0
+            n_linear += 1
+            continue
+        if isinstance(module, LinearBase):
+            prefix = getattr(module, "prefix", name)
+            if not prefix:
+                prefix = name
+            keys = _vllm_prefix_to_gguf_name(prefix)
+            if not keys:
+                n_skipped += 1
+                continue
+            _prefix_to_keys[prefix] = keys
+            device = next(module.parameters()).device
+            in_features = module.input_size
+            for k in keys:
+                if k not in _accumulators:
+                    _accumulators[k] = torch.zeros(
+                        in_features, device=device,
+                        dtype=torch.float32,
+                    )
+                    _token_counts[k] = 0
+            n_linear += 1
+
+    # Discover MoE expert count + pre-allocate per-expert accumulators.
+    # Look for a FusedMoE-style attribute on any module named ``...experts``.
+    # We walk ALL MoE layers (not just the first) so every block's
+    # ffn_*_exps accumulator is pre-built before CUDA-graph capture.
+    n_moe_layers = 0
+    moe_re = re.compile(r".*?layers\.(\d+)\.mlp\.experts$")
+    for name, module in model.named_modules():
+        n_exp = getattr(module, "num_experts", None)
+        if not (isinstance(n_exp, int) and n_exp > 0):
+            continue
+        m = moe_re.match(name)
+        if m is None:
+            continue
+        if _N_EXPERTS is None:
+            _N_EXPERTS = n_exp
+            log.info(
+                "calibration_imatrix: detected %d MoE experts (from %r)",
+                n_exp, name,
+            )
+        elif _N_EXPERTS != n_exp:
+            log.warning(
+                "calibration_imatrix: MoE expert count mismatch at %s "
+                "(%d vs first-seen %d); using the first value for "
+                "pre-allocation, late-alloc guard will handle the rest.",
+                name, n_exp, _N_EXPERTS,
+            )
+
+        layer_idx = int(m.group(1))
+        device = next(module.parameters()).device
+        # Derive shapes from the canonical FusedMoE weight tensors:
+        #   w13_weight: [n_experts, 2 * intermediate, hidden]
+        #   w2_weight : [n_experts, hidden, intermediate]
+        # We prefer w13_weight.shape[-1] for the gate/up input width and
+        # w2_weight.shape[-1] for the down-proj input (= intermediate).
+        w13 = getattr(module, "w13_weight", None)
+        w2 = getattr(module, "w2_weight", None)
+        if w13 is None or w2 is None:
+            # No standard FusedMoE weights -- fall back to the late-alloc
+            # guard inside the callbacks.
+            continue
+        hidden_dim = int(w13.shape[-1])
+        intermediate_dim = int(w2.shape[-1])
+        for gguf_suffix in ("ffn_gate_exps", "ffn_up_exps"):
+            key = f"blk.{layer_idx}.{gguf_suffix}"
+            if key not in _moe_accumulators:
+                _moe_accumulators[key] = torch.zeros(
+                    n_exp, hidden_dim,
+                    device=device, dtype=torch.float32,
+                )
+                _moe_token_counts_per_expert[key] = torch.zeros(
+                    n_exp, device=device, dtype=torch.int64,
+                )
+        down_key = f"blk.{layer_idx}.ffn_down_exps"
+        if down_key not in _moe_down_accumulators:
+            _moe_down_accumulators[down_key] = torch.zeros(
+                n_exp, intermediate_dim,
+                device=device, dtype=torch.float32,
+            )
+            _moe_down_token_counts_per_expert[down_key] = torch.zeros(
+                n_exp, device=device, dtype=torch.int64,
+            )
+        n_moe_layers += 1
+
+    # Register the callbacks against the source-patched dispatch sites.
+    # This is the ONLY hook installation path -- no class wrapping anywhere.
+    _ch.register_callback("linear_in", _on_linear_in)
+    _ch.register_callback("lm_head_in", _on_lm_head_in)
+    _ch.register_callback("expert_in", _on_expert_in)
+    _ch.register_callback("expert_mid", _on_expert_mid)
+
+    log.info(
+        "calibration_imatrix: pre-allocated %d dense accumulators "
+        "(%d linear modules skipped as un-mapped), %d MoE layers; "
+        "N_EXPERTS=%s, min_tokens=%d; callbacks registered for "
+        "linear_in / lm_head_in / expert_in / expert_mid.",
+        n_linear, n_skipped, n_moe_layers, _N_EXPERTS, _IMATRIX_MIN_TOKENS,
+    )
+
+
+def _resolve_model(llm: Any) -> Any | None:
+    """Walk a few well-known attribute paths to find the live nn.Module."""
+    candidates = [
+        ("llm_engine", "model_executor", "driver_worker", "model_runner",
+         "model"),
+        ("llm_engine", "model_executor", "model_runner", "model"),
+        ("model_executor", "driver_worker", "model_runner", "model"),
+        ("model_runner", "model"),
+    ]
+    for path in candidates:
+        obj: Any = llm
+        ok = True
+        for attr in path:
+            obj = getattr(obj, attr, None)
+            if obj is None:
+                ok = False
+                break
+        if ok:
+            return obj
+    return None
+
+
+def dump_imatrix(path: str, chunk_count: int) -> None:
+    """Write the accumulated statistics to a llama.cpp ``.dat`` file.
+
+    ``chunk_count`` becomes the ``m_last_chunk`` field. The legacy format
+    consumers don't enforce it; we pass ``total_prompts_processed`` so the
+    file metadata reflects calibration scale.
+
+    All entry kinds (dense, ``ffn_*_exps``, and ``ffn_down_exps``) write
+    real running-mean statistics. The ``ffn_down_exps`` entries source
+    from :func:`_on_expert_mid` (the ``expert_mid`` callback) -- if for
+    some reason ``VLLM_CALIB_CAPTURE_EXPERT_MID=0`` was set and the
+    accumulator was never populated, the missing entry is logged at WARN
+    and skipped.
+
+    Args:
+        path: Output filepath. Conventionally ends in ``.imatrix.dat``.
+        chunk_count: Number of calibration "chunks" (prompts) used to
+            compute the statistics. Recorded in the ``m_last_chunk``
+            field for downstream traceability.
+    """
+    if not _CAPTURE_IMATRIX:
+        log.warning(
+            "dump_imatrix called but VLLM_CALIB_CAPTURE_IMATRIX is off; "
+            "no accumulators present."
+        )
+        return
+
+    entries: list[tuple[str, int, torch.Tensor]] = []
+
+    # Dense accumulators.
+    for name, acc in _accumulators.items():
+        ncall = int(_token_counts.get(name, 0))
+        # llama.cpp's imatrix tool normalises by token count when storing;
+        # the legacy .dat format stores the running mean (sum / ncall).
+        if ncall > 0:
+            values = (acc / float(ncall)).detach().to("cpu",
+                                                        dtype=torch.float32)
+        else:
+            values = acc.detach().to("cpu", dtype=torch.float32)
+        entries.append((name, ncall, values))
+
+    # MoE expert input accumulators (ffn_gate_exps / ffn_up_exps):
+    # flatten [n_experts, hidden] -> single contiguous fp32 vector of
+    # length n_experts * hidden, normalised per-expert by its own count.
+    for name, acc in _moe_accumulators.items():
+        tok_cnt = _moe_token_counts_per_expert.get(name)
+        if tok_cnt is None:
+            continue
+        # ncall = max over experts (closest to what llama.cpp reports).
+        ncall = int(tok_cnt.max().item()) if tok_cnt.numel() > 0 else 0
+        # Per-expert mean: divide each row by its own count, guarding
+        # against zero-routing experts.
+        safe_cnt = tok_cnt.clamp(min=1).to(torch.float32).unsqueeze(-1)
+        mean_per_expert = acc / safe_cnt
+        values = mean_per_expert.flatten().detach().to(
+            "cpu", dtype=torch.float32,
+        )
+        entries.append((name, ncall, values))
+
+    # MoE expert mid-activation accumulators (ffn_down_exps): real
+    # running mean of Σ(silu(gate)·up)² per expert sourced from the
+    # ``expert_mid`` hook. Replaces the v1 uniform-ones placeholder.
+    seen_down_keys: set[str] = set()
+    for name, acc in _moe_down_accumulators.items():
+        tok_cnt = _moe_down_token_counts_per_expert.get(name)
+        if tok_cnt is None:
+            continue
+        ncall = int(tok_cnt.max().item()) if tok_cnt.numel() > 0 else 0
+        safe_cnt = tok_cnt.clamp(min=1).to(torch.float32).unsqueeze(-1)
+        mean_per_expert = acc / safe_cnt
+        values = mean_per_expert.flatten().detach().to(
+            "cpu", dtype=torch.float32,
+        )
+        entries.append((name, ncall, values))
+        seen_down_keys.add(name)
+
+    # Fallback warning: every ffn_gate_exps entry should have a matching
+    # ffn_down_exps entry. If not (which can only happen if
+    # VLLM_CALIB_CAPTURE_EXPERT_MID was disabled), surface a WARN so the
+    # downstream llama-quantize step gets a heads-up. The entry is simply
+    # omitted -- llama-quantize tolerates missing imatrix rows.
+    for name in _moe_accumulators:
+        if not name.endswith(".ffn_gate_exps"):
+            continue
+        down_name = name.replace("ffn_gate_exps", "ffn_down_exps")
+        if down_name in seen_down_keys:
+            continue
+        log.warning(
+            "calibration_imatrix: %s not populated; the expert_mid "
+            "hook was disabled (VLLM_CALIB_CAPTURE_EXPERT_MID=0) or "
+            "the FusedMoE forward never reached the source-patched "
+            "TritonExperts.apply path. The entry will be omitted from "
+            "the .imatrix.dat output.",
+            down_name,
+        )
+
+    _write_dat(path, entries, chunk_count, dataset="vllm-self-traces")
+    log.info(
+        "calibration_imatrix: wrote %d entries to %s (chunk_count=%d)",
+        len(entries), path, chunk_count,
+    )
+
+
+def _write_dat(
+    path: str,
+    entries: list[tuple[str, int, torch.Tensor]],
+    chunk_count: int,
+    dataset: str = "vllm-self-traces",
+) -> None:
+    """Write the legacy llama.cpp .imatrix.dat binary format.
+
+    Format (all little-endian, no padding):
+
+        int32 n_entries
+        for each entry:
+            int32 name_len
+            char[name_len] name (utf-8, no NUL terminator)
+            int32 ncall
+            int32 nval
+            float32[nval] values
+        int32 m_last_chunk
+        int32 dataset_len
+        char[dataset_len] dataset
+
+    Atomicity: writes to ``path + ".tmp"`` then ``os.replace(tmp, path)``
+    so a kill mid-write leaves any previous version of ``path`` intact.
+    """
+    tmp = path + ".tmp"
+    with open(tmp, "wb") as f:
+        f.write(struct.pack("<i", len(entries)))
+        for name, ncall, values in entries:
+            name_b = name.encode("utf-8")
+            f.write(struct.pack("<i", len(name_b)))
+            f.write(name_b)
+            f.write(struct.pack("<i", int(ncall)))
+            f.write(struct.pack("<i", int(values.numel())))
+            f.write(values.contiguous().numpy().tobytes())
+        f.write(struct.pack("<i", int(chunk_count)))
+        dataset_b = dataset.encode("utf-8")
+        f.write(struct.pack("<i", len(dataset_b)))
+        f.write(dataset_b)
+        f.flush()
+        os.fsync(f.fileno())
+    os.replace(tmp, path)
+    _dir_fd = os.open(os.path.dirname(path) or ".", os.O_RDONLY)
+    try:
+        os.fsync(_dir_fd)
+    except OSError:
+        pass
+    finally:
+        os.close(_dir_fd)
+
+
+# ---------------------------------------------------------------------------
+# Checkpoint / resume primitives (added in calib-v2-imatrix-resumable).
+# ---------------------------------------------------------------------------
+
+
+def get_n_prompts_accumulated() -> int:
+    """Read-only accessor for the cumulative prompt counter.
+
+    The counter is updated by :func:`set_n_prompts_accumulated` (driver
+    side) and persisted by :func:`dump_imatrix_checkpoint`. It is the
+    canonical source of truth for the ``m_last_chunk`` field passed to
+    :func:`dump_imatrix` at end-of-run.
+    """
+    return _n_prompts_accumulated
+
+
+def set_n_prompts_accumulated(n: int) -> None:
+    """Update the cumulative prompt counter.
+
+    Called by the driver (``build_self_traces_calib_vllm.py``) after each
+    chunked ``LLM.generate`` returns. Tracking is driver-owned because the
+    accumulator callbacks see tokens / sub-batches, not prompt boundaries.
+
+    Args:
+        n: Total prompts whose activations are now folded into the
+           accumulators. MUST be monotonically non-decreasing across calls
+           within one run.
+
+    Raises:
+        ValueError: if ``n < 0``.
+    """
+    global _n_prompts_accumulated
+    if n < 0:
+        raise ValueError(
+            f"n_prompts_accumulated must be >= 0; got {n}"
+        )
+    _n_prompts_accumulated = int(n)
+
+
+def dump_imatrix_checkpoint(path: str) -> None:
+    """Atomically write live accumulator state to ``path`` (.imatrix.ckpt).
+
+    Format: ``torch.save`` of a single dict with stable keys keyed off
+    :data:`_CHECKPOINT_SCHEMA_VERSION`. Tensors are moved to CPU + fp32
+    (or int64 for counts) so the checkpoint is device-agnostic — one
+    dumped on an H200 can be hydrated on an RTX 6000 Pro.
+
+    Atomicity: writes to ``path + ".tmp"`` then ``os.replace(tmp, path)``.
+    A kill mid-write leaves the previous version of ``path`` intact
+    (only ``.tmp`` is partial). This pairs with the atomic write in
+    :func:`_write_dat` so neither the periodic checkpoint nor the final
+    .dat can corrupt their respective committed files.
+
+    Pre-step: ``torch.cuda.synchronize()`` so any in-flight accumulator
+    updates from CUDA-graph-captured forwards are visible before we
+    snapshot them. Vllm joins streams at the request boundary, so this
+    is belt-and-suspenders insurance with negligible cost.
+
+    No-op if ``VLLM_CALIB_CAPTURE_IMATRIX`` is off (matches
+    :func:`dump_imatrix` semantics — callers don't have to gate).
+
+    Args:
+        path: Output path, conventionally ``<jsonl>.imatrix.ckpt``.
+    """
+    if not _CAPTURE_IMATRIX:
+        return
+    if torch.cuda.is_available():
+        torch.cuda.synchronize()
+
+    payload = {
+        "schema_version": _CHECKPOINT_SCHEMA_VERSION,
+        "n_prompts_accumulated": _n_prompts_accumulated,
+        "n_experts": _N_EXPERTS,
+        "prefix_to_keys": dict(_prefix_to_keys),
+        "accumulators": {
+            k: v.detach().to("cpu", dtype=torch.float32, copy=True)
+            for k, v in _accumulators.items()
+        },
+        "token_counts": dict(_token_counts),
+        "moe_accumulators": {
+            k: v.detach().to("cpu", dtype=torch.float32, copy=True)
+            for k, v in _moe_accumulators.items()
+        },
+        "moe_token_counts_per_expert": {
+            k: v.detach().to("cpu", dtype=torch.int64, copy=True)
+            for k, v in _moe_token_counts_per_expert.items()
+        },
+        "moe_down_accumulators": {
+            k: v.detach().to("cpu", dtype=torch.float32, copy=True)
+            for k, v in _moe_down_accumulators.items()
+        },
+        "moe_down_token_counts_per_expert": {
+            k: v.detach().to("cpu", dtype=torch.int64, copy=True)
+            for k, v in _moe_down_token_counts_per_expert.items()
+        },
+    }
+    tmp = path + ".tmp"
+    with open(tmp, "wb") as f:
+        torch.save(payload, f)
+        f.flush()
+        os.fsync(f.fileno())
+    os.replace(tmp, path)
+    _dir_fd = os.open(os.path.dirname(path) or ".", os.O_RDONLY)
+    try:
+        os.fsync(_dir_fd)
+    except OSError:
+        pass
+    finally:
+        os.close(_dir_fd)
+
+
+def load_imatrix_checkpoint(path: str) -> int:
+    """Hydrate accumulators from a previous run's checkpoint file.
+
+    Returns the cumulative ``n_prompts_accumulated`` value loaded from
+    the file so the caller knows how many prompts had already been
+    counted (and therefore how many remain to do). Returns ``0`` if
+    ``path`` does not exist (cold-start; non-error).
+
+    Tensors are placed on the same device + dtype as the corresponding
+    pre-allocated accumulator (which :func:`setup` populates from the
+    live model). The in-place ``.copy_()`` preserves the buffer that
+    CUDA-graph capture pinned. For keys NOT in the live dict (e.g. the
+    checkpoint was dumped by a different vLLM build that exposed extra
+    modules), the tensor is added on CPU; the next callback invocation
+    for that prefix will migrate it.
+
+    The cumulative ``_n_prompts_accumulated`` is restored so subsequent
+    chunks add to it rather than restarting from zero.
+
+    Args:
+        path: Input path, conventionally ``<jsonl>.imatrix.ckpt``.
+
+    Returns:
+        The ``n_prompts_accumulated`` value from the checkpoint, or 0
+        if no checkpoint file exists at ``path``.
+
+    Raises:
+        ValueError: on schema_version mismatch (delete the stale
+            checkpoint to restart from scratch).
+    """
+    global _N_EXPERTS, _n_prompts_accumulated
+
+    if not os.path.exists(path):
+        log.info(
+            "calibration_imatrix: no checkpoint at %s; cold start.", path,
+        )
+        return 0
+
+    payload = torch.load(path, map_location="cpu", weights_only=False)
+    schema = int(payload.get("schema_version", 0))
+    if schema != _CHECKPOINT_SCHEMA_VERSION:
+        raise ValueError(
+            f"calibration_imatrix: checkpoint {path} has schema_version "
+            f"{schema}, expected {_CHECKPOINT_SCHEMA_VERSION}. Delete the "
+            f"checkpoint to restart from scratch."
+        )
+    loaded_n = int(payload["n_prompts_accumulated"])
+
+    if _N_EXPERTS is None and payload.get("n_experts") is not None:
+        _N_EXPERTS = int(payload["n_experts"])
+
+    for prefix, keys in payload.get("prefix_to_keys", {}).items():
+        _prefix_to_keys.setdefault(prefix, list(keys))
+
+    def _hydrate_tensor_dict(
+        target: dict[str, torch.Tensor],
+        source: dict[str, torch.Tensor],
+        dtype: torch.dtype,
+    ) -> None:
+        for key, tensor in source.items():
+            existing = target.get(key)
+            if existing is not None:
+                # Preserve the pre-allocated buffer that CUDA-graph capture
+                # pinned: copy in-place into the existing tensor's device.
+                existing.copy_(tensor.to(existing.device, dtype=dtype))
+            else:
+                # Not pre-allocated -- accept on CPU; the first callback
+                # invocation for this key will migrate it on demand.
+                target[key] = tensor.to(dtype=dtype).clone()
+
+    _hydrate_tensor_dict(
+        _accumulators, payload.get("accumulators", {}), torch.float32,
+    )
+    for k, v in payload.get("token_counts", {}).items():
+        _token_counts[k] = int(v)
+    _hydrate_tensor_dict(
+        _moe_accumulators, payload.get("moe_accumulators", {}),
+        torch.float32,
+    )
+    _hydrate_tensor_dict(
+        _moe_token_counts_per_expert,
+        payload.get("moe_token_counts_per_expert", {}),
+        torch.int64,
+    )
+    _hydrate_tensor_dict(
+        _moe_down_accumulators,
+        payload.get("moe_down_accumulators", {}),
+        torch.float32,
+    )
+    _hydrate_tensor_dict(
+        _moe_down_token_counts_per_expert,
+        payload.get("moe_down_token_counts_per_expert", {}),
+        torch.int64,
+    )
+
+    _n_prompts_accumulated = loaded_n
+    log.info(
+        "calibration_imatrix: hydrated checkpoint from %s "
+        "(%d prompts; %d dense + %d moe_exp_in + %d moe_exp_down "
+        "accumulators)",
+        path, loaded_n,
+        len(payload.get("accumulators", {})),
+        len(payload.get("moe_accumulators", {})),
+        len(payload.get("moe_down_accumulators", {})),
+    )
+    return loaded_n
