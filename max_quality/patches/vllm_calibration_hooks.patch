@@ -0,0 +1,392 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Calibration capture hooks for the MoE forward path.
+
+This module exposes a tiny callback-registry + dispatch API that the MoE
+forward code uses to surface intermediate tensors during a calibration run
+(e.g. for building expert importance / routing statistics or for training a
+distilled approximate router).
+
+Eight hooks are defined. Each hook is gated by a dedicated environment
+variable read **once** at import time; when the variable is unset (default),
+``dispatch`` returns immediately after a single boolean test and the
+production forward path pays no extra cost.
+
+================  ============================================  ==================================
+Hook name         Kwargs delivered to callback                  Env var gate
+================  ============================================  ==================================
+``router``        ``layer_idx: int`` plus tensors:              ``VLLM_CALIB_CAPTURE_ROUTER``
+                  ``router_logits[n_tok, n_experts]``,
+                  ``topk_weights[n_tok, top_k]``,
+                  ``topk_ids[n_tok, top_k]``
+``expert_in``     ``layer_idx: int``,                           ``VLLM_CALIB_CAPTURE_EXPERT``
+                  ``hidden_states[n_tok, hidden]``,
+                  ``topk_ids[n_tok, top_k]``
+``expert_out_weighted``                                          ``VLLM_CALIB_CAPTURE_EXPERT``
+                  ``layer_idx: int``,
+                  ``fused_output[n_tok, hidden]``,
+                  ``topk_weights[n_tok, top_k]``,
+                  ``topk_ids[n_tok, top_k]``
+``expert_out_unweighted``                                        ``VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED``
+                  ``layer_idx: int``,
+                  ``unweighted[n_tok, top_k, hidden]``,
+                  ``topk_ids[n_tok, top_k]``
+                  Precision: the side-store is ``bf16``-cast from the
+                  kernel's fp32 accumulator. ``unweighted.to(fp32) *
+                  topk_weights`` recovers the post-routing-weight expert
+                  output within bf16 precision (relative err < 2e-2 vs
+                  the bf16 ``fused_output`` reference; < 1e-3 vs an fp32
+                  reference).
+                  This payload may be SKIPPED for batches with
+                  ``num_tokens > max_cudagraph_capture_size`` (typically
+                  prefill). The persistent buffer is sized for the
+                  largest CUDA-graph-capture bucket; oversized batches
+                  bypass the side-store rather than risk an out-of-bounds
+                  kernel write. A one-time WARNING is logged the first
+                  time a batch is skipped on this path. Decode-batch
+                  coverage is the primary signal source.
+``expert_mid``    ``layer_idx: int``,                           ``VLLM_CALIB_CAPTURE_EXPERT_MID``
+                  ``intermediate[n_tok, top_k, intermediate_dim]``,
+                  ``topk_ids[n_tok, top_k]``.
+                  The post-SwiGLU pre-quantize tensor in
+                  ``TritonExperts.apply()`` -- exactly the input the
+                  down-projection matmul will consume. Source-patched
+                  into the kernel-driver path between
+                  ``self.activation(...)`` and
+                  ``moe_kernel_quantize_input(...)``. Used by
+                  :mod:`vllm.calibration_imatrix` to populate the
+                  ``ffn_down_exps`` GGUF entry with real per-expert
+                  Σ(silu(gate)·up)² statistics (replaces the prior
+                  uniform-ones placeholder).
+``block_out``     ``layer_idx: int``,                           ``VLLM_CALIB_CAPTURE_BLOCK``
+                  ``output[n_tok, hidden]``
+``linear_in``     ``prefix: str`` (module FQN, e.g.              ``VLLM_CALIB_CAPTURE_IMATRIX``
+                  ``model.layers.3.self_attn.qkv_proj``),
+                  ``x[n_tok, in_features]``.
+                  Source-patched into the three concrete LinearBase
+                  subclasses (``ReplicatedLinear``,
+                  ``ColumnParallelLinear``, ``RowParallelLinear``) in
+                  ``vllm/model_executor/layers/linear.py`` -- the
+                  dispatch is the first statement inside each
+                  ``forward``. ``QKVParallelLinear`` and
+                  ``MergedColumnParallelLinear`` inherit
+                  ``ColumnParallelLinear.forward`` and therefore need no
+                  separate insertion. Consumed by
+                  :mod:`vllm.calibration_imatrix` for per-input-channel
+                  squared-activation statistics.
+``lm_head_in``    ``x[n_tok, hidden]``                          ``VLLM_CALIB_CAPTURE_IMATRIX``
+                  Source-patched into
+                  ``LogitsProcessor._get_logits`` immediately before
+                  ``lm_head.quant_method.apply(...)``. This is the only
+                  correct lm_head surface in vLLM v0.21 -- the literal
+                  ``ParallelLMHead.forward`` raises ``RuntimeError`` and
+                  is never invoked. Consumed by
+                  :mod:`vllm.calibration_imatrix` for the ``output``
+                  (lm_head) GGUF entry.
+================  ============================================  ==================================
+
+Ephemeral-tensor contract
+-------------------------
+The tensors delivered to a callback are views into vLLM's own forward
+workspace and are **NOT** guaranteed to live past callback return. A
+callback that wants to keep data MUST either:
+
+    * ``.clone()`` the tensor (preferred for one-off captures), or
+    * accumulate / reduce into a callback-owned buffer inside the call.
+
+Holding a raw reference and reading it later is undefined behaviour: the
+workspace can be reused, freed, or overwritten by the next forward.
+
+Persistent-buffer contract (``expert_out_unweighted`` only)
+------------------------------------------------------------
+When ``VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED=1``, the ``unweighted`` tensor
+delivered to the ``expert_out_unweighted`` callback is a *slice* of a
+persistent per-layer buffer whose address is fixed for the lifetime of the
+model. The buffer will be overwritten by the NEXT forward call through the
+same MoE layer. Callbacks MUST ``.clone()`` any tensor they intend to
+accumulate or inspect after the callback returns. Raw references held past
+callback return are silently invalidated on the next forward.
+
+Env-var gating
+--------------
+Each signal has its own env var. The flag is sampled once at module import
+(``os.getenv(...) == "1"``) and cached as a module-level boolean. To change
+the setting after import, set the env var **before** importing
+``vllm.calibration_hooks`` (typically before importing ``vllm``).
+
+The reading is **strict-string**: only the literal value ``"1"`` enables
+the hook. Other truthy spellings (``"true"``, ``"yes"``, ``"on"``, ``"2"``)
+are treated as OFF. This is intentionally narrower than the
+``bool(int(os.getenv(...)))`` parser used by :mod:`vllm.envs` for the
+mirrored public ``VLLM_CALIB_CAPTURE_*`` attributes — the mirror exists for
+documentation / discoverability, but the hook fast-path always consults
+the module-level booleans declared here. When wiring the env var from a
+launcher, set it to exactly ``"1"`` (or unset it) to avoid surprises.
+
+Thread-safety
+-------------
+``register_callback`` mutates a module-level dict and SHOULD be called from
+a single thread, **before** any forward pass that could trigger a dispatch.
+``dispatch`` reads the dict lock-free; concurrent forward passes are safe.
+Re-registering during forward is not supported.
+
+Multi-callback (chained) semantics
+----------------------------------
+Each hook name maps to a LIST of callbacks (ordered by registration). A
+single ``dispatch`` call invokes every callback in registration order on
+the same payload. This lets multiple writers share an upstream signal --
+``vllm.calibration_imatrix._on_expert_in`` and
+``vllm.calibration_input_cov._on_expert_in`` can both subscribe to the
+same ``expert_in`` dispatch without one overwriting the other (which was
+the single-slot bug fixed for the calibration-v2 writers campaign). De-
+duplication: registering the SAME callable twice is a no-op (the list
+contains each callable at most once). Clearing: passing ``fn=None`` empties
+the list for that hook.
+
+L2 max-layer early-exit (orthogonal to the per-hook gates)
+----------------------------------------------------------
+The module-level ``_CALIB_MAX_LAYER`` (env: ``VLLM_CALIB_MAX_LAYER``,
+default unset / ``None``) lets a calibration driver tell ``Qwen3MoeModel``
+to stop the decoder-layer loop after a specific layer. When set to a non-
+negative int ``N``, the model forward processes layers ``0..N`` (inclusive)
+and skips ``N+1..num_hidden_layers-1``. The final RMSNorm is still applied
+to keep the return shape consistent with the un-truncated path. The L2 path
+is the foundation for L1 (sequential REAP+REAM per-layer profiling) but
+also useful standalone: any writer whose payload comes from layer ``L``
+or earlier (every per-block / per-expert hook listed above) saves the
+``L+1..end`` compute. Set via :func:`set_calibration_max_layer` (runtime;
+triggers torch.compile re-specialisation on first forward) or via
+``VLLM_CALIB_MAX_LAYER=<N>`` before importing ``vllm`` (preferred --
+specialises ONCE).
+"""
+from __future__ import annotations
+
+import os
+from typing import Any, Callable
+
+__all__ = [
+    "register_callback",
+    "dispatch",
+    "VALID_HOOK_NAMES",
+    "set_calibration_max_layer",
+    "get_calibration_max_layer",
+]
+
+
+# ---------------------------------------------------------------------------
+# Module-level flags. Sampled once at import. The MoE forward path checks
+# these on every call; keep them as plain module attributes so the lookup
+# stays a single LOAD_ATTR + POP_JUMP_IF_FALSE.
+# ---------------------------------------------------------------------------
+_CAPTURE_ROUTER: bool = os.getenv("VLLM_CALIB_CAPTURE_ROUTER", "0") == "1"
+_CAPTURE_EXPERT: bool = os.getenv("VLLM_CALIB_CAPTURE_EXPERT", "0") == "1"
+_CAPTURE_BLOCK: bool = os.getenv("VLLM_CALIB_CAPTURE_BLOCK", "0") == "1"
+_CAPTURE_EXPERT_UNWEIGHTED: bool = (
+    os.getenv("VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED", "0") == "1"
+)
+_CAPTURE_IMATRIX: bool = os.getenv("VLLM_CALIB_CAPTURE_IMATRIX", "0") == "1"
+_CAPTURE_EXPERT_MID: bool = (
+    os.getenv("VLLM_CALIB_CAPTURE_EXPERT_MID", "0") == "1"
+)
+_CAPTURE_LAYER_IN: bool = os.getenv("VLLM_CALIB_CAPTURE_LAYER_IN", "0") == "1"
+
+
+VALID_HOOK_NAMES: frozenset[str] = frozenset(
+    {
+        "router",
+        "expert_in",
+        "expert_out_weighted",
+        "expert_out_unweighted",
+        "expert_mid",
+        "block_out",
+        "layer_in",
+        "linear_in",
+        "lm_head_in",
+    }
+)
+
+
+# Callback registry. Each hook maps to a LIST of callbacks, dispatched in
+# registration order. An empty list means "no callback registered" --
+# dispatch then becomes a no-op even if the env var is on. The list shape
+# is mandatory because more than one writer may legitimately subscribe to
+# the same upstream signal (e.g. ``calibration_imatrix._on_expert_in`` and
+# ``calibration_input_cov._on_expert_in`` both observe ``expert_in``); a
+# single-slot dict silently overwrote whichever was registered first and
+# corrupted the loser's accumulators.
+_callbacks: dict[str, list[Callable[..., None]]] = {
+    name: [] for name in VALID_HOOK_NAMES
+}
+
+
+# Optional: the runner sets the current MoE layer index on this module
+# right before invoking the quant-method ``apply`` path, so kernel-level
+# hooks (e.g. ``expert_out_unweighted``) that do not have direct access to
+# the FusedMoE layer object can report a stable layer_idx. The runner
+# writes this attribute; callbacks SHOULD prefer the explicit ``layer_idx``
+# kwarg in the payload.
+_current_layer_idx: int = -1
+
+
+# ---------------------------------------------------------------------------
+# L2 max-layer early-exit gate. When set to a non-negative int N, the model
+# forward truncates the decoder-layer loop after layer N (inclusive) and
+# returns the post-layer-N hidden states normalized by the final RMSNorm.
+# Subsequent decoder layers (N+1 .. num_hidden_layers-1) are SKIPPED.
+#
+# Sampling discipline mirrors the per-hook capture gates: read from env once
+# at import (so the loop-bound modification specializes under
+# ``support_torch_compile``), with a runtime override via
+# ``set_calibration_max_layer(N)`` for drivers that need to flip it after
+# import (forces a torch.compile recompile on next forward, by design).
+#
+# Read by ``Qwen3MoeModel.forward`` as ``_ch._CALIB_MAX_LAYER``. Default
+# ``None`` => unchanged (no truncation, full forward).
+# ---------------------------------------------------------------------------
+def _parse_max_layer_env() -> int | None:
+    raw = os.getenv("VLLM_CALIB_MAX_LAYER", "")
+    if raw == "" or raw == "-1":
+        return None
+    try:
+        v = int(raw)
+    except ValueError:
+        return None
+    return v if v >= 0 else None
+
+
+_CALIB_MAX_LAYER: int | None = _parse_max_layer_env()
+
+
+def set_calibration_max_layer(layer: int | None) -> None:
+    """Set the L2 max-layer early-exit boundary at runtime.
+
+    Args:
+        layer: ``None`` (or a negative int) disables early-exit (full
+            forward). A non-negative int ``N`` causes the model forward
+            to truncate after decoder layer ``N`` (inclusive) and return
+            the post-norm hidden state at that point. Layers ``N+1 ..``
+            are SKIPPED.
+
+    Notes:
+        * ``Qwen3MoeModel`` is wrapped with ``@support_torch_compile``;
+          changing this value invalidates any specialised compile and
+          will trigger a recompile on the next forward. Set ONCE before
+          the first ``generate()`` call for the cleanest perf profile.
+        * Setting this DOES NOT alter any calibration capture hook; the
+          ``block_out`` / ``expert_in`` / etc. callbacks still fire on
+          layers ``0..N`` as normal (which is the entire L2 win: skip
+          the wasted compute on layers ``> N`` when the calibration
+          writer for that pass only needs layer-N data).
+    """
+    global _CALIB_MAX_LAYER
+    if layer is None or (isinstance(layer, int) and layer < 0):
+        _CALIB_MAX_LAYER = None
+        return
+    if not isinstance(layer, int):
+        raise TypeError(
+            f"set_calibration_max_layer expects int|None, got "
+            f"{type(layer).__name__}"
+        )
+    _CALIB_MAX_LAYER = layer
+
+
+def get_calibration_max_layer() -> int | None:
+    """Return the current L2 max-layer early-exit boundary (or ``None``)."""
+    return _CALIB_MAX_LAYER
+
+
+def register_callback(name: str, fn: Callable[..., None] | None) -> None:
+    """Register (or unregister) a callback for ``name``.
+
+    Args:
+        name: One of the entries in :data:`VALID_HOOK_NAMES`.
+        fn: Callable invoked as ``fn(**payload)``. Pass ``None`` to clear
+            ALL callbacks for ``name`` (used by tests + the re-import
+            pattern). Registering the SAME callable a second time is a
+            no-op (de-duplication via identity check).
+
+    Raises:
+        ValueError: If ``name`` is not a recognised hook name.
+
+    The callback is invoked inside the MoE forward pass on the same CUDA
+    stream / device that produced the tensors. See the module docstring
+    for the ephemeral-tensor contract.
+
+    Multi-callback dispatch: callbacks registered for the same hook are
+    invoked in registration order on every ``dispatch`` call -- see the
+    "Multi-callback (chained) semantics" section of the module docstring.
+    """
+    if name not in VALID_HOOK_NAMES:
+        raise ValueError(
+            f"Unknown calibration hook name {name!r}; "
+            f"valid names are {sorted(VALID_HOOK_NAMES)}"
+        )
+    if fn is None:
+        # Clear the list (preserves the key so dispatch's ``.get`` path
+        # stays a single dict-lookup -- no fallback insertion needed).
+        _callbacks[name] = []
+        return
+    bucket = _callbacks[name]
+    # Identity-based de-dup. The producer side (a calibration module's
+    # setup()) may be called more than once across resume / driver
+    # reinitialisation; without this guard the same callback would fire
+    # multiple times per dispatch and double-count its accumulators.
+    for existing in bucket:
+        if existing is fn:
+            return
+    bucket.append(fn)
+
+
+def dispatch(name: str, **payload: Any) -> None:
+    """Dispatch a captured-tensor payload to the registered callback.
+
+    Fast path: a single boolean test on the env-var gate (an attribute
+    lookup on this module). If the gate is off, this function returns
+    immediately. If the gate is on but no callback is registered, this
+    function returns after a dict lookup.
+
+    Args:
+        name: One of the entries in :data:`VALID_HOOK_NAMES`. Unknown
+            names are silently ignored on the fast path (so a future
+            vLLM-side rename never crashes a calibration run).
+        **payload: Hook-specific kwargs forwarded to the callback. See
+            the table in the module docstring.
+    """
+    # Single-branch gate per hook. Ordered roughly by expected hit rate
+    # during a typical calibration run.
+    if name == "router":
+        if not _CAPTURE_ROUTER:
+            return
+    elif name == "expert_in":
+        if not _CAPTURE_EXPERT:
+            return
+    elif name == "expert_out_weighted":
+        if not _CAPTURE_EXPERT:
+            return
+    elif name == "expert_out_unweighted":
+        if not _CAPTURE_EXPERT_UNWEIGHTED:
+            return
+    elif name == "expert_mid":
+        if not _CAPTURE_EXPERT_MID:
+            return
+    elif name == "block_out":
+        if not _CAPTURE_BLOCK:
+            return
+    elif name == "linear_in":
+        if not _CAPTURE_IMATRIX:
+            return
+    elif name == "lm_head_in":
+        if not _CAPTURE_IMATRIX:
+            return
+    else:
+        # Unknown name. Be defensive: log nothing, do nothing.
+        return
+
+    # Multi-callback fan-out. The list is iterated in registration order
+    # on every dispatch; an empty list is a no-op (the typical case until
+    # a writer module calls ``register_callback`` from its ``setup()``).
+    bucket = _callbacks.get(name)
+    if not bucket:
+        return
+    for fn in bucket:
+        fn(**payload)
