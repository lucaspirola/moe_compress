+# ---------------------------------------------------------------------------
+# Test 12 -- two-segment additivity (spot-preemption simulation)
+# ---------------------------------------------------------------------------
+
+
+def test_two_segment_additivity(tmp_path):
+    """The full imatrix from a 6-prompt run must equal a 3-prompt run +
+    checkpoint + 3-prompt resume. Pins the additive contract that makes
+    preemption recovery sound.
+    """
+    prefix = "model.layers.0.self_attn.o_proj"
+    key = "blk.0.attn_output"
+
+    # Deterministic synthetic "prompts" -- six 4-d activation tensors.
+    prompts = [
+        torch.tensor([[float(i + 1)] * 4, [float(i + 2)] * 4],
+                     dtype=torch.float32)
+        for i in range(6)
+    ]
+
+    # Baseline: process all 6 in one shot.
+    im_a = _reload_imatrix({
+        "VLLM_CALIB_CAPTURE_IMATRIX": "1",
+        "VLLM_CALIB_IMATRIX_MIN_TOKENS": "0",
+    })
+    im_a._prefix_to_keys[prefix] = [key]
+    im_a._accumulators[key] = torch.zeros(4, dtype=torch.float32)
+    im_a._token_counts[key] = 0
+    for x in prompts:
+        im_a._imatrix_accumulate_linear(prefix, x)
+    im_a.set_n_prompts_accumulated(6)
+    baseline = im_a._accumulators[key].clone()
+    baseline_count = im_a._token_counts[key]
+
+    # Segment 1: first 3 prompts then checkpoint.
+    im_b = _reload_imatrix({
+        "VLLM_CALIB_CAPTURE_IMATRIX": "1",
+        "VLLM_CALIB_IMATRIX_MIN_TOKENS": "0",
+    })
+    im_b._prefix_to_keys[prefix] = [key]
+    im_b._accumulators[key] = torch.zeros(4, dtype=torch.float32)
+    im_b._token_counts[key] = 0
+    for x in prompts[:3]:
+        im_b._imatrix_accumulate_linear(prefix, x)
+    im_b.set_n_prompts_accumulated(3)
+    ckpt = str(tmp_path / "seg1.imatrix.ckpt")
+    im_b.dump_imatrix_checkpoint(ckpt)
+
+    # Segment 2: fresh module, load checkpoint, process last 3.
+    im_c = _reload_imatrix({
+        "VLLM_CALIB_CAPTURE_IMATRIX": "1",
+        "VLLM_CALIB_IMATRIX_MIN_TOKENS": "0",
+    })
+    # setup()'s allocation step is emulated -- the buffer that load_
+    # checkpoint copies into MUST already exist for the in-place copy_().
+    im_c._prefix_to_keys[prefix] = [key]
+    im_c._accumulators[key] = torch.zeros(4, dtype=torch.float32)
+    im_c._token_counts[key] = 0
+    loaded = im_c.load_imatrix_checkpoint(ckpt)
+    assert loaded == 3
+    for x in prompts[3:]:
+        im_c._imatrix_accumulate_linear(prefix, x)
+    im_c.set_n_prompts_accumulated(6)
+
+    # Assert: segmented run == baseline run, byte-for-byte.
+    assert torch.equal(im_c._accumulators[key], baseline), (
+        f"additive contract broken: segmented={im_c._accumulators[key]}, "
+        f"baseline={baseline}"
+    )
+    assert im_c._token_counts[key] == baseline_count
+    assert im_c.get_n_prompts_accumulated() == 6
+
+
+# ---------------------------------------------------------------------------
+# Test 13 -- atomic write crash safety
+# ---------------------------------------------------------------------------
+
+
+def test_atomic_write_crash_safety(tmp_path, monkeypatch):
+    """A torch.save failure mid-checkpoint must NOT corrupt a prior
+    checkpoint at the same path. The temp+rename contract guarantees
+    the final path is always either v1 or v2, never a half-write.
+    """
+    im = _reload_imatrix({
+        "VLLM_CALIB_CAPTURE_IMATRIX": "1",
+        "VLLM_CALIB_IMATRIX_MIN_TOKENS": "0",
+    })
+    prefix = "model.layers.0.self_attn.o_proj"
+    key = "blk.0.attn_output"
+    im._prefix_to_keys[prefix] = [key]
+    im._accumulators[key] = torch.tensor(
+        [1.0, 1.0, 1.0, 1.0], dtype=torch.float32,
+    )
+    im._token_counts[key] = 1
+    im.set_n_prompts_accumulated(1)
+
+    # Write v1 cleanly.
+    ckpt = str(tmp_path / "test.imatrix.ckpt")
+    im.dump_imatrix_checkpoint(ckpt)
+    with open(ckpt, "rb") as f:
+        v1_bytes = f.read()
+    assert len(v1_bytes) > 0
+
+    # Mutate state and try to write v2, but make torch.save crash.
+    im._accumulators[key] = torch.tensor(
+        [99.0, 99.0, 99.0, 99.0], dtype=torch.float32,
+    )
+
+    import vllm.calibration_imatrix as mod
+
+    def _boom(*args, **kwargs):
+        raise RuntimeError("simulated mid-write crash")
+
+    monkeypatch.setattr(mod.torch, "save", _boom)
+    with pytest.raises(RuntimeError, match="simulated mid-write crash"):
+        im.dump_imatrix_checkpoint(ckpt)
+
+    # v1 must still be intact at the final path.
+    with open(ckpt, "rb") as f:
+        post_bytes = f.read()
+    assert post_bytes == v1_bytes, (
+        "previous checkpoint was corrupted by the crashed write"
+    )
+
+
+# ---------------------------------------------------------------------------
+# Test 14 -- chunk_count is cumulative after resume
+# ---------------------------------------------------------------------------
+
+
+def test_chunk_count_cumulative_after_resume(tmp_path):
+    """After load_imatrix_checkpoint + additional accumulation,
+    dump_imatrix(path, chunk_count=get_n_prompts_accumulated()) writes
+    the cumulative count to the m_last_chunk field of the .dat file.
+    """
+    im = _reload_imatrix({
+        "VLLM_CALIB_CAPTURE_IMATRIX": "1",
+        "VLLM_CALIB_IMATRIX_MIN_TOKENS": "0",
+    })
+    prefix = "model.layers.0.self_attn.o_proj"
+    key = "blk.0.attn_output"
+    im._prefix_to_keys[prefix] = [key]
+    im._accumulators[key] = torch.zeros(4, dtype=torch.float32)
+    im._token_counts[key] = 0
+
+    # Simulate segment 1: 100 prompts.
+    im._imatrix_accumulate_linear(
+        prefix, torch.ones(2, 4, dtype=torch.float32),
+    )
+    im.set_n_prompts_accumulated(100)
+    ckpt = str(tmp_path / "first.imatrix.ckpt")
+    im.dump_imatrix_checkpoint(ckpt)
+
+    # Fresh module; hydrate; add 50 more.
+    im2 = _reload_imatrix({
+        "VLLM_CALIB_CAPTURE_IMATRIX": "1",
+        "VLLM_CALIB_IMATRIX_MIN_TOKENS": "0",
+    })
+    im2._prefix_to_keys[prefix] = [key]
+    im2._accumulators[key] = torch.zeros(4, dtype=torch.float32)
+    im2._token_counts[key] = 0
+    im2.load_imatrix_checkpoint(ckpt)
+    im2._imatrix_accumulate_linear(
+        prefix, torch.ones(2, 4, dtype=torch.float32),
+    )
+    im2.set_n_prompts_accumulated(150)
+
+    # Final dump with cumulative chunk_count.
+    dat = str(tmp_path / "final.imatrix.dat")
+    im2.dump_imatrix(dat, chunk_count=im2.get_n_prompts_accumulated())
+
+    # Parse m_last_chunk out of the binary file.
+    with open(dat, "rb") as f:
+        data = f.read()
+    # Layout: int32 n_entries, then for each entry:
+    #   int32 name_len, bytes[name_len], int32 ncall, int32 nval,
+    #   float32[nval] values.
+    # Then int32 m_last_chunk, int32 dataset_len, bytes[dataset_len].
+    offset = 0
+    (n_entries,) = struct.unpack_from("<i", data, offset); offset += 4
+    for _ in range(n_entries):
+        (name_len,) = struct.unpack_from("<i", data, offset); offset += 4
+        offset += name_len
+        offset += 4   # ncall
+        (nval,) = struct.unpack_from("<i", data, offset); offset += 4
+        offset += nval * 4
+    (m_last_chunk,) = struct.unpack_from("<i", data, offset)
+    assert m_last_chunk == 150, (
+        f"m_last_chunk={m_last_chunk}, expected cumulative 150"
+    )
+
+
+# ---------------------------------------------------------------------------
+# Test 15 -- final .dat write is atomic (tmp+rename)
+# ---------------------------------------------------------------------------
+
+
+def test_final_dat_write_is_atomic(tmp_path, monkeypatch):
+    """``dump_imatrix`` → ``_write_dat`` must use the tmp+rename pattern
+    so a kill during the final write leaves any previous .imatrix.dat
+    on disk intact, not half-overwritten.
+    """
+    im = _reload_imatrix({
+        "VLLM_CALIB_CAPTURE_IMATRIX": "1",
+        "VLLM_CALIB_IMATRIX_MIN_TOKENS": "0",
+    })
+    prefix = "model.layers.0.self_attn.o_proj"
+    key = "blk.0.attn_output"
+    im._prefix_to_keys[prefix] = [key]
+    im._accumulators[key] = torch.tensor(
+        [1.0, 1.0, 1.0, 1.0], dtype=torch.float32,
+    )
+    im._token_counts[key] = 1
+
+    # Write v1 cleanly.
+    dat = str(tmp_path / "final.imatrix.dat")
+    im.dump_imatrix(dat, chunk_count=1)
+    with open(dat, "rb") as f:
+        v1_bytes = f.read()
+
+    # Mutate state and try to write v2, but crash mid-write.
+    im._accumulators[key] = torch.tensor(
+        [99.0, 99.0, 99.0, 99.0], dtype=torch.float32,
+    )
+
+    import vllm.calibration_imatrix as mod
+    original_replace = mod.os.replace
+
+    def _boom_replace(src, dst):
+        raise RuntimeError("simulated mid-rename crash")
+
+    monkeypatch.setattr(mod.os, "replace", _boom_replace)
+    with pytest.raises(RuntimeError, match="simulated mid-rename crash"):
+        im.dump_imatrix(dat, chunk_count=2)
+
+    # v1 at the final path must be intact (no half-write).
+    with open(dat, "rb") as f:
+        post_bytes = f.read()
+    assert post_bytes == v1_bytes, (
+        "final .imatrix.dat was corrupted by the crashed write -- "
+        "atomicity contract broken"
+    )
+    # Restore for any post-test cleanup.
+    monkeypatch.setattr(mod.os, "replace", original_replace)
+
+
+if __name__ == "__main__":
+    sys.exit(pytest.main([__file__, "-v"]))
