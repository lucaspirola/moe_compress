+++ b/vllm/calibration_reap_scores.py
@@ -0,0 +1,341 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""REAP per-(layer, expert) saliency-score capture for calibration-v2.
+
+Computes S_j = (1/|X_j|) · sum(g_j(x) · ||f_j(x)||_2) per (layer, expert)
+during a calibration forward pass, via two source-patched hooks:
+
+* ``router`` (vllm/model_executor/layers/fused_moe/moe_runner.py)
+  dispatches ``(layer_idx, router_logits, topk_weights, topk_ids)`` per
+  MoE layer forward. This module stashes ``topk_weights`` keyed by
+  ``layer_idx`` for the immediately-following ``expert_out_unweighted``
+  callback to match.
+
+* ``expert_out_unweighted`` (vllm/model_executor/layers/fused_moe/experts/
+  triton_moe.py) dispatches ``(layer_idx, unweighted, topk_ids)`` after
+  ``invoke_fused_moe_triton_kernel`` returns. This module computes
+  per-token per-top-k ``||f_j||_2``, multiplies by the matching
+  ``topk_weights``, and scatter-accumulates into per-(layer, expert)
+  CPU buffers.
+
+Env-var gating
+--------------
+``VLLM_CALIB_CAPTURE_REAP_SCORES=1`` activates the module. Requires:
+
+* ``VLLM_CALIB_CAPTURE_ROUTER=1`` (router hook fires)
+* ``VLLM_CALIB_CAPTURE_EXPERT_UNWEIGHTED=1`` (Triton kernel hook fires)
+* ``VLLM_USE_FLASHINFER_MOE_FP16=0`` (forces Triton MoE backend;
+  ``expert_out_unweighted`` is NOT available on the FlashInfer
+  monolithic path -- ``MoERunner.__init__`` will AssertionError at
+  model load if the FlashInfer path is selected with capture enabled)
+
+The driver (``build_self_traces_calib_vllm.py``) sets all four env vars
+BEFORE the first vllm import when ``--capture-reap-scores`` is passed.
+
+CUDA-graph compatibility
+------------------------
+Accumulators live on CPU. The callbacks are dispatched from Python
+synchronously after the kernel returns; no in-kernel allocation occurs.
+Safe for CUDA-graph capture.
+
+Resumability
+------------
+Mirrors ``vllm.calibration_imatrix``: periodic ``dump_reap_scores_checkpoint``
+during the run, ``load_reap_scores_checkpoint`` on ``--resume``. The final
+``dump_reap_scores`` writes the normalized S_j payload via
+``moe_compress.utils.cached_calibration_signals.save_reap_scores`` (Item 0).
+"""
+from __future__ import annotations
+
+import logging
+import os
+from pathlib import Path
+from typing import Any
+
+import torch
+
+import vllm.calibration_hooks as _ch
+
+log = logging.getLogger(__name__)
+
+__all__ = [
+    "setup",
+    "dump_reap_scores",
+    "dump_reap_scores_checkpoint",
+    "load_reap_scores_checkpoint",
+    "get_n_prompts_accumulated",
+    "set_n_prompts_accumulated",
+]
+
+# Sampled at import time -- matches calibration_imatrix pattern.
+_CAPTURE_REAP_SCORES: bool = (
+    os.getenv("VLLM_CALIB_CAPTURE_REAP_SCORES", "0") == "1"
+)
+
+# Per-layer-rank CPU accumulators.
+_REAP_SCORE_ACCUM: dict[int, torch.Tensor] = {}   # rank -> [n_experts] float32
+_REAP_TOKEN_COUNTS: dict[int, torch.Tensor] = {}  # rank -> [n_experts] int64
+
+# Per-layer router-weight stash. Cleared after each expert_out_unweighted use.
+_ROUTER_WEIGHTS_STASH: dict[int, torch.Tensor] = {}
+
+_LAYER_ID_TO_RANK: dict[int, int] = {}
+_N_LAYERS: int = 0
+_N_EXPERTS: int = 0
+
+# Cumulative prompt counter mirroring imatrix.
+_n_prompts_accumulated: int = 0
+_CHECKPOINT_SCHEMA_VERSION: int = 1
+
+
+def get_n_prompts_accumulated() -> int:
+    return _n_prompts_accumulated
+
+
+def set_n_prompts_accumulated(n: int) -> None:
+    global _n_prompts_accumulated
+    if n < 0:
+        raise ValueError(f"n must be >= 0; got {n}")
+    _n_prompts_accumulated = int(n)
+
+
+def _resolve_model(llm: Any) -> Any | None:
+    """Walk well-known attribute paths to find the live nn.Module."""
+    candidates = [
+        ("llm_engine", "model_executor", "driver_worker", "model_runner",
+         "model"),
+        ("llm_engine", "model_executor", "model_runner", "model"),
+        ("model_executor", "driver_worker", "model_runner", "model"),
+        ("model_runner", "model"),
+    ]
+    for path in candidates:
+        obj: Any = llm
+        ok = True
+        for attr in path:
+            obj = getattr(obj, attr, None)
+            if obj is None:
+                ok = False
+                break
+        if ok:
+            return obj
+    return None
+
+
+def setup(llm: Any) -> None:
+    """Discover MoE layers, pre-allocate accumulators, register callbacks.
+
+    Idempotent: calling twice does not double-allocate.
+    """
+    global _N_LAYERS, _N_EXPERTS
+
+    if not _CAPTURE_REAP_SCORES:
+        log.info("calibration_reap_scores: env gate off; no-op setup.")
+        return
+
+    model = _resolve_model(llm)
+    if model is None:
+        log.warning(
+            "calibration_reap_scores: could not resolve model from LLM; "
+            "callbacks will be registered but accumulators will be lazily "
+            "allocated at first router dispatch."
+        )
+
+    # Discover MoE layers by attribute presence.
+    n_layers = 0
+    n_experts_seen: int | None = None
+    if model is not None:
+        for name, module in model.named_modules():
+            moe_layer_id = getattr(module, "moe_layer_id", None)
+            num_experts = getattr(module, "num_experts", None)
+            if not (isinstance(moe_layer_id, int)
+                    and isinstance(num_experts, int) and num_experts > 0):
+                continue
+            _LAYER_ID_TO_RANK[moe_layer_id] = n_layers
+            if n_experts_seen is None:
+                n_experts_seen = num_experts
+            elif n_experts_seen != num_experts:
+                log.warning(
+                    "calibration_reap_scores: mixed expert counts "
+                    "(%d vs first-seen %d at %s); using first.",
+                    num_experts, n_experts_seen, name,
+                )
+            n_layers += 1
+
+    _N_LAYERS = n_layers
+    _N_EXPERTS = int(n_experts_seen) if n_experts_seen is not None else 0
+
+    # Pre-allocate CPU accumulators.
+    for rank in range(_N_LAYERS):
+        if rank not in _REAP_SCORE_ACCUM:
+            _REAP_SCORE_ACCUM[rank] = torch.zeros(
+                _N_EXPERTS, dtype=torch.float32,
+            )
+            _REAP_TOKEN_COUNTS[rank] = torch.zeros(
+                _N_EXPERTS, dtype=torch.int64,
+            )
+
+    _ch.register_callback("router", _on_router)
+    _ch.register_callback("expert_out_unweighted", _on_expert_out_unweighted)
+
+    log.info(
+        "calibration_reap_scores: setup complete -- %d MoE layers, "
+        "%d experts/layer; callbacks registered for "
+        "router + expert_out_unweighted.",
+        _N_LAYERS, _N_EXPERTS,
+    )
+
+
+def _on_router(layer_idx: int, router_logits: torch.Tensor,
+               topk_weights: torch.Tensor, topk_ids: torch.Tensor,
+               **_: Any) -> None:
+    """Stash per-layer topk_weights for the matching expert_out_unweighted."""
+    if not _CAPTURE_REAP_SCORES:
+        return
+    _ROUTER_WEIGHTS_STASH[layer_idx] = topk_weights.detach().cpu().to(torch.float32)
+
+
+def _on_expert_out_unweighted(layer_idx: int, unweighted: torch.Tensor,
+                              topk_ids: torch.Tensor, **_: Any) -> None:
+    """Scatter-reduce per-expert ``g_j · ||f_j||_2`` into the accumulators.
+
+    ``unweighted`` is ``[n_tok, top_k, hidden]`` bf16 (a slice of the
+    persistent buffer in the Triton kernel); must be cloned immediately
+    because the buffer is overwritten by the next forward.
+    """
+    if not _CAPTURE_REAP_SCORES:
+        return
+
+    tw = _ROUTER_WEIGHTS_STASH.get(layer_idx)
+    if tw is None:
+        log.warning(
+            "calibration_reap_scores: expert_out_unweighted at layer %d "
+            "without a preceding router dispatch (stash miss); skipping.",
+            layer_idx,
+        )
+        return
+
+    rank = _LAYER_ID_TO_RANK.get(layer_idx)
+    if rank is None:
+        raise RuntimeError(
+            f"calibration_reap_scores: layer_idx={layer_idx} was not "
+            f"discovered by setup() — the MoE layer must be visible via "
+            f"named_modules() with the moe_layer_id attribute set. "
+            f"Late-discovered layers would force the accumulators to grow, "
+            f"corrupting already-allocated buffers for other layers. Fix "
+            f"the setup() pass to find ALL MoE layers (or this layer's "
+            f"FusedMoE module is missing the moe_layer_id attribute)."
+        )
+
+    # Move to CPU + float32 for the math.
+    uw = unweighted.detach().cpu().to(torch.float32)   # [n_tok, top_k, hidden]
+    norms = uw.norm(dim=-1)                             # [n_tok, top_k]
+    tw_cpu = tw[:uw.shape[0], :uw.shape[1]]             # trim if mismatched
+    contrib = (tw_cpu * norms).reshape(-1)              # [n_tok * top_k]
+    ids = topk_ids.detach().cpu().to(torch.int64).reshape(-1)
+
+    score_accum = _REAP_SCORE_ACCUM[rank]
+    count_accum = _REAP_TOKEN_COUNTS[rank]
+    score_accum.scatter_add_(0, ids, contrib)
+    count_accum.scatter_add_(0, ids, torch.ones_like(ids, dtype=torch.int64))
+
+
+def dump_reap_scores(jsonl_path: str | Path) -> None:
+    """Normalize and write the final S_j sidecar via the Item-0 helper."""
+    if not _CAPTURE_REAP_SCORES:
+        return
+
+    # Import here (not at module top) so the dependency is lazy.
+    from moe_compress.utils.cached_calibration_signals import (
+        Stage2ReapPayload, save_reap_scores, SCHEMA_VERSIONS,
+    )
+
+    if _N_LAYERS == 0 or _N_EXPERTS == 0:
+        log.warning(
+            "calibration_reap_scores: no MoE layers seen; skipping dump."
+        )
+        return
+
+    score_rows = []
+    count_rows = []
+    for rank in range(_N_LAYERS):
+        scores = _REAP_SCORE_ACCUM.get(rank)
+        counts = _REAP_TOKEN_COUNTS.get(rank)
+        if scores is None or counts is None:
+            score_rows.append(torch.zeros(_N_EXPERTS, dtype=torch.float32))
+            count_rows.append(torch.zeros(_N_EXPERTS, dtype=torch.int64))
+            continue
+        safe = counts.clamp(min=1).to(torch.float32)
+        score_rows.append(scores / safe)
+        count_rows.append(counts)
+    reap_scores = torch.stack(score_rows)
+    token_counts = torch.stack(count_rows)
+
+    payload = Stage2ReapPayload(
+        schema_version=SCHEMA_VERSIONS["reap_scores"],
+        n_experts=_N_EXPERTS,
+        n_layers=_N_LAYERS,
+        reap_scores=reap_scores,
+        token_counts=token_counts,
+    )
+    save_reap_scores(payload, Path(jsonl_path))
+    log.info(
+        "calibration_reap_scores: wrote %d-layer × %d-expert sidecar "
+        "next to %s", _N_LAYERS, _N_EXPERTS, jsonl_path,
+    )
+
+
+def dump_reap_scores_checkpoint(ckpt_path: str) -> None:
+    """Atomic checkpoint of raw accumulator state for resume."""
+    if not _CAPTURE_REAP_SCORES:
+        return
+    payload = {
+        "schema_version": _CHECKPOINT_SCHEMA_VERSION,
+        "n_prompts_accumulated": _n_prompts_accumulated,
+        "n_layers": _N_LAYERS,
+        "n_experts": _N_EXPERTS,
+        "layer_id_to_rank": dict(_LAYER_ID_TO_RANK),
+        "score_accum": {r: v.clone() for r, v in _REAP_SCORE_ACCUM.items()},
+        "token_counts": {r: v.clone() for r, v in _REAP_TOKEN_COUNTS.items()},
+    }
+    tmp = ckpt_path + ".tmp"
+    with open(tmp, "wb") as f:
+        torch.save(payload, f)
+        f.flush()
+        os.fsync(f.fileno())
+    os.replace(tmp, ckpt_path)
+    _dir_fd = os.open(os.path.dirname(ckpt_path) or ".", os.O_RDONLY)
+    try:
+        os.fsync(_dir_fd)
+    except OSError:
+        pass
+    finally:
+        os.close(_dir_fd)
+
+
+def load_reap_scores_checkpoint(ckpt_path: str) -> int:
+    """Hydrate accumulators from a previous run's checkpoint. Returns
+    n_prompts_accumulated; 0 if file missing."""
+    global _N_LAYERS, _N_EXPERTS, _n_prompts_accumulated
+    if not os.path.exists(ckpt_path):
+        return 0
+    payload = torch.load(ckpt_path, map_location="cpu", weights_only=False)
+    schema = int(payload.get("schema_version", 0))
+    if schema != _CHECKPOINT_SCHEMA_VERSION:
+        raise ValueError(
+            f"calibration_reap_scores: checkpoint at {ckpt_path} has "
+            f"schema_version={schema}, expected {_CHECKPOINT_SCHEMA_VERSION}. "
+            f"Delete the checkpoint to restart from scratch."
+        )
+    _n_prompts_accumulated = int(payload["n_prompts_accumulated"])
+    _N_LAYERS = int(payload["n_layers"])
+    _N_EXPERTS = int(payload["n_experts"])
+    _LAYER_ID_TO_RANK.clear()
+    _LAYER_ID_TO_RANK.update({int(k): int(v) for k, v in payload.get(
+        "layer_id_to_rank", {}).items()})
+    _REAP_SCORE_ACCUM.clear()
+    _REAP_TOKEN_COUNTS.clear()
+    for r, t in payload.get("score_accum", {}).items():
+        _REAP_SCORE_ACCUM[int(r)] = t.to(torch.float32).clone()
+    for r, t in payload.get("token_counts", {}).items():
+        _REAP_TOKEN_COUNTS[int(r)] = t.to(torch.int64).clone()
+    return _n_prompts_accumulated
diff --git a/vllm/calibration_router_logits_stats.py b/vllm/calibration_router_logits_stats.py
